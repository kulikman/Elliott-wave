ANTHROPIC_API_KEY=sk-ant-...

# Рыночные данные по акциям (крипта берётся с Binance без ключа).
# Бесплатный ключ: https://www.tiingo.com/  →  Account → API → Token
TIINGO_API_KEY=

# Модель для извлечения AKU и chapter map
EXTRACTION_MODEL=claude-opus-4-6

# Модель для Vision (диаграммы из PDF)
VISION_MODEL=claude-opus-4-6

# Модель для формализации правил
FORMALIZATION_MODEL=claude-opus-4-6

# Максимум AKU за один запрос (anti-hallucination guard)
MAX_AKU_PER_REQUEST=10

# Максимальный размер секции в словах перед автоматическим разбиением
MAX_SECTION_WORDS=3000

# Telegram-уведомления о сигналах (необязательно). Без них трейдер работает,
# просто не шлёт сообщения. Бот: @BotFather → /newbot → токен.
# chat_id: напиши боту, затем https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
