ANTHROPIC_API_KEY=sk-ant-...

# Модель для извлечения AKU и chapter map
EXTRACTION_MODEL=claude-opus-4-6

# Модель для Vision (диаграммы из PDF)
VISION_MODEL=claude-opus-4-6

# Модель для формализации правил
FORMALIZATION_MODEL=claude-opus-4-6

# Максимум AKU за один запрос (anti-hallucination guard)
MAX_AKU_PER_REQUEST=10

# Максимальный размер секции в словах перед автоматическим разбиением
MAX_SECTION_WORDS=3000
