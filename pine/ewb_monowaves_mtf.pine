wH      = input.int(3, "Толщина линий", group = grpH, minval = 1, maxval = 5)

grpHtfMap = "HTF wave map"
showHtfWaveMap = input.bool(true, "Show auto higher-TF wave map", group = grpHtfMap,
     tooltip = "Визуальный слой вложенности: показывает ближайшие старшие активные моноволны, не меняя торговый HTF-фильтр.")
htfContextLevels = input.int(2, "Auto higher-TF levels", group = grpHtfMap, minval = 1, maxval = 4,
     tooltip = "1D: W(+M), 4H: D+W, 1H: 4H+D, 15m/30m: 1H+4H. Увеличьте до 3-4 для более дальнего контекста.")
htfContextSegments = input.int(3, "Confirmed HTF segments", group = grpHtfMap, minval = 1, maxval = 6,
     tooltip = "Сколько последних завершённых HTF-моноволн рисовать для контекста.")
showHtfWaveMapLabels = input.bool(true, "Label active HTF waves", group = grpHtfMap,
     tooltip = "Подписывает активные старшие моноволны справа от последнего бара.")
htfContextWidth = input.int(2, "HTF map line width", group = grpHtfMap, minval = 1, maxval = 5)
htfMapRightOffset = input.int(24, "HTF map label right offset", group = grpHtfMap, minval = 4, maxval = 120,
     tooltip = "Сдвигает подписи старших ТФ вправо от последнего бара, чтобы они не закрывали свечи.")
colMap1h = input.color(color.blue, "1H context color", group = grpHtfMap)
colMap4h = input.color(color.orange, "4H context color", group = grpHtfMap)
colMapD = input.color(color.purple, "1D context color", group = grpHtfMap)
colMapW = input.color(color.fuchsia, "1W context color", group = grpHtfMap)
colMapM = input.color(color.gray, "1M context color", group = grpHtfMap)

grpActive = "Активная волна последнего бара"
showActiveWave = input.bool(true, "Показывать активную волну текущего ТФ", group = grpActive,
     tooltip = "Показывает незавершённую моноволну от последнего подтверждённого pivot до последнего бара. Это live-контекст, не подтверждённая фигура.")
