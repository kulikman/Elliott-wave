//@version=6
// =============================================================================
// Elliott Wave Brain — Monowaves MTF
// Уровень 1 методологии Нили: идентификация моноволн (Гл.2)
// + MTF-синхронизация: разлиновка на текущем и старшем таймфреймах
//
// Моноволна (Neely): движение цены между двумя сменами направления.
// На этом уровне НЕ делается классификация :3/:5 и распознавание фигур —
// это следующие уровни (см. pine/README.md и indicator-spec/spec_vN.json).
// =============================================================================
indicator("Elliott Wave Brain — Monowaves MTF", "EWB Mono",
     overlay = true, max_labels_count = 500, max_lines_count = 500, max_boxes_count = 200)

// ───────────────────────────── ВВОД ─────────────────────────────
grpDet  = "Идентификация моноволн (Уровень 1)"
useATR  = input.bool(true,  "Порог разворота по ATR", group = grpDet)
atrLen  = input.int(14,     "ATR период",             group = grpDet, minval = 1)
atrMult = input.float(2.5,  "ATR множитель",          group = grpDet, minval = 0.1, step = 0.1,
     tooltip = "Чем больше — тем крупнее моноволны (меньше шума)")
pctRev  = input.float(2.0,  "Порог разворота, %",     group = grpDet, minval = 0.1, step = 0.1,
     tooltip = "Используется когда ATR-порог выключен")

grpC    = "Текущий таймфрейм"
showC   = input.bool(true,  "Показывать моноволны текущего ТФ", group = grpC)
colCUp  = input.color(color.teal, "Восходящая моноволна", group = grpC)
colCDn  = input.color(color.red,  "Нисходящая моноволна", group = grpC)
wC      = input.int(2, "Толщина линий", group = grpC, minval = 1, maxval = 4)

grpH    = "Старший таймфрейм (MTF-синхронизация)"
showH   = input.bool(true,  "Показывать моноволны старшего ТФ", group = grpH)
htf     = input.timeframe("240", "Старший таймфрейм", group = grpH)
colH    = input.color(color.orange, "Цвет старшего ТФ", group = grpH)
wH      = input.int(3, "Толщина линий", group = grpH, minval = 1, maxval = 5)

grpL    = "Метки"
showLbl = input.bool(false, "Нумеровать моноволны (m0, m1, ...)", group = grpL)

grpS    = "Правило подобия и баланса (AKU-0003, Уровень 3)"
showSim = input.bool(false, "Помечать смену Порядка между моноволнами", group = grpS,
     tooltip = "Правило Нили: две смежные моноволны могут быть одного Порядка, " +
     "только если меньшая >= 1/3 большей по ЦЕНЕ ИЛИ по ВРЕМЕНИ. " +
     "Если нет — разный Порядок, кандидат на сжатие (compaction).")

grpClass = "Определитель Правил (Уровень 2, AKU-0141/0142)"
showClass = input.bool(false, "Классифицировать моноволны (Пр.1-7 + Условие a-f)", group = grpClass,
     tooltip = "Для каждой моноволны m1: m2/m1 -> Правило 1-7 (Определитель Правил), " +
     "m0/m1 -> Условие a-f. Это структурная классификация Нили (Гл.3).")
colClass = input.color(color.fuchsia, "Цвет меток классификации", group = grpClass)

grpFig  = "Распознавание фигур по Структурным Сериям (Уровень 3, AKU-0158..0166)"
showFig = input.bool(false, "Распознавать фигуры (Импульс/Зигзаг/Плоская/Треугольник)", group = grpFig,
     tooltip = "Сопоставление окна базовых структур (:5/:3) со Структурными Сериями A-E (Гл.4). " +
     "Базовая разметка: точные метки :F3/:c3 требуют Индикаторов положения (Гл.3), " +
     "поэтому Зигзаг и хвост Импульса могут совпадать (правило 'Зигзаг или Импульс?' AKU-0166).")
colFig  = input.color(color.aqua, "Цвет рамок фигур", group = grpFig)

grpTrade = "Торговый слой Антона (research: Flat/DC fade)"
showTrade = input.bool(true, "Показывать торговые сигналы Flat/DC", group = grpTrade,
     tooltip = "Research-слой после Sprint 6: торгуются только подтверждённые Flat и Double Correction в fade-направлении. Impulse/Triangle не дают вход.")
showTradeMarkers = input.bool(false, "Рисовать исторические trade-метки/зоны", group = grpTrade,
     tooltip = "Выключено по умолчанию, чтобы график не шумел. Таблица, статус и alerts продолжают работать.")
showNoise = input.bool(false, "Показывать Impulse/Triangle как NO TRADE", group = grpTrade)
flatProb = input.float(61.0, "Вероятность Flat fade, %", group = grpTrade, minval = 0, maxval = 100, step = 0.1,
     tooltip = "Оценка из Sprint 6/all-TF: Flat fade около 60-63% hit-rate; это research, не гарантия.")
dcProb = input.float(89.0, "Вероятность Double Correction fade, %", group = grpTrade, minval = 0, maxval = 100, step = 0.1,
     tooltip = "Оценка из Sprint 6/all-TF: DC fade сильный, но редкий сигнал; n меньше, поэтому использовать осторожно.")
maxHybridPivots = input.int(40, "Память hybrid-пивотов", group = grpTrade, minval = 10, maxval = 200)
tradeMaxAgeBars = input.int(80, "Срок актуальности сигнала, баров", group = grpTrade, minval = 1, maxval = 500,
     tooltip = "После этого количества баров сигнал помечается EXPIRED, если TP/SL ещё не достигнуты.")
stockOnlyMode = input.bool(true, "Только акции: crypto = UNSUPPORTED", group = grpTrade,
     tooltip = "Probability calibration v0 построена по акциям. Для crypto Action now будет WAIT/UNSUPPORTED.")
actionFreshBars = input.int(3, "Свежий вход: максимум баров", group = grpTrade, minval = 0, maxval = 50,
     tooltip = "BUY/SELL разрешён только пока сигнал свежий. Позже таблица покажет WAIT/STALE.")
maxEntryProgress = input.float(0.35, "Поздно входить после % пути к TP", group = grpTrade, minval = 0.05, maxval = 0.95, step = 0.05,
     tooltip = "Если цена уже прошла эту долю пути от Entry к TP, Action now станет WAIT/LATE.")
minActionRR = input.float(1.0, "Минимальный текущий R:R", group = grpTrade, minval = 0.1, maxval = 10.0, step = 0.1,
     tooltip = "Если оставшаяся прибыль к риску меньше порога, Action now станет WAIT/RR BAD.")
useHtfFilter = input.bool(true, "Использовать HTF-фильтр", group = grpTrade,
     tooltip = "BUY блокируется при DOWN bias старшего ТФ, SELL блокируется при UP bias старшего ТФ.")

// ───────────────────────────── ТИПЫ ─────────────────────────────
// Состояние ZigZag-детектора моноволн (по reversal-порогу).
// Один экземпляр на каждый таймфрейм — состояние не пересекается.
type ZZState
    int   dir        = 0    // 1 = ищем максимум (вверх), -1 = ищем минимум (вниз)
    float pivotPrice = na   // цена последнего подтверждённого пивота
    int   pivotBar   = na   // bar_index последнего пивота
    float extPrice   = na   // текущий экстремум-кандидат
    int   extBar      = na
    int   count       = 0   // сколько моноволн уже подтверждено
    float lastPriceLen = na // длина предыдущей моноволны по цене
    int   lastTimeLen  = na // длина предыдущей моноволны по времени (в барах)
    bool  hasPrev      = false
    float len0        = na  // длина m0 (для Определителя Правил)
    float len1        = na  // длина m1

// Результат шага детектора
type ZZResult
    bool  confirmed  = false  // подтверждён ли новый пивот на этом шаге
    float price      = na     // цена подтверждённого пивота
    int   bar        = na     // bar_index пивота
    float prevPrice  = na     // предыдущий пивот (начало завершившейся моноволны)
    int   prevBar    = na
    int   dir        = 0      // направление завершившейся моноволны (1/-1)
    int   idx        = 0      // порядковый номер моноволны
    float priceLen   = na     // длина этой моноволны по цене
    int   timeLen    = na     // длина этой моноволны по времени (в барах)
    bool  simChecked = false  // проверено ли правило подобия со смежной
    bool  similar    = false  // могут ли быть одного Порядка (AKU-0003)
    int   ruleNo     = 0      // Определитель Правил: Правило 1-7 для предыдущей m1 (AKU-0141)
    string condLetter = ""    // Условие a-f (AKU-0142)

// ───────────── ОПРЕДЕЛИТЕЛЬ ПРАВИЛ (AKU-0141, Гл.3 стр.3-22) ──────────
// m2/m1 -> Правило 1-7. Допуск ±4% на границе 61.8% (Правило 3) — конвенция
// допусков Фибоначчи (AKU «±4%», стр.3-34).
classifyRule(float m2, float m1) =>
    float ratio = m1 != 0 ? m2 / m1 : na
    int rule = 0
    if not na(ratio)
        if math.abs(ratio - 0.618) <= 0.618 * 0.04
            rule := 3
        else if ratio < 0.382
            rule := 1
        else if ratio < 0.618
            rule := 2
        else if ratio < 1.000
            rule := 4
        else if ratio < 1.618
            rule := 5
        else if ratio <= 2.618
            rule := 6
        else
            rule := 7
    rule

// m0/m1 -> Условие a-f (AKU-0142). Таблицы условий по каждому Правилу
// (ch03-length-ratio-rules.md).
classifyCond(int rule, float m0, float m1) =>
    float r = m1 != 0 ? m0 / m1 : na
    string c = ""
    if not na(r) and rule > 0
        if rule == 1
            c := r < 0.618 ? "a" : r < 1.000 ? "b" : r < 1.618 ? "c" : "d"
        else if rule == 2
            c := r < 0.382 ? "a" : r < 0.618 ? "b" : r < 1.000 ? "c" : r <= 1.618 ? "d" : "e"
        else if rule == 3
            c := r < 0.382 ? "a" : r < 0.618 ? "b" : r < 1.000 ? "c" : r < 1.618 ? "d" : r <= 2.618 ? "e" : "f"
        else if rule == 4
            c := r < 0.382 ? "a" : r < 1.000 ? "b" : r < 1.618 ? "c" : r <= 2.618 ? "d" : "e"
        else
            c := r < 1.000 ? "a" : r < 1.618 ? "b" : r <= 2.618 ? "c" : "d"
    c

// Вероятная структурная метка m1 по Правилу (первый кандидат из Структурного списка,
// AKU Правил 1-7). Малый откат -> :5 (импульс); средний -> :F3 (коррекция);
// большой (Пр.6-7) -> "?" (нужны Индикаторы положения).
ruleToStructure(int rule) =>
    rule == 1 or rule == 2 ? ":5" : (rule == 3 or rule == 4 or rule == 5) ? ":F3" : rule >= 6 ? "?" : ""

// ──────────────────────── ДЕТЕКТОР МОНОВОЛН ──────────────────────
// Reversal-ZigZag: моноволна завершается, когда цена развернулась
// от экстремума более чем на `rev` (порог разворота).
method step(ZZState s, float h, float l, float rev) =>
    ZZResult r = ZZResult.new()

    if na(s.extPrice)
        // Инициализация на первом баре
        s.extPrice   := h
        s.extBar     := bar_index
        s.pivotPrice := l
        s.pivotBar   := bar_index
        s.dir        := 1
    else if s.dir > 0
        // Тренд вверх: следим за максимумом
        if h > s.extPrice
            s.extPrice := h
            s.extBar   := bar_index
        // Разворот вниз → подтверждаем максимум как пивот
        if l < s.extPrice - rev
            r.confirmed := true
            r.price     := s.extPrice
            r.bar       := s.extBar
            r.prevPrice := s.pivotPrice
            r.prevBar   := s.pivotBar
            r.dir       := 1
            r.idx       := s.count
            s.count     += 1
            s.pivotPrice := s.extPrice
            s.pivotBar   := s.extBar
            s.dir        := -1
            s.extPrice   := l
            s.extBar     := bar_index
    else
        // Тренд вниз: следим за минимумом
        if l < s.extPrice
            s.extPrice := l
            s.extBar   := bar_index
        // Разворот вверх → подтверждаем минимум как пивот
        if h > s.extPrice + rev
            r.confirmed := true
            r.price     := s.extPrice
            r.bar       := s.extBar
            r.prevPrice := s.pivotPrice
            r.prevBar   := s.pivotBar
            r.dir       := -1
            r.idx       := s.count
            s.count     += 1
            s.pivotPrice := s.extPrice
            s.pivotBar   := s.extBar
            s.dir        := 1
            s.extPrice   := h
            s.extBar     := bar_index

    // Правило подобия и баланса (AKU-0003): сравнить с предыдущей моноволной
    if r.confirmed and not na(r.prevBar)
        r.priceLen := math.abs(r.price - r.prevPrice)
        r.timeLen  := r.bar - r.prevBar
        if s.hasPrev
            r.simChecked := true
            float pmin = math.min(r.priceLen, s.lastPriceLen)
            float pmax = math.max(r.priceLen, s.lastPriceLen)
            float tmin = math.min(r.timeLen,  s.lastTimeLen)
            float tmax = math.max(r.timeLen,  s.lastTimeLen)
            // similar, если выполнено хотя бы одно условие: цена ИЛИ время
            r.similar := (pmax > 0 and pmin >= pmax / 3.0) or (tmax > 0 and tmin >= tmax / 3.0)
        // Классификация предыдущей моноволны m1 (m0=len0, m1=len1, m2=текущая)
        if not na(s.len0) and not na(s.len1) and s.len1 != 0
            r.ruleNo     := classifyRule(r.priceLen, s.len1)
            r.condLetter := classifyCond(r.ruleNo, s.len0, s.len1)
        s.len0 := s.len1
        s.len1 := r.priceLen
        s.lastPriceLen := r.priceLen
        s.lastTimeLen  := r.timeLen
        s.hasPrev      := true
    r

// Отрисовка одной завершившейся моноволны
drawMono(ZZResult r, color cUp, color cDn, int width, bool isHTF, color cHTF, bool lbl) =>
    if r.confirmed and not na(r.prevBar)
        col = isHTF ? cHTF : (r.dir > 0 ? cUp : cDn)
        line.new(r.prevBar, r.prevPrice, r.bar, r.price,
             xloc = xloc.bar_index, color = col, width = width,
             style = isHTF ? line.style_dashed : line.style_solid)
        if lbl
            prefix = isHTF ? "M" : "m"
            yloc_  = r.dir > 0 ? yloc.abovebar : yloc.belowbar
            label.new(r.bar, r.price, prefix + str.tostring(r.idx),
                 xloc = xloc.bar_index, yloc = yloc_,
                 style = r.dir > 0 ? label.style_label_down : label.style_label_up,
                 color = isHTF ? cHTF : (r.dir > 0 ? cUp : cDn),
                 textcolor = color.white, size = isHTF ? size.normal : size.small)

// ──────────── РАСПОЗНАВАНИЕ ФИГУР (Уровень 3, Структурные Серии A-E) ──────────
// Рисует рамку фигуры + метку с названием.
drawFig(string nm, int b0, int b1, float lo, float hi, color c) =>
    box.new(b0, hi, b1, lo, xloc = xloc.bar_index,
         border_color = c, border_width = 1, bgcolor = color.new(c, 92))
    label.new(int((b0 + b1) / 2), hi, nm, xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_down, color = color.new(c, 10),
         textcolor = color.white, size = size.small)

// Подписывает каждый сегмент фигуры позиционной меткой Нили из Структурной Серии
// (AKU Индикаторов положения 3-60..3-63 + Серии Гл.4). lset = метки через '|'.
labelSeg(array<int> eb, array<float> ep, int firstIdx, string lset, color c) =>
    array<string> parts = str.split(lset, "|")
    for i = 0 to array.size(parts) - 1
        label.new(array.get(eb, firstIdx + i), array.get(ep, firstIdx + i), array.get(parts, i),
             xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_up,
             color = color.new(c, 45), textcolor = color.white, size = size.tiny)

// Метки Движения (Motion Labels) — нумерация волн на подтверждённой фигуре.
// Импульс: 1 2 3 4 5 на пивотах. Коррекция: A B C. Треугольник: a b c d e.
// Это классическая нотация Эллиота для отображения на графике трейдера.
drawMotionLabels(array<int> eb, array<float> ep, int firstIdx,
                 int count, string lblSet, color c) =>
    array<string> lbs = str.split(lblSet, "|")
    for i = 0 to math.min(count - 1, array.size(lbs) - 1)
        int bi  = array.get(eb, firstIdx + i)
        float px = array.get(ep, firstIdx + i)
        string txt = array.get(lbs, i)
        bool isImpOdd = txt == "1" or txt == "3" or txt == "5"
        label.new(bi, px, txt, xloc = xloc.bar_index, yloc = yloc.price,
             style = isImpOdd ? label.style_label_down : label.style_label_up,
             color = color.new(c, 0), textcolor = color.white, size = size.normal)

// ─── Уровень 4: inline-подтверждение + каналы Нили ───────────────────────────
// Цена точки на линии через (b0,p0)→(b2,p2) при bar_index = bx
priceOnLine(int b0, float p0, int b2, float p2, int bx) =>
    int db = b2 - b0
    db != 0 ? p0 + (p2 - p0) * float(bx - b0) / float(db) : p0

// Рисует канал Нили для подтверждённого Импульса (AKU-0011 канал 0-2, AKU-0054 канал 2-4)
drawImpulseChannels(array<int> eb, array<float> ep, int i0, color c) =>
    int b0 = array.get(eb, i0),   float p0 = array.get(ep, i0)
    int b1 = array.get(eb, i0+1), float p1 = array.get(ep, i0+1)
    int b2 = array.get(eb, i0+2), float p2 = array.get(ep, i0+2)
    int b3 = array.get(eb, i0+3), float p3 = array.get(ep, i0+3)
    int b4 = array.get(eb, i0+4), float p4 = array.get(ep, i0+4)
    // Базовый канал 0-2 (AKU-0011): линия через пивоты 0 и 2 → продолжить до b4
    line.new(b0, p0, b4, priceOnLine(b0, p0, b2, p2, b4),
         xloc = xloc.bar_index, color = color.new(c, 30),
         width = 1, style = line.style_dashed)
    // Параллельная верхняя граница через пивот 1 (вершина W1)
    float offset02 = p1 - priceOnLine(b0, p0, b2, p2, b1)
    line.new(b0, p0 + offset02, b4, priceOnLine(b0, p0, b2, p2, b4) + offset02,
         xloc = xloc.bar_index, color = color.new(c, 50),
         width = 1, style = line.style_dotted)
    // Канал 2-4 (AKU-0054): линия через пивоты 2 и 4 → назад до b0
    line.new(b0, priceOnLine(b2, p2, b4, p4, b0), b4, p4,
         xloc = xloc.bar_index, color = color.new(c, 30),
         width = 1, style = line.style_dashed)
    // Fibonacci проекции Волны-5 (AKU-0201):
    // Цель W5 = end(W3) + 1.618 * (end(W3) - start(W1))
    // Старт от p2 (end W3), не от p4 (end W4)
    bool isUp = p1 > p0
    float m = math.abs(p2 - p0)          // расстояние start(W1) → end(W3)
    float w5target = isUp ? p2 + 1.618 * m : p2 - 1.618 * m
    int   w5bar    = b2 + (b4 - b0)      // проецируем от end(W3) на ту же длину что W1..W4
    line.new(b4, p4, w5bar, w5target, xloc = xloc.bar_index,
         color = color.new(color.yellow, 30), width = 1, style = line.style_dotted)
    label.new(w5bar, w5target, "W5 161.8%", xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_left, color = color.new(color.yellow, 20),
         textcolor = color.white, size = size.tiny)
    // Параллельная граница через пивот 3 (вершина W3)
    float offset24 = p3 - priceOnLine(b2, p2, b4, p4, b3)
    line.new(b0, priceOnLine(b2, p2, b4, p4, b0) + offset24, b4, p4 + offset24,
         xloc = xloc.bar_index, color = color.new(c, 50),
         width = 1, style = line.style_dotted)

// Проверяет правила Импульса (AKU-0001,0004,0005,0002,0007,0009,0127,0126)
// Возвращает: [confirmed, failMsg]
confirmImpulse(array<float> ep, int i0, string dir) =>
    float p0px = array.get(ep, i0),     p1px = array.get(ep, i0 + 1)
    float p2px = array.get(ep, i0 + 2), p3px = array.get(ep, i0 + 3)
    float p4px = array.get(ep, i0 + 4)
    float lw1 = math.abs(p1px - p0px), float lw2 = math.abs(p2px - p1px)
    float lw3 = math.abs(p3px - p2px), float lw4 = math.abs(p4px - p3px)
    // AKU-0001/0004: W2 не пробивает старт W1
    bool r1 = dir == "up" ? p2px > p0px : p2px < p0px
    // AKU-0005: W4 не пробивает старт W3
    bool r2 = dir == "up" ? p4px > p2px : p4px < p2px
    // AKU-0002/0007: W3 >= W1 по цене
    bool r3 = lw3 >= lw1
    // AKU-0127: W2 <= 61.8% W1
    bool r4 = lw1 > 0 ? lw2 / lw1 <= 0.618 : true
    // AKU-0009: ценовые диапазоны W2 и W4 не перекрываются
    float w2lo = math.min(p1px, p2px), float w2hi = math.max(p1px, p2px)
    float w4lo = math.min(p3px, p4px), float w4hi = math.max(p3px, p4px)
    bool r5 = w2hi < w4lo or w4hi < w2lo  // нет пересечения
    // AKU-0126: чередование W2/W4 по цене (>20% разница)
    bool r6 = lw2 > 0 ? (lw4 / lw2 < 0.8 or lw4 / lw2 > 1.2) : true
    // AKU-0203: признаки неправильной начальной точки — длины 1/3/5 почти равны
    float minW = math.min(lw1, math.min(lw3, lw4))
    float maxW = math.max(lw1, math.max(lw3, lw4))
    bool r7 = maxW > 0 ? minW / maxW < 0.85 : true
    bool ok = r1 and r2 and r3 and r4
    string msg = not r1 ? "W2>W1start" : not r2 ? "W4>W3start" :
         not r3 ? "W3<W1" : not r4 ? "W2>61.8%W1" :
         not r5 ? "⚠W2/W4 overlap" : not r6 ? "⚠нет чередования" :
         not r7 ? "⚠W1≈W3≈W5 (неверный старт?)" : ""
    [ok, msg]

// Проверяет Плоскую: B >= 61.8% A (AKU-0017)
confirmFlat(array<float> ep, int i0) =>
    float wA = math.abs(array.get(ep, i0 + 1) - array.get(ep, i0))
    float wB = math.abs(array.get(ep, i0 + 2) - array.get(ep, i0 + 1))
    bool ok = wA > 0 ? wB / wA >= 0.618 : true
    [ok, ok ? "" : "B<61.8%A"]

// Проверяет Треугольник: W3<W1 и W4<W2 (AKU-0018)
confirmTriangle(array<float> ep, int i0) =>
    float lw1 = math.abs(array.get(ep, i0+1)-array.get(ep, i0))
    float lw2 = math.abs(array.get(ep, i0+2)-array.get(ep, i0+1))
    float lw3 = math.abs(array.get(ep, i0+3)-array.get(ep, i0+2))
    float lw4 = math.abs(array.get(ep, i0+4)-array.get(ep, i0+3))
    bool ok = lw3 < lw1 and lw4 < lw2
    [ok, ok ? "" : "не сужается"]

// Возвращает направление по p0→p1
figDirection(float p0px, float p1px) =>
    p1px > p0px ? "up" : "down"

// ─── Hybrid matcher: как Python, напрямую по окнам подтверждённых пивотов ───
// В отличие от base-sequence matcher, этот слой не зависит от :5/:3 для W2/W4,
// поэтому Flat/DC сигналы не пропадают из-за Правил 6-7.
hybridAlternate(array<int> dirs, int i0, int waves) =>
    bool ok = true
    for k = i0 + 2 to i0 + waves
        if array.get(dirs, k) == array.get(dirs, k - 1)
            ok := false
    ok

hybridBounds(array<int> bars, array<float> pxs, int i0, int count) =>
    int b0 = array.get(bars, i0)
    int b1 = array.get(bars, i0 + count - 1)
    float hi = array.get(pxs, i0)
    float lo = array.get(pxs, i0)
    for k = i0 to i0 + count - 1
        float px = array.get(pxs, k)
        hi := math.max(hi, px)
        lo := math.min(lo, px)
    [b0, b1, lo, hi]

hybridFlatOK(array<float> pxs, int i0) =>
    float a = math.abs(array.get(pxs, i0 + 1) - array.get(pxs, i0))
    float b = math.abs(array.get(pxs, i0 + 2) - array.get(pxs, i0 + 1))
    a > 0 and b / a >= 0.618

hybridDoubleCorrOK(array<float> pxs, int i0) =>
    float w = math.abs(array.get(pxs, i0 + 1) - array.get(pxs, i0))
    float x = math.abs(array.get(pxs, i0 + 2) - array.get(pxs, i0 + 1))
    float xr = w > 0 ? x / w : na
    not na(xr) and xr > 0.1 and xr < 0.618

hybridImpulseOK(array<float> pxs, int i0) =>
    string dir = figDirection(array.get(pxs, i0), array.get(pxs, i0 + 1))
    [ok, msg] = confirmImpulse(pxs, i0, dir)
    ok

hybridTriangleOK(array<float> pxs, int i0) =>
    [ok, msg] = confirmTriangle(pxs, i0)
    ok

drawTradeSignal(string figType, string figDir, int confBar, float entryPx,
                int b0, int b1, float lo, float hi, float amp) =>
    bool figUp = figDir == "up"
    bool isLong = not figUp
    float tp = isLong ? entryPx + amp : entryPx - amp
    float sl = isLong ? entryPx - amp : entryPx + amp
    float prob = figType == "flat" ? flatProb : dcProb
    string side = isLong ? "LONG" : "SHORT"
    color sigCol = isLong ? color.lime : color.red
    string title = figType == "flat" ? "FLAT fade" : "DOUBLE CORR fade"
    drawFig(title, b0, b1, lo, hi, color.new(sigCol, 55))
    label.new(confBar, entryPx, side + "\n" + title + "\nP≈" + str.tostring(prob, "#.0") + "%",
         xloc = xloc.bar_index, yloc = yloc.price,
         style = isLong ? label.style_label_up : label.style_label_down,
         color = color.new(sigCol, 0), textcolor = color.white, size = size.normal,
         tooltip = "Research Sprint 6: сигнал появляется на баре подтверждения pivot, не на экстремуме. TP/SL = amplitude фигуры.")
    line.new(confBar, tp, confBar + 50, tp, xloc = xloc.bar_index,
         color = color.new(color.lime, 25), width = 1, style = line.style_dotted)
    line.new(confBar, sl, confBar + 50, sl, xloc = xloc.bar_index,
         color = color.new(color.red, 25), width = 1, style = line.style_dotted)
    label.new(confBar + 50, tp, "TP", xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_left, color = color.new(color.lime, 25),
         textcolor = color.white, size = size.tiny)
    label.new(confBar + 50, sl, "SL/invalid", xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_left, color = color.new(color.red, 25),
         textcolor = color.white, size = size.tiny)

drawNoTrade(string figType, int confBar, float entryPx) =>
    label.new(confBar, entryPx, "NO TRADE\n" + figType,
         xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_left, color = color.new(color.gray, 25),
         textcolor = color.white, size = size.tiny,
         tooltip = "Sprint 6: этот тип фигуры не показал торговый edge. Использовать только как контекст.")

tradeStatusColor(string status, string side) =>
    status == "ACTIVE" ? (side == "LONG" ? color.new(color.lime, 35) : side == "SHORT" ? color.new(color.red, 35) : color.new(color.gray, 55)) :
     status == "TP HIT" ? color.new(color.lime, 20) :
     status == "SL HIT" ? color.new(color.red, 20) :
     status == "EXPIRED" ? color.new(color.orange, 30) :
     color.new(color.gray, 60)

actionColor(string action) =>
    action == "BUY" ? color.new(color.lime, 20) :
     action == "SELL" ? color.new(color.red, 20) :
     color.new(color.gray, 45)

tfCalibKey() =>
    timeframe.isdaily and timeframe.multiplier == 1 ? "1d" :
     timeframe.isintraday and timeframe.multiplier == 60 ? "1h" :
     "fallback"

calibratedTradeStats(string figType, string side) =>
    string tfKey = tfCalibKey()
    float prob = figType == "flat" ? flatProb : dcProb
    int sampleN = 0
    string conf = "fallback"
    string src = "input"
    if figType == "flat" and side == "LONG"
        if tfKey == "1d"
            prob := 66.7, sampleN := 24, conf := "low", src := "flat|1d|long"
        else if tfKey == "1h"
            prob := 55.4, sampleN := 251, conf := "high", src := "flat|1h|long"
        else
            prob := 56.4, sampleN := 275, conf := "high", src := "flat|long"
    else if figType == "flat" and side == "SHORT"
        if tfKey == "1d"
            prob := 69.6, sampleN := 23, conf := "low", src := "flat|1d|short"
        else if tfKey == "1h"
            prob := 54.5, sampleN := 233, conf := "high", src := "flat|1h|short"
        else
            prob := 55.9, sampleN := 256, conf := "high", src := "flat|short"
    else if figType == "double_corr" and side == "LONG"
        if tfKey == "1d"
            prob := 100.0, sampleN := 3, conf := "low", src := "double_corr|1d|long"
        else if tfKey == "1h"
            prob := 78.6, sampleN := 14, conf := "low", src := "double_corr|1h|long"
        else
            prob := 82.4, sampleN := 17, conf := "low", src := "double_corr|long"
    else if figType == "double_corr" and side == "SHORT"
        if tfKey == "1d"
            prob := 100.0, sampleN := 1, conf := "low", src := "double_corr|1d|short"
        else if tfKey == "1h"
            prob := 86.7, sampleN := 15, conf := "low", src := "double_corr|1h|short"
        else
            prob := 87.5, sampleN := 16, conf := "low", src := "double_corr|short"
    [prob, sampleN, conf, src]

signalGrade(string action, float prob, int sampleN, string conf, float rr) =>
    if action != "BUY" and action != "SELL"
        "NO TRADE"
    else if sampleN < 20 or conf == "low"
        "B-SMALL-N"
    else if prob >= 65 and not na(rr) and rr >= 1.5
        "A"
    else if prob >= 55 and not na(rr) and rr >= 1.0
        "B"
    else
        "C"

// ─── Рейтинг Энергии (AKU-0213, Гл.10 стр.10-2) ─────────────────────────────
// Возвращает рейтинг энергии и макс. откат следующей волны для подтверждённой фигуры.
// figType: "impulse"|"terminal"|"flat"|"zigzag"|"triangle"|"double_corr"
// dir: 1=восходящая -1=нисходящая
energyRating(string figType, int dir) =>
    int e = 0
    float retracePct = 1.0  // макс. % следующей волны от текущей
    if figType == "impulse"
        e := dir > 0 ? 0 : 0   // Трендовый Импульс: нейтральный (0)
        retracePct := 1.0       // следующая < 100% (не достигает старта)
    else if figType == "terminal"
        e := dir > 0 ? -2 : 2  // Терминал: сильный контртренд
        retracePct := 1.0       // следующая ДОЛЖНА достичь старта (быстро)
    else if figType == "zigzag"
        e := dir > 0 ? 0 : 0
        retracePct := 1.0
    else if figType == "flat"
        e := dir > 0 ? -1 : 1
        retracePct := 0.9
    else if figType == "triangle"
        e := 0                  // Треугольник нейтрален для последующих волн
        retracePct := 1.0
    else if figType == "double_corr"
        e := dir > 0 ? 2 : -2  // Двойная Коррекция: сильная (+2/-2)
        retracePct := 0.8
    [e, retracePct]

// Рисует метку Рейтинга Энергии и линию максимального отката после фигуры.
drawEnergy(int b1, float p1, string figType, int dir, float figLen) =>
    [e, retPct] = energyRating(figType, dir)
    string eStr = e > 0 ? "+" + str.tostring(e) : str.tostring(e)
    string eTip  = "Рейтинг Энергии: " + eStr + " | Макс.откат: " + str.tostring(math.round(retPct*100)) + "% (AKU-0213)"
    color eCol = e > 1 ? color.lime : e < -1 ? color.red : e != 0 ? color.orange : color.gray
    label.new(b1, p1, "E" + eStr, xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_right, color = color.new(eCol, 20),
         textcolor = color.white, size = size.small, tooltip = eTip)
    // Линия максимального отката следующей волны
    if retPct < 1.0 and figLen > 0
        float retLevel = dir > 0 ? p1 - figLen * retPct : p1 + figLen * retPct
        line.new(b1, retLevel, b1 + 30, retLevel, xloc = xloc.bar_index,
             color = color.new(eCol, 40), width = 1, style = line.style_dotted)

// ─── Правило соотношения длительностей (AKU-0205, Гл.9 стр.9-4) ─────────────
// 3 смежных волны одного Порядка не могут иметь одинаковую временную длину.
// Возвращает true если нарушение (все три равны ±10%).
checkTimeEquality(int t1, int t2, int t3) =>
    float tmax = math.max(t1, math.max(t2, t3))
    float tmin = math.min(t1, math.min(t2, t3))
    tmax > 0 ? tmin / tmax > 0.9 : false  // все три в пределах 10% → нарушение

// ─── Правило точек касания (AKU-0204, Гл.9 стр.9-1) ─────────────────────────
// Считает, сколько из 6 пивотов Импульса (p0..p5) лежат на двух линиях канала.
// Если > 4 → скорее Коррекция, чем Импульс.
countTouchpoints(array<float> ep, int i0, int b0lo, float p0lo,
                 int b1lo, float p1lo, int b0hi, float p0hi, int b1hi, float p1hi) =>
    int touches = 0
    for i = 0 to 5
        if i0 + i < array.size(ep)
            float px = array.get(ep, i0 + i)
            float loLine = priceOnLine(b0lo, p0lo, b1lo, p1lo, b0lo + i * 5)
            float hiLine = priceOnLine(b0hi, p0hi, b1hi, p1hi, b0hi + i * 5)
            if math.abs(px - loLine) < loLine * 0.005 or math.abs(px - hiLine) < hiLine * 0.005
                touches += 1
    touches

// ─── Сжатие (Compaction) — Цикл 2 Нили (AKU-0180) ────────────────────────────
// После подтверждения фигуры удаляем N элементов из хвоста массивов и заменяем
// их ОДНИМ сжатым элементом с базовой структурой (:5 для импульса, :3 для коррекции).
// Пивот сжатой волны = начальный бар фигуры + конечная цена.
// AKU-0180: подтверждённая группа сжимается до базовой :3/:5; соседние волны переоцениваются.
compactFigure(array<int> s, array<int> eb, array<float> ep,
              int n, int count, int baseStruct) =>
    // Удаляем count+1 пивотов из хвоста (count волн = count+1 пивот, но первый = граница)
    // Оставляем стартовый пивот фигуры, убираем промежуточные, финальный остаётся
    for i = 0 to count - 1
        if array.size(s) > 1
            array.remove(s,  array.size(s) - 2)   // убираем предпоследний (сохраняем финальный)
            array.remove(eb, array.size(eb) - 2)
            array.remove(ep, array.size(ep) - 2)
    // Меняем последнюю структуру на сжатую
    if array.size(s) > 0
        array.set(s, array.size(s) - 1, baseStruct)

// Сопоставляет хвост последовательности базовых структур (5/3) со Структурными Сериями.
// Приоритет 5-элементных шаблонов (Импульс/Треугольник) — правило 'Зигзаг или Импульс?'.
matchFigure(array<int> s, array<int> eb, array<float> ep, color c) =>
    int n = array.size(s)
    bool drew = false
    if n >= 5
        int v1 = array.get(s, n - 5), v2 = array.get(s, n - 4), v3 = array.get(s, n - 3)
        int v4 = array.get(s, n - 2), v5 = array.get(s, n - 1)
        int startIdx = n >= 6 ? n - 6 : n - 5
        int b0 = array.get(eb, startIdx)
        int b1 = array.get(eb, n - 1)
        float hi = array.get(ep, startIdx), lo = array.get(ep, startIdx)
        for i = startIdx to n - 1
            float p = array.get(ep, i)
            hi := math.max(hi, p)
            lo := math.min(lo, p)
        if v1 == 5 and v2 == 3 and v3 == 5 and v4 == 3 and v5 == 5
            // Уровень 4: подтвердить Импульс + каналы + Сжатие (AKU-0180)
            int pi0 = startIdx
            string dir = figDirection(array.get(ep, pi0), array.get(ep, pi0 + 1))
            [impOK, impMsg] = confirmImpulse(ep, pi0, dir)
            string nm = impOK ? "Импульс ✅" : "Импульс? ❌ " + impMsg
            color fc = impOK ? color.new(color.green, 20) : color.new(color.red, 20)
            drawFig(nm, b0, b1, lo, hi, fc)
            labelSeg(eb, ep, n - 5, ":5|:F3|:5|:F3|:L5", fc)
            if impOK
                // AKU-0205: проверка соотношения длительностей волн (3 не могут быть равны)
                int tb0 = array.get(eb, pi0),  int tb1 = array.get(eb, pi0+1)
                int tb2 = array.get(eb, pi0+2), int tb3 = array.get(eb, pi0+3)
                int tb4 = array.get(eb, pi0+4)
                bool timeEqWarn = checkTimeEquality(tb1-tb0, tb2-tb1, tb3-tb2)
                if timeEqWarn
                    label.new(b1, hi, "⚠ t1≈t2≈t3", xloc = xloc.bar_index,
                         yloc = yloc.price, style = label.style_label_down,
                         color = color.new(color.orange, 20), textcolor = color.white, size = size.tiny)
                drawImpulseChannels(eb, ep, pi0, color.green)
                drawMotionLabels(eb, ep, pi0, 6, "0|1|2|3|4|5", color.green)
                float impLen = math.abs(array.get(ep, n-1) - array.get(ep, pi0))
                drawEnergy(b1, hi, "impulse", dir == "up" ? 1 : -1, impLen)
                // AKU-0224: Реальная линия 2-4 — временное окно прорыва = длительность W5
                // Рисуем вертикальную зону: конец W5 + длительность W5 = ожидаемый прорыв
                int w5dur = tb4 - tb3  // длительность W5 в барах
                if w5dur > 0
                    line.new(tb4 + w5dur, lo, tb4 + w5dur, hi, xloc = xloc.bar_index,
                         color = color.new(color.yellow, 50), width = 1, style = line.style_dotted)
                    label.new(tb4 + w5dur, lo, "↓2-4\n≤W5", xloc = xloc.bar_index,
                         yloc = yloc.price, style = label.style_label_up,
                         color = color.new(color.yellow, 30), textcolor = color.white, size = size.tiny,
                         tooltip = "AKU-0224: прорыв линии 2-4 должен произойти в этот срок (≤ длительности W5). Иначе → W5 сегментирована или Терминал.")
                compactFigure(s, eb, ep, n, 4, 5)  // 5 волн → :5
            drew := true
        else if v1 == 3 and v2 == 3 and v3 == 3 and v4 == 3 and v5 == 3
            // Уровень 4: Треугольник (→:3) ИЛИ Терминал (→:5)
            // AKU Гл.7 стр.7-1: Треугольник сжимается в :3, Терминальный Импульс — в :5
            int pi0 = startIdx
            [triOK, triMsg] = confirmTriangle(ep, pi0)
            // Терминал: те же 3-3-3-3-3 НО волны перекрываются и сужаются как клин
            // Точное различение требует правил Гл.5 стр.5-2 (AKU-0177)
            // В Pine v1: если подтверждён по сужению → помечаем как Треуг. (безопасная версия)
            string nm = triOK ? "Треуг./Терминал ✅" : "Треуг.? ❌ " + triMsg
            color fc = triOK ? color.new(color.purple, 20) : color.new(color.red, 20)
            drawFig(nm, b0, b1, lo, hi, fc)
            labelSeg(eb, ep, n - 5, ":F3|:c3|:c3|:sL3|:L3", fc)
            if triOK
                drawMotionLabels(eb, ep, pi0, 6, "0|a|b|c|d|e", color.purple)
                // Сжатие: :3 для Треугольника, :5 для Терминала — пока :3 (безопасно)
                compactFigure(s, eb, ep, n, 4, 3)
            drew := true
    if not drew and n >= 5
        // Нестандартные серии с x-волнами: Двойной Зигзаг / Двойная Коррекция (AKU-0187..0191)
        // Паттерн: :3 ++ :3(x) ++ :3 — три тройки подряд, средняя = x-волна
        // Проверяем относительный размер x-волны: если средний элемент < 61.8% первого → x-волна
        int dx1 = array.get(s, n - 5), dx2 = array.get(s, n - 4), dx3 = array.get(s, n - 3)
        int dx4 = array.get(s, n - 2), dx5 = array.get(s, n - 1)
        if dx1 == 3 and dx2 == 3 and dx3 == 3 and dx4 == 3 and dx5 == 3
            // 5 троек = потенциальная Двойная Коррекция с большой x + Тройная?
            // Пропускаем — уже детектируется как Треугольник выше
            drew := false
        if not drew and n >= 3
            int cx1 = array.get(s, n - 3), cx2 = array.get(s, n - 2), cx3 = array.get(s, n - 1)
            if cx1 == 3 and cx2 == 3 and cx3 == 3
                // Три тройки — кандидат на Двойную Коррекцию (:3 ++ x:3 ++ :3)
                int dstartIdx = n >= 4 ? n - 4 : n - 3
                int db0 = array.get(eb, dstartIdx)
                int db1 = array.get(eb, n - 1)
                float dhi = array.get(ep, dstartIdx), dlo = array.get(ep, dstartIdx)
                for i = dstartIdx to n - 1
                    float p = array.get(ep, i)
                    dhi := math.max(dhi, p)
                    dlo := math.min(dlo, p)
                // Проверяем размер x-волны (средний элемент)
                float p0x = array.get(ep, n - 4), float p1x = array.get(ep, n - 3)
                float p2x = array.get(ep, n - 2), float p3x = array.get(ep, n - 1)
                float len1 = math.abs(p1x - p0x), float lenX = math.abs(p2x - p1x)
                float xRatio = len1 > 0 ? lenX / len1 : na
                bool isSmallX = not na(xRatio) and xRatio < 0.618   // Условие 1 (AKU-0185)
                bool isBigX   = not na(xRatio) and xRatio >= 1.618  // Условие 2 (AKU-0186)
                if isSmallX
                    drawFig("Двойн.Корр. ✅", db0, db1, dlo, dhi, color.new(color.orange, 20))
                    compactFigure(s, eb, ep, n, 2, 3)  // → :3 (AKU-0191)
                    drew := true
                else if isBigX
                    drawFig("Двойн.Корр.? (большая x)", db0, db1, dlo, dhi, color.new(color.orange, 40))
                    drew := true

    if not drew and n >= 3
        int w1 = array.get(s, n - 3), int w2 = array.get(s, n - 2), int w3 = array.get(s, n - 1)
        int startIdx = n >= 4 ? n - 4 : n - 3
        int b0 = array.get(eb, startIdx)
        int b1 = array.get(eb, n - 1)
        float hi = array.get(ep, startIdx), lo = array.get(ep, startIdx)
        for i = startIdx to n - 1
            float p = array.get(ep, i)
            hi := math.max(hi, p)
            lo := math.min(lo, p)
        if w1 == 3 and w2 == 3 and w3 == 5
            // Уровень 4: подтвердить Плоскую (AKU-0017)
            int pi0 = startIdx
            [flatOK, flatMsg] = confirmFlat(ep, pi0)
            string nm = flatOK ? "Плоская ✅" : "Плоская? ❌ " + flatMsg
            color fc = flatOK ? color.new(color.teal, 20) : color.new(color.red, 20)
            drawFig(nm, b0, b1, lo, hi, fc)
            labelSeg(eb, ep, n - 3, ":F3|:c3|:?5", fc)
            if flatOK
                drawMotionLabels(eb, ep, n - 4, 4, "0|A|B|C", color.teal)
                float flatDir = array.get(ep, n-3) > array.get(ep, n-4) ? 1.0 : -1.0
                float flatLen = math.abs(array.get(ep, n-1) - array.get(ep, n-4))
                drawEnergy(b1, hi, "flat", int(flatDir), flatLen)
                compactFigure(s, eb, ep, n, 2, 3)  // 3 волны → :3
        // Зигзаг (5-3-5) подавлен: неотличим от хвоста Импульса без Индикаторов положения.
        // Активировать после реализации полной логики F/c/L (Гл.3 стр.3-60+).

// ──────────────────── ПОРОГ РАЗВОРОТА (текущий ТФ) ───────────────
revC = useATR ? ta.atr(atrLen) * atrMult : close * pctRev / 100.0

// ──────────────────── ТЕКУЩИЙ ТАЙМФРЕЙМ ──────────────────────────
var ZZState zC = ZZState.new()
ZZResult rc = zC.step(high, low, revC)
if showC
    drawMono(rc, colCUp, colCDn, wC, false, colH, showLbl)
// Маркер смены Порядка: смежные моноволны НЕ подобны (AKU-0003) → нужно сжатие
if showC and showSim and rc.simChecked and not rc.similar
    label.new(rc.prevBar, rc.prevPrice, "≠",
         xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_center, color = color.new(color.yellow, 0),
         textcolor = color.black, size = size.tiny,
         tooltip = "Смежные моноволны разного Порядка (правило подобия AKU-0003): " +
         "кандидат на сжатие/перегруппировку")
// Классификация моноволны по Определителю Правил (Уровень 2, AKU-0141/0142)
if showC and showClass and rc.ruleNo > 0
    string lbl = "П" + str.tostring(rc.ruleNo) + rc.condLetter + " " + ruleToStructure(rc.ruleNo)
    label.new(rc.prevBar, rc.prevPrice, lbl,
         xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_left, color = color.new(colClass, 20),
         textcolor = color.white, size = size.tiny,
         tooltip = "Определитель Правил: m2/m1 -> Правило " + str.tostring(rc.ruleNo) +
         ", m0/m1 -> Условие '" + rc.condLetter + "'. Вероятная структура m1: " +
         ruleToStructure(rc.ruleNo) + " (Нили, Гл.3)")

// ── Накопление базовых структур и распознавание фигур (Уровень 3) ──
// Окно ограничено 10 элементами — достаточно для 5-эл. шаблона + контекст.
// Без ограничения массивы растут до тысяч баров → ложные рамки на всей истории.
var array<int>   figStruct  = array.new<int>()
var array<int>   figEndBar  = array.new<int>()
var array<float> figEndPx   = array.new<float>()
if showFig and rc.ruleNo > 0
    string st = ruleToStructure(rc.ruleNo)
    int base = st == ":5" ? 5 : st == ":F3" ? 3 : 0
    array.push(figStruct, base)
    array.push(figEndBar, rc.prevBar)
    array.push(figEndPx, rc.prevPrice)
    while array.size(figStruct) > 10
        array.shift(figStruct)
        array.shift(figEndBar)
        array.shift(figEndPx)
    if base > 0
        matchFigure(figStruct, figEndBar, figEndPx, colFig)

// ── Hybrid trade matcher: подтверждённые пивоты текущего ТФ ──
var array<int>   hybBar  = array.new<int>()
var array<float> hybPx   = array.new<float>()
var array<int>   hybDir  = array.new<int>()
var array<int>   hybConf = array.new<int>()
var bool hybInit = false
var int lastTradeConfBar = na
var string lastTradeSide = "—"
var string lastTradeType = "—"
var float lastTradeProb = na
var float lastTradeEntry = na
var float lastTradeTp = na
var float lastTradeSl = na
var string lastTradeStatus = "—"
var int lastTradeAge = na
var int lastTradeSampleN = 0
var string lastTradeConfidence = "—"
var string lastTradeProbSource = "—"
var bool tradeLongSignal = false
var bool tradeShortSignal = false
tradeLongSignal := false
tradeShortSignal := false

if showTrade and rc.confirmed and not na(rc.prevBar)
    if not hybInit
        array.push(hybBar, rc.prevBar)
        array.push(hybPx, rc.prevPrice)
        array.push(hybDir, 0)
        array.push(hybConf, rc.prevBar)
        hybInit := true
    array.push(hybBar, rc.bar)
    array.push(hybPx, rc.price)
    array.push(hybDir, rc.dir)
    array.push(hybConf, bar_index)
    while array.size(hybBar) > maxHybridPivots
        array.shift(hybBar)
        array.shift(hybPx)
        array.shift(hybDir)
        array.shift(hybConf)

    int hn = array.size(hybBar)
    bool matchedTrade = false
    if hn >= 4
        int s4 = hn - 4
        bool alt4 = hybridAlternate(hybDir, s4, 3)
        if alt4
            string figDir4 = figDirection(array.get(hybPx, s4), array.get(hybPx, s4 + 1))
            int confBar4 = array.get(hybConf, hn - 1)
            float entry4 = close
            float amp4 = math.abs(array.get(hybPx, s4 + 3) - array.get(hybPx, s4))
            [b0h4, b1h4, loh4, hih4] = hybridBounds(hybBar, hybPx, s4, 4)
            if hybridFlatOK(hybPx, s4)
                if showTradeMarkers
                    drawTradeSignal("flat", figDir4, confBar4, entry4, b0h4, b1h4, loh4, hih4, amp4)
                bool isLongFlat = figDir4 == "down"
                tradeLongSignal := isLongFlat
                tradeShortSignal := not isLongFlat
                string sideFlat = isLongFlat ? "LONG" : "SHORT"
                [probFlat, nFlat, confFlat, srcFlat] = calibratedTradeStats("flat", sideFlat)
                lastTradeConfBar := confBar4
                lastTradeSide := sideFlat
                lastTradeType := "Flat fade"
                lastTradeProb := probFlat
                lastTradeEntry := entry4
                lastTradeTp := isLongFlat ? entry4 + amp4 : entry4 - amp4
                lastTradeSl := isLongFlat ? entry4 - amp4 : entry4 + amp4
                lastTradeStatus := "ACTIVE"
                lastTradeAge := 0
                lastTradeSampleN := nFlat
                lastTradeConfidence := confFlat
                lastTradeProbSource := srcFlat
                matchedTrade := true
            else if hybridDoubleCorrOK(hybPx, s4)
                if showTradeMarkers
                    drawTradeSignal("double_corr", figDir4, confBar4, entry4, b0h4, b1h4, loh4, hih4, amp4)
                bool isLongDc = figDir4 == "down"
                tradeLongSignal := isLongDc
                tradeShortSignal := not isLongDc
                string sideDc = isLongDc ? "LONG" : "SHORT"
                [probDc, nDc, confDc, srcDc] = calibratedTradeStats("double_corr", sideDc)
                lastTradeConfBar := confBar4
                lastTradeSide := sideDc
                lastTradeType := "DoubleCorr fade"
                lastTradeProb := probDc
                lastTradeEntry := entry4
                lastTradeTp := isLongDc ? entry4 + amp4 : entry4 - amp4
                lastTradeSl := isLongDc ? entry4 - amp4 : entry4 + amp4
                lastTradeStatus := "ACTIVE"
                lastTradeAge := 0
                lastTradeSampleN := nDc
                lastTradeConfidence := confDc
                lastTradeProbSource := srcDc
                matchedTrade := true
    if showNoise and not matchedTrade and hn >= 6
        int s6 = hn - 6
        bool alt6 = hybridAlternate(hybDir, s6, 5)
        if alt6
            int confBar6 = array.get(hybConf, hn - 1)
            float entry6 = close
            if hybridImpulseOK(hybPx, s6)
                drawNoTrade("Impulse", confBar6, entry6)
            else if hybridTriangleOK(hybPx, s6)
                drawNoTrade("Triangle", confBar6, entry6)

if lastTradeStatus == "ACTIVE" and not na(lastTradeConfBar) and bar_index > lastTradeConfBar and not na(lastTradeTp) and not na(lastTradeSl)
    lastTradeAge := bar_index - lastTradeConfBar
    bool lastIsLong = lastTradeSide == "LONG"
    bool tpHit = lastIsLong ? high >= lastTradeTp : low <= lastTradeTp
    bool slHit = lastIsLong ? low <= lastTradeSl : high >= lastTradeSl
    if slHit
        // Консервативно: если TP и SL достигнуты в одном баре, считаем риск первым.
        lastTradeStatus := "SL HIT"
    else if tpHit
        lastTradeStatus := "TP HIT"
    else if lastTradeAge > tradeMaxAgeBars
        lastTradeStatus := "EXPIRED"

// ──────────────────── СТАРШИЙ ТАЙМФРЕЙМ (MTF) ────────────────────
// Запрашиваем OHLC старшего ТФ; детектор шагает только при закрытии HTF-бара.
// Pine v6: tuple в request.security не поддерживается — отдельный запрос на каждое значение.
float hHigh  = request.security(syminfo.tickerid, htf, high,          lookahead = barmerge.lookahead_off)
float hLow   = request.security(syminfo.tickerid, htf, low,           lookahead = barmerge.lookahead_off)
float hClose = request.security(syminfo.tickerid, htf, close,         lookahead = barmerge.lookahead_off)
int   hTime  = request.security(syminfo.tickerid, htf, time,          lookahead = barmerge.lookahead_off)
float hAtr   = request.security(syminfo.tickerid, htf, ta.atr(atrLen), lookahead = barmerge.lookahead_off)

revH = useATR ? hAtr * atrMult : hClose * pctRev / 100.0

var ZZState zH = ZZState.new()
var int htfBiasDir = 0
int   hTimeChg = ta.change(hTime)
bool newHTF = not na(hTime) and hTimeChg != 0
if newHTF and not na(hHigh)
    ZZResult rh = zH.step(hHigh, hLow, revH)
    if rh.confirmed
        htfBiasDir := rh.dir
    if showH
        drawMono(rh, colCUp, colCDn, wH, true, colH, showLbl)

string htfBias = htfBiasDir > 0 ? "UP" : htfBiasDir < 0 ? "DOWN" : "NEUTRAL"

bool supportedTradeSymbol = not stockOnlyMode or syminfo.type == "stock"
string actionNow = "WAIT"
string actionReason = "NO SIGNAL"
float actionRR = na
float actionProgress = na

if not supportedTradeSymbol
    actionReason := "UNSUPPORTED " + syminfo.type
else if lastTradeSide != "LONG" and lastTradeSide != "SHORT"
    actionReason := "NO SIGNAL"
else if lastTradeStatus != "ACTIVE"
    actionReason := lastTradeStatus
else if na(lastTradeEntry) or na(lastTradeTp) or na(lastTradeSl)
    actionReason := "INCOMPLETE"
else
    int actionAge = na(lastTradeAge) and not na(lastTradeConfBar) ? bar_index - lastTradeConfBar : lastTradeAge
    bool actionLong = lastTradeSide == "LONG"
    float rewardNow = actionLong ? lastTradeTp - close : close - lastTradeTp
    float riskNow = actionLong ? close - lastTradeSl : lastTradeSl - close
    float pathToTp = math.abs(lastTradeTp - lastTradeEntry)
    float movedToTp = actionLong ? close - lastTradeEntry : lastTradeEntry - close
    actionProgress := pathToTp > 0 ? movedToTp / pathToTp : na
    actionRR := riskNow > 0 ? rewardNow / riskNow : na
    if actionAge > actionFreshBars
        actionReason := "STALE " + str.tostring(actionAge) + "b"
    else if rewardNow <= 0
        actionReason := "TP PASSED"
    else if riskNow <= 0
        actionReason := "SL ZONE"
    else if not na(actionProgress) and actionProgress > maxEntryProgress
        actionReason := "LATE " + str.tostring(actionProgress * 100, "#") + "%"
    else if not na(actionRR) and actionRR < minActionRR
        actionReason := "RR BAD " + str.tostring(actionRR, "#.00")
    else if useHtfFilter and actionLong and htfBiasDir < 0
        actionReason := "HTF AGAINST " + htfBias
    else if useHtfFilter and not actionLong and htfBiasDir > 0
        actionReason := "HTF AGAINST " + htfBias
    else
        actionNow := actionLong ? "BUY" : "SELL"
        actionReason := "FRESH + RR OK"

bool actionBuySignal = actionNow == "BUY" and tradeLongSignal
bool actionSellSignal = actionNow == "SELL" and tradeShortSignal
string signalGradeNow = signalGrade(actionNow, lastTradeProb, lastTradeSampleN, lastTradeConfidence, actionRR)

// ──────────────────────── ИНФО-ПАНЕЛЬ ────────────────────────────
alertcondition(actionBuySignal, "EWB Action BUY", "EWB Action now BUY on {{ticker}} {{interval}}")
alertcondition(actionSellSignal, "EWB Action SELL", "EWB Action now SELL on {{ticker}} {{interval}}")

var table info = table.new(position.top_right, 2, 14, border_width = 1)
if barstate.islast
    table.cell(info, 0, 0, "Action now", text_color = color.white, bgcolor = color.new(color.gray, 20))
    table.cell(info, 1, 0, actionNow, text_color = color.white, bgcolor = actionColor(actionNow))
    table.cell(info, 0, 1, "Reason", text_color = color.white, bgcolor = color.new(color.gray, 45))
    table.cell(info, 1, 1, actionReason, text_color = color.white, bgcolor = actionColor(actionNow))
    table.cell(info, 0, 2, "Слой",        text_color = color.white, bgcolor = color.new(color.gray, 30))
    table.cell(info, 1, 2, "Моноволн",    text_color = color.white, bgcolor = color.new(color.gray, 30))
    table.cell(info, 0, 3, "Trade", text_color = color.white, bgcolor = color.new(color.gray, 35))
    table.cell(info, 1, 3, lastTradeSide, text_color = color.white,
         bgcolor = tradeStatusColor(lastTradeStatus, lastTradeSide))
    table.cell(info, 0, 4, "Фигура", text_color = color.white, bgcolor = color.new(color.gray, 50))
    table.cell(info, 1, 4, lastTradeType, text_color = color.white, bgcolor = color.new(color.gray, 70))
    table.cell(info, 0, 5, "Status", text_color = color.white, bgcolor = color.new(color.gray, 50))
    table.cell(info, 1, 5, lastTradeStatus + (na(lastTradeAge) ? "" : " / " + str.tostring(lastTradeAge) + "b"),
         text_color = color.white, bgcolor = tradeStatusColor(lastTradeStatus, lastTradeSide))
    table.cell(info, 0, 6, "P≈", text_color = color.white, bgcolor = color.new(color.gray, 50))
    table.cell(info, 1, 6, na(lastTradeProb) ? "—" : str.tostring(lastTradeProb, "#.0") + "%", text_color = color.white, bgcolor = color.new(color.gray, 70))
    table.cell(info, 0, 7, "Grade", text_color = color.white, bgcolor = color.new(color.gray, 50))
    table.cell(info, 1, 7, signalGradeNow, text_color = color.white, bgcolor = actionColor(actionNow))
    table.cell(info, 0, 8, "n / conf", text_color = color.white, bgcolor = color.new(color.gray, 50))
    table.cell(info, 1, 8, str.tostring(lastTradeSampleN) + " / " + lastTradeConfidence, text_color = color.white, bgcolor = color.new(color.gray, 70))
    table.cell(info, 0, 9, "Entry / TP", text_color = color.white, bgcolor = color.new(color.gray, 50))
    table.cell(info, 1, 9, na(lastTradeEntry) ? "—" : str.tostring(lastTradeEntry, format.mintick) + " / " + str.tostring(lastTradeTp, format.mintick), text_color = color.white, bgcolor = color.new(color.gray, 70))
    table.cell(info, 0, 10, "SL / invalid", text_color = color.white, bgcolor = color.new(color.gray, 50))
    table.cell(info, 1, 10, na(lastTradeSl) ? "—" : str.tostring(lastTradeSl, format.mintick), text_color = color.white, bgcolor = color.new(color.gray, 70))
    table.cell(info, 0, 11, "RR / progress", text_color = color.white, bgcolor = color.new(color.gray, 50))
    table.cell(info, 1, 11, (na(actionRR) ? "—" : str.tostring(actionRR, "#.00")) + " / " + (na(actionProgress) ? "—" : str.tostring(actionProgress * 100, "#") + "%"),
         text_color = color.white, bgcolor = color.new(color.gray, 70))
    table.cell(info, 0, 12, "HTF bias", text_color = color.white, bgcolor = color.new(color.gray, 50))
    table.cell(info, 1, 12, htfBias, text_color = color.white,
         bgcolor = htfBias == "UP" ? color.new(color.lime, 45) : htfBias == "DOWN" ? color.new(color.red, 45) : color.new(color.gray, 70))
    table.cell(info, 0, 13, "Calib / TF", text_color = color.white, bgcolor = color.new(color.gray, 50))
    table.cell(info, 1, 13, lastTradeProbSource, text_color = color.white, bgcolor = color.new(color.gray, 70))
