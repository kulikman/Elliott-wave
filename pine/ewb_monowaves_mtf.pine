// ───────────────────────────── ТИПЫ ─────────────────────────────
// Состояние ZigZag-детектора моноволн (по reversal-порогу).
// Один экземпляр на каждый таймфрейм — состояние не пересекается.
type ZZState
    int   dir        = 0    // 1 = ищем максимум (вверх), -1 = ищем минимум (вниз)
    float pivotPrice = na   // цена последнего подтверждённого пивота
    int   pivotBar   = na   // bar_index последнего пивота
    float extPrice   = na   // текущий экстремум-кандидат
    int   extBar      = na
    int   count       = 0   // сколько моноволн уже подтверждено
    float lastPriceLen = na // длина предыдущей моноволны по цене
    int   lastTimeLen  = na // длина предыдущей моноволны по времени (в барах)
    bool  hasPrev      = false
    float len0        = na  // длина m0 (для Определителя Правил)
    float len1        = na  // длина m1

// Результат шага детектора
type ZZResult
    bool  confirmed  = false  // подтверждён ли новый пивот на этом шаге
    float price      = na     // цена подтверждённого пивота
    int   bar        = na     // bar_index пивота
    float prevPrice  = na     // предыдущий пивот (начало завершившейся моноволны)
    int   prevBar    = na
    int   dir        = 0      // направление завершившейся моноволны (1/-1)
    int   idx        = 0      // порядковый номер моноволны
    float priceLen   = na     // длина этой моноволны по цене
    int   timeLen    = na     // длина этой моноволны по времени (в барах)
    bool  simChecked = false  // проверено ли правило подобия со смежной
    bool  similar    = false  // могут ли быть одного Порядка (AKU-0003)
    int   ruleNo     = 0      // Определитель Правил: Правило 1-7 для предыдущей m1 (AKU-0141)
    string condLetter = ""    // Условие a-f (AKU-0142)

// ───────────── ОПРЕДЕЛИТЕЛЬ ПРАВИЛ (AKU-0141, Гл.3 стр.3-22) ──────────
// m2/m1 -> Правило 1-7. Допуск ±4% на границе 61.8% (Правило 3) — конвенция
// допусков Фибоначчи (AKU «±4%», стр.3-34).
classifyRule(float m2, float m1) =>
    float ratio = m1 != 0 ? m2 / m1 : na
    int rule = 0
    if not na(ratio)
        if math.abs(ratio - 0.618) <= 0.618 * 0.04
            rule := 3
        else if ratio < 0.382
            rule := 1
        else if ratio < 0.618
            rule := 2
        else if ratio < 1.000
            rule := 4
        else if ratio < 1.618
            rule := 5
        else if ratio <= 2.618
            rule := 6
        else
            rule := 7
    rule

// m0/m1 -> Условие a-f (AKU-0142). Таблицы условий по каждому Правилу
// (ch03-length-ratio-rules.md).
classifyCond(int rule, float m0, float m1) =>
    float r = m1 != 0 ? m0 / m1 : na
    string c = ""
    if not na(r) and rule > 0
        if rule == 1
            c := r < 0.618 ? "a" : r < 1.000 ? "b" : r < 1.618 ? "c" : "d"
        else if rule == 2
            c := r < 0.382 ? "a" : r < 0.618 ? "b" : r < 1.000 ? "c" : r <= 1.618 ? "d" : "e"
        else if rule == 3
            c := r < 0.382 ? "a" : r < 0.618 ? "b" : r < 1.000 ? "c" : r < 1.618 ? "d" : r <= 2.618 ? "e" : "f"
        else if rule == 4
            c := r < 0.382 ? "a" : r < 1.000 ? "b" : r < 1.618 ? "c" : r <= 2.618 ? "d" : "e"
        else
            c := r < 1.000 ? "a" : r < 1.618 ? "b" : r <= 2.618 ? "c" : "d"
    c

// Вероятная структурная метка m1 по Правилу (первый кандидат из Структурного списка,
// AKU Правил 1-7). Малый откат -> :5 (импульс); средний -> :F3 (коррекция);
// большой (Пр.6-7) -> "?" (нужны Индикаторы положения).
ruleToStructure(int rule) =>
    rule == 1 or rule == 2 ? ":5" : (rule == 3 or rule == 4 or rule == 5) ? ":F3" : rule >= 6 ? "?" : ""

// ──────────────────────── ДЕТЕКТОР МОНОВОЛН ──────────────────────
// Reversal-ZigZag: моноволна завершается, когда цена развернулась
// от экстремума более чем на `rev` (порог разворота).
method step(ZZState s, float h, float l, float rev) =>
    ZZResult r = ZZResult.new()

    if na(s.extPrice)
        // Инициализация на первом баре
        s.extPrice   := h
        s.extBar     := bar_index
        s.pivotPrice := l
        s.pivotBar   := bar_index
        s.dir        := 1
    else if s.dir > 0
        // Тренд вверх: следим за максимумом
        if h > s.extPrice
            s.extPrice := h
            s.extBar   := bar_index
        // Разворот вниз → подтверждаем максимум как пивот
        if l < s.extPrice - rev
            r.confirmed := true
            r.price     := s.extPrice
            r.bar       := s.extBar
            r.prevPrice := s.pivotPrice
            r.prevBar   := s.pivotBar
            r.dir       := 1
            r.idx       := s.count
            s.count     += 1
            s.pivotPrice := s.extPrice
            s.pivotBar   := s.extBar
            s.dir        := -1
            s.extPrice   := l
            s.extBar     := bar_index
    else
        // Тренд вниз: следим за минимумом
        if l < s.extPrice
            s.extPrice := l
            s.extBar   := bar_index
        // Разворот вверх → подтверждаем минимум как пивот
        if h > s.extPrice + rev
            r.confirmed := true
            r.price     := s.extPrice
            r.bar       := s.extBar
            r.prevPrice := s.pivotPrice
            r.prevBar   := s.pivotBar
            r.dir       := -1
            r.idx       := s.count
            s.count     += 1
            s.pivotPrice := s.extPrice
            s.pivotBar   := s.extBar
            s.dir        := 1
            s.extPrice   := h
            s.extBar     := bar_index

    // Правило подобия и баланса (AKU-0003): сравнить с предыдущей моноволной
    if r.confirmed and not na(r.prevBar)
        r.priceLen := math.abs(r.price - r.prevPrice)
        r.timeLen  := r.bar - r.prevBar
        if s.hasPrev
            r.simChecked := true
            float pmin = math.min(r.priceLen, s.lastPriceLen)
            float pmax = math.max(r.priceLen, s.lastPriceLen)
            float tmin = math.min(r.timeLen,  s.lastTimeLen)
            float tmax = math.max(r.timeLen,  s.lastTimeLen)
            // similar, если выполнено хотя бы одно условие: цена ИЛИ время
            r.similar := (pmax > 0 and pmin >= pmax / 3.0) or (tmax > 0 and tmin >= tmax / 3.0)
        // Классификация предыдущей моноволны m1 (m0=len0, m1=len1, m2=текущая)
        if not na(s.len0) and not na(s.len1) and s.len1 != 0
            r.ruleNo     := classifyRule(r.priceLen, s.len1)
            r.condLetter := classifyCond(r.ruleNo, s.len0, s.len1)
        s.len0 := s.len1
        s.len1 := r.priceLen
        s.lastPriceLen := r.priceLen
        s.lastTimeLen  := r.timeLen
        s.hasPrev      := true
    r

// Отрисовка одной завершившейся моноволны
drawMono(ZZResult r, color cUp, color cDn, int width, bool isHTF, color cHTF, bool lbl) =>
    if r.confirmed and not na(r.prevBar)
        col = isHTF ? cHTF : (r.dir > 0 ? cUp : cDn)
        line.new(r.prevBar, r.prevPrice, r.bar, r.price,
             xloc = xloc.bar_index, color = col, width = width,
             style = isHTF ? line.style_dashed : line.style_solid)
        if lbl
            prefix = isHTF ? "M" : "m"
            yloc_  = r.dir > 0 ? yloc.abovebar : yloc.belowbar
            label.new(r.bar, r.price, prefix + str.tostring(r.idx),
                 xloc = xloc.bar_index, yloc = yloc_,
                 style = r.dir > 0 ? label.style_label_down : label.style_label_up,
                 color = isHTF ? cHTF : (r.dir > 0 ? cUp : cDn),
                 textcolor = color.white, size = isHTF ? size.normal : size.small)

waveDirText(int dir) =>
    dir > 0 ? "UP" : dir < 0 ? "DOWN" : "NEUTRAL"

waveAtrText(float amp, float atrValue) =>
    not na(amp) and not na(atrValue) and atrValue > 0 ? str.tostring(amp / atrValue, "#.00") + " ATR" : "n/a ATR"

chartTfRank() =>
    timeframe.isintraday ? timeframe.multiplier < 60 ? 1 : timeframe.multiplier < 240 ? 2 : 3 :
     timeframe.isdaily ? 4 :
     timeframe.isweekly ? 5 :
     timeframe.ismonthly ? 6 : 7

contextTfEnabled(int tfRank, int currentRank) =>
    showHtfWaveMap and tfRank > currentRank and tfRank <= currentRank + htfContextLevels

appendContextText(string base, string item) =>
    item == "" ? base : base == "" ? item : base + " | " + item

contextWaveText(bool enabled, string tfName, int count, int dir) =>
    enabled and dir != 0 ? tfName + " m" + str.tostring(count) + " " + waveDirText(dir) : ""

clearHtfWaveMap(array<line> lines, array<label> labels) =>
    while array.size(lines) > 0
        line.delete(array.pop(lines))
    while array.size(labels) > 0
        label.delete(array.pop(labels))

rememberContextPivot(array<int> bars, array<float> prices, ZZResult r, int maxPivots) =>
    if r.confirmed and not na(r.prevBar)
        if array.size(bars) == 0
            array.push(bars, r.prevBar)
            array.push(prices, r.prevPrice)
        array.push(bars, r.bar)
        array.push(prices, r.price)
        while array.size(bars) > maxPivots
            array.shift(bars)
            array.shift(prices)

drawHtfWaveMap(string tfName, bool enabled, array<int> bars, array<float> prices, int activeDir, int activeCount,
               int activeBar, float activePivot, float activePrice, float activeAtr, color ctxCol, int xOffset, float yAtrShift,
               array<line> lines, array<label> labels) =>
    clearHtfWaveMap(lines, labels)
    if enabled
        int n = array.size(bars)
        if n >= 2
            int firstIdx = math.max(0, n - htfContextSegments - 1)
            for i = firstIdx to n - 2
                int x1 = array.get(bars, i)
                int x2 = array.get(bars, i + 1)
                float y1 = array.get(prices, i)
                float y2 = array.get(prices, i + 1)
                line ctxLine = line.new(x1, y1, x2, y2,
                     xloc = xloc.bar_index, color = color.new(ctxCol, 35),
                     width = htfContextWidth, style = line.style_dashed)
                array.push(lines, ctxLine)
        if not na(activeBar) and not na(activePivot) and not na(activePrice)
            float activeAmp = math.abs(activePrice - activePivot)
            float labelY = activePrice + (na(activeAtr) ? 0.0 : activeAtr * yAtrShift)
            line activeCtxLine = line.new(activeBar, activePivot, bar_index, activePrice,
                 xloc = xloc.bar_index, color = color.new(ctxCol, 0),
                 width = htfContextWidth + 1, style = line.style_solid)
            array.push(lines, activeCtxLine)
            if showHtfWaveMapLabels
                label activeCtxLabel = label.new(bar_index + htfMapRightOffset + xOffset, labelY,
                     tfName + " active\nm" + str.tostring(activeCount) + " " + waveDirText(activeDir) + "\n" + waveAtrText(activeAmp, activeAtr),
                     xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
                     color = color.new(ctxCol, 5), textcolor = color.white, size = size.tiny,
                     tooltip = "Активная моноволна старшего ТФ, внутри которой находится последний бар текущего графика.")
                array.push(labels, activeCtxLabel)

// ──────────── РАСПОЗНАВАНИЕ ФИГУР (Уровень 3, Структурные Серии A-E) ──────────
// Рисует рамку фигуры + метку с названием.
drawFig(string nm, int b0, int b1, float lo, float hi, color c) =>
    box.new(b0, hi, b1, lo, xloc = xloc.bar_index,
         border_color = c, border_width = 1, bgcolor = color.new(c, 92))
    label.new(int((b0 + b1) / 2), hi, nm, xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_down, color = color.new(c, 10),
         textcolor = color.white, size = size.small)

// Подписывает каждый сегмент фигуры позиционной меткой Нили из Структурной Серии
// (AKU Индикаторов положения 3-60..3-63 + Серии Гл.4). lset = метки через '|'.
labelSeg(array<int> eb, array<float> ep, int firstIdx, string lset, color c) =>
    array<string> parts = str.split(lset, "|")
    for i = 0 to array.size(parts) - 1
        label.new(array.get(eb, firstIdx + i), array.get(ep, firstIdx + i), array.get(parts, i),
             xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_up,
             color = color.new(c, 45), textcolor = color.white, size = size.tiny)

// Метки Движения (Motion Labels) — нумерация волн на подтверждённой фигуре.
// Импульс: 1 2 3 4 5 на пивотах. Коррекция: A B C. Треугольник: a b c d e.
// Это классическая нотация Эллиота для отображения на графике трейдера.
drawMotionLabels(array<int> eb, array<float> ep, int firstIdx,
                 int count, string lblSet, color c) =>
    array<string> lbs = str.split(lblSet, "|")
    for i = 0 to math.min(count - 1, array.size(lbs) - 1)
        int bi  = array.get(eb, firstIdx + i)
        float px = array.get(ep, firstIdx + i)
        string txt = array.get(lbs, i)
        bool isImpOdd = txt == "1" or txt == "3" or txt == "5"
        label.new(bi, px, txt, xloc = xloc.bar_index, yloc = yloc.price,
             style = isImpOdd ? label.style_label_down : label.style_label_up,
             color = color.new(c, 0), textcolor = color.white, size = size.normal)

// ─── Уровень 4: inline-подтверждение + каналы Нили ───────────────────────────
// Цена точки на линии через (b0,p0)→(b2,p2) при bar_index = bx
priceOnLine(int b0, float p0, int b2, float p2, int bx) =>
    int db = b2 - b0
    db != 0 ? p0 + (p2 - p0) * float(bx - b0) / float(db) : p0

// Рисует канал Нили для подтверждённого Импульса (AKU-0011 канал 0-2, AKU-0054 канал 2-4)
drawImpulseChannels(array<int> eb, array<float> ep, int i0, color c) =>
    int b0 = array.get(eb, i0),   float p0 = array.get(ep, i0)
    int b1 = array.get(eb, i0+1), float p1 = array.get(ep, i0+1)
    int b2 = array.get(eb, i0+2), float p2 = array.get(ep, i0+2)
    int b3 = array.get(eb, i0+3), float p3 = array.get(ep, i0+3)
    int b4 = array.get(eb, i0+4), float p4 = array.get(ep, i0+4)
    // Базовый канал 0-2 (AKU-0011): линия через пивоты 0 и 2 → продолжить до b4
    line.new(b0, p0, b4, priceOnLine(b0, p0, b2, p2, b4),
         xloc = xloc.bar_index, color = color.new(c, 30),
         width = 1, style = line.style_dashed)
    // Параллельная верхняя граница через пивот 1 (вершина W1)
    float offset02 = p1 - priceOnLine(b0, p0, b2, p2, b1)
    line.new(b0, p0 + offset02, b4, priceOnLine(b0, p0, b2, p2, b4) + offset02,
         xloc = xloc.bar_index, color = color.new(c, 50),
         width = 1, style = line.style_dotted)
    // Канал 2-4 (AKU-0054): линия через пивоты 2 и 4 → назад до b0
    line.new(b0, priceOnLine(b2, p2, b4, p4, b0), b4, p4,
         xloc = xloc.bar_index, color = color.new(c, 30),
         width = 1, style = line.style_dashed)
    // Fibonacci проекции Волны-5 (AKU-0201):
    // Цель W5 = end(W3) + 1.618 * (end(W3) - start(W1))
    // Старт от p2 (end W3), не от p4 (end W4)
    bool isUp = p1 > p0
    float m = math.abs(p2 - p0)          // расстояние start(W1) → end(W3)
    float w5target = isUp ? p2 + 1.618 * m : p2 - 1.618 * m
    int   w5bar    = b2 + (b4 - b0)      // проецируем от end(W3) на ту же длину что W1..W4
    line.new(b4, p4, w5bar, w5target, xloc = xloc.bar_index,
         color = color.new(color.yellow, 30), width = 1, style = line.style_dotted)
    label.new(w5bar, w5target, "W5 161.8%", xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_left, color = color.new(color.yellow, 20),
         textcolor = color.white, size = size.tiny)
    // Параллельная граница через пивот 3 (вершина W3)
    float offset24 = p3 - priceOnLine(b2, p2, b4, p4, b3)
    line.new(b0, priceOnLine(b2, p2, b4, p4, b0) + offset24, b4, p4 + offset24,
         xloc = xloc.bar_index, color = color.new(c, 50),
         width = 1, style = line.style_dotted)

// Проверяет правила Импульса (AKU-0001,0004,0005,0002,0007,0009,0127,0126)
// Возвращает: [confirmed, failMsg]
confirmImpulse(array<float> ep, int i0, string dir) =>
    float p0px = array.get(ep, i0),     p1px = array.get(ep, i0 + 1)
    float p2px = array.get(ep, i0 + 2), p3px = array.get(ep, i0 + 3)
    float p4px = array.get(ep, i0 + 4)
    float lw1 = math.abs(p1px - p0px), float lw2 = math.abs(p2px - p1px)
    float lw3 = math.abs(p3px - p2px), float lw4 = math.abs(p4px - p3px)
    // AKU-0001/0004: W2 не пробивает старт W1
    bool r1 = dir == "up" ? p2px > p0px : p2px < p0px
    // AKU-0005: W4 не пробивает старт W3
    bool r2 = dir == "up" ? p4px > p2px : p4px < p2px
    // AKU-0002/0007: W3 >= W1 по цене
    bool r3 = lw3 >= lw1
    // AKU-0127: W2 <= 61.8% W1
    bool r4 = lw1 > 0 ? lw2 / lw1 <= 0.618 : true
    // AKU-0009: ценовые диапазоны W2 и W4 не перекрываются
    float w2lo = math.min(p1px, p2px), float w2hi = math.max(p1px, p2px)
    float w4lo = math.min(p3px, p4px), float w4hi = math.max(p3px, p4px)
    bool r5 = w2hi < w4lo or w4hi < w2lo  // нет пересечения
    // AKU-0126: чередование W2/W4 по цене (>20% разница)
    bool r6 = lw2 > 0 ? (lw4 / lw2 < 0.8 or lw4 / lw2 > 1.2) : true
    // AKU-0203: признаки неправильной начальной точки — длины 1/3/5 почти равны
    float minW = math.min(lw1, math.min(lw3, lw4))
    float maxW = math.max(lw1, math.max(lw3, lw4))
    bool r7 = maxW > 0 ? minW / maxW < 0.85 : true
    bool ok = r1 and r2 and r3 and r4
    string msg = not r1 ? "W2>W1start" : not r2 ? "W4>W3start" :
         not r3 ? "W3<W1" : not r4 ? "W2>61.8%W1" :
         not r5 ? "⚠W2/W4 overlap" : not r6 ? "⚠нет чередования" :
         not r7 ? "⚠W1≈W3≈W5 (неверный старт?)" : ""
    [ok, msg]

// Проверяет Плоскую: B >= 61.8% A (AKU-0017)
confirmFlat(array<float> ep, int i0) =>
    float wA = math.abs(array.get(ep, i0 + 1) - array.get(ep, i0))
    float wB = math.abs(array.get(ep, i0 + 2) - array.get(ep, i0 + 1))
    bool ok = wA > 0 ? wB / wA >= 0.618 : true
    [ok, ok ? "" : "B<61.8%A"]

// Проверяет Треугольник: W3<W1 и W4<W2 (AKU-0018)
confirmTriangle(array<float> ep, int i0) =>
    float lw1 = math.abs(array.get(ep, i0+1)-array.get(ep, i0))
    float lw2 = math.abs(array.get(ep, i0+2)-array.get(ep, i0+1))
    float lw3 = math.abs(array.get(ep, i0+3)-array.get(ep, i0+2))
    float lw4 = math.abs(array.get(ep, i0+4)-array.get(ep, i0+3))
    bool ok = lw3 < lw1 and lw4 < lw2
    [ok, ok ? "" : "не сужается"]

// Возвращает направление по p0→p1
figDirection(float p0px, float p1px) =>
    p1px > p0px ? "up" : "down"

// ─── Hybrid matcher: как Python, напрямую по окнам подтверждённых пивотов ───
// В отличие от base-sequence matcher, этот слой не зависит от :5/:3 для W2/W4,
// поэтому Flat/DC сигналы не пропадают из-за Правил 6-7.
hybridAlternate(array<int> dirs, int i0, int waves) =>
    bool ok = true
    for k = i0 + 2 to i0 + waves
        if array.get(dirs, k) == array.get(dirs, k - 1)
            ok := false
    ok

hybridBounds(array<int> bars, array<float> pxs, int i0, int count) =>
    int b0 = array.get(bars, i0)
    int b1 = array.get(bars, i0 + count - 1)
    float hi = array.get(pxs, i0)
    float lo = array.get(pxs, i0)
    for k = i0 to i0 + count - 1
        float px = array.get(pxs, k)
        hi := math.max(hi, px)
        lo := math.min(lo, px)
    [b0, b1, lo, hi]

hybridFlatOK(array<float> pxs, int i0) =>
    float a = math.abs(array.get(pxs, i0 + 1) - array.get(pxs, i0))
    float b = math.abs(array.get(pxs, i0 + 2) - array.get(pxs, i0 + 1))
    a > 0 and b / a >= 0.618

hybridZigzagOK(array<float> pxs, int i0) =>
    float p0 = array.get(pxs, i0)
    float p1 = array.get(pxs, i0 + 1)
    float p2 = array.get(pxs, i0 + 2)
    float p3 = array.get(pxs, i0 + 3)
    float a = math.abs(p1 - p0)
    float b = math.abs(p2 - p1)
    float c = math.abs(p3 - p2)
    string dir = figDirection(p0, p1)
    bool cBeyondA = dir == "up" ? p3 > p1 : p3 < p1
    a > 0 and b / a < 0.618 and c / a >= 0.618 and cBeyondA

hybridMovingFlatOK(array<float> pxs, int i0) =>
    float p0 = array.get(pxs, i0)
    float p1 = array.get(pxs, i0 + 1)
    float p2 = array.get(pxs, i0 + 2)
    float p3 = array.get(pxs, i0 + 3)
    float a = math.abs(p1 - p0)
    float b = math.abs(p2 - p1)
    float c = math.abs(p3 - p2)
    string dir = figDirection(p0, p1)
    bool bBeyondStart = dir == "up" ? p2 < p0 : p2 > p0
    bool cFailsAEnd = dir == "up" ? p3 < p1 : p3 > p1
    a > 0 and b / a >= 1.0 and c / a >= 0.618 and cFailsAEnd and bBeyondStart

hybridDoubleCorrOK(array<float> pxs, int i0) =>
    float w = math.abs(array.get(pxs, i0 + 1) - array.get(pxs, i0))
    float x = math.abs(array.get(pxs, i0 + 2) - array.get(pxs, i0 + 1))
    float xr = w > 0 ? x / w : na
    not na(xr) and xr > 0.1 and xr < 0.618

hybridImpulseOK(array<float> pxs, int i0) =>
    string dir = figDirection(array.get(pxs, i0), array.get(pxs, i0 + 1))
    [ok, msg] = confirmImpulse(pxs, i0, dir)
    ok

hybridTriangleOK(array<float> pxs, int i0) =>
    [ok, msg] = confirmTriangle(pxs, i0)
    ok

coreSignalColor(string signalType, int dir) =>
    signalType == "TRIANGLE THRUST" ? color.new(color.purple, 0) :
     signalType == "IMPULSE POST" ? color.new(color.blue, 0) :
     signalType == "ZIGZAG REVERSAL" ? color.new(color.aqua, 0) :
     signalType == "MOVING CORR" ? color.new(color.orange, 0) :
     dir > 0 ? color.new(color.lime, 0) : dir < 0 ? color.new(color.red, 0) : color.new(color.gray, 0)

coreDirText(int dir) =>
    dir > 0 ? "LONG/UP" : dir < 0 ? "SHORT/DOWN" : "WAIT"

drawTradeSignal(string figType, string figDir, int confBar, float entryPx,
                int b0, int b1, float lo, float hi, float amp) =>
    bool figUp = figDir == "up"
    bool isLong = not figUp
    float tp = isLong ? entryPx + amp : entryPx - amp
    float sl = isLong ? entryPx - amp : entryPx + amp
    float prob = figType == "flat" ? flatProb : dcProb
    string side = isLong ? "LONG" : "SHORT"
    color sigCol = isLong ? color.lime : color.red
    string title = figType == "flat" ? "FLAT fade" : "DOUBLE CORR fade"
    drawFig(title, b0, b1, lo, hi, color.new(sigCol, 55))
    label.new(confBar, entryPx, side + "\n" + title + "\nP≈" + str.tostring(prob, "#.0") + "%",
         xloc = xloc.bar_index, yloc = yloc.price,
         style = isLong ? label.style_label_up : label.style_label_down,
         color = color.new(sigCol, 0), textcolor = color.white, size = size.normal,
         tooltip = "Research Sprint 6: сигнал появляется на баре подтверждения pivot, не на экстремуме. TP/SL = amplitude фигуры.")
    line.new(confBar, tp, confBar + 50, tp, xloc = xloc.bar_index,
         color = color.new(color.lime, 25), width = 1, style = line.style_dotted)
    line.new(confBar, sl, confBar + 50, sl, xloc = xloc.bar_index,
         color = color.new(color.red, 25), width = 1, style = line.style_dotted)
    label.new(confBar + 50, tp, "TP", xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_left, color = color.new(color.lime, 25),
         textcolor = color.white, size = size.tiny)
    label.new(confBar + 50, sl, "SL/invalid", xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_left, color = color.new(color.red, 25),
         textcolor = color.white, size = size.tiny)

drawNoTrade(string figType, int confBar, float entryPx) =>
    label.new(confBar, entryPx, "NO TRADE\n" + figType,
         xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_left, color = color.new(color.gray, 25),
         textcolor = color.white, size = size.tiny,
         tooltip = "Sprint 6: этот тип фигуры не показал торговый edge. Использовать только как контекст.")

tradeStatusColor(string status, string side) =>
    status == "ACTIVE" ? (side == "LONG" ? color.new(color.lime, 35) : side == "SHORT" ? color.new(color.red, 35) : color.new(color.gray, 55)) :
     status == "TP HIT" ? color.new(color.lime, 20) :
     status == "SL HIT" ? color.new(color.red, 20) :
     status == "EXPIRED" ? color.new(color.orange, 30) :
     color.new(color.gray, 60)

actionColor(string action) =>
    action == "BUY" ? color.new(color.lime, 20) :
     action == "SELL" ? color.new(color.red, 20) :
     color.new(color.gray, 45)

clampPct(float value) =>
    math.max(5.0, math.min(95.0, value))

tpProbability(float baseProb, float offset) =>
    clampPct((na(baseProb) ? 50.0 : baseProb) + offset)

tpText(string title, float prob) =>
    showTpProbabilities ? title + " " + str.tostring(prob, "#") + "%" : title

tfCalibKey() =>
    timeframe.isdaily and timeframe.multiplier == 1 ? "1d" :
     timeframe.isintraday and timeframe.multiplier == 240 ? "4h" :
     timeframe.isintraday and timeframe.multiplier == 60 ? "1h" :
     "fallback"

calibratedTradeStats(string figType, string side, bool isCryptoModel) =>
    string tfKey = tfCalibKey()
    float prob = figType == "flat" ? flatProb : dcProb
    int sampleN = 0
    string conf = "fallback"
    string src = "baseline|fallback"
    if isCryptoModel and figType == "flat" and side == "LONG"
        if tfKey == "4h"
            prob := 58.9, sampleN := 112, conf := "crypto_high", src := "crypto_v0|flat|4h|long"
        else if tfKey == "1d"
            prob := 55.6, sampleN := 27, conf := "crypto_low", src := "crypto_v0|flat|1d|long"
        else if tfKey == "1h"
            prob := 54.0, sampleN := 226, conf := "crypto_ok", src := "crypto_v0|flat|1h|long"
        else
            prob := 52.3, sampleN := 218, conf := "crypto_ok", src := "crypto_v0|flat|long"
    else if isCryptoModel and figType == "flat" and side == "SHORT"
        if tfKey == "4h"
            prob := 69.7, sampleN := 132, conf := "crypto_high", src := "crypto_v0|flat|4h|short"
        else if tfKey == "1d"
            prob := 69.2, sampleN := 26, conf := "crypto_low", src := "crypto_v0|flat|1d|short"
        else if tfKey == "1h"
            prob := 58.8, sampleN := 267, conf := "crypto_ok", src := "crypto_v0|flat|1h|short"
        else
            prob := 55.7, sampleN := 255, conf := "crypto_ok", src := "crypto_v0|flat|short"
    else if isCryptoModel and figType == "double_corr" and side == "LONG"
        if tfKey == "1d"
            prob := 100.0, sampleN := 6, conf := "crypto_low", src := "crypto_v0|double_corr|1d|long"
        else if tfKey == "4h"
            prob := 91.7, sampleN := 12, conf := "crypto_low", src := "crypto_v0|double_corr|4h|long"
        else if tfKey == "1h"
            prob := 90.0, sampleN := 20, conf := "crypto_high", src := "crypto_v0|double_corr|1h|long"
        else
            prob := 82.1, sampleN := 28, conf := "crypto_ok", src := "crypto_v0|double_corr|long"
    else if isCryptoModel and figType == "double_corr" and side == "SHORT"
        if tfKey == "4h"
            prob := 90.9, sampleN := 11, conf := "crypto_low", src := "crypto_v0|double_corr|4h|short"
        else if tfKey == "1h"
            prob := 96.4, sampleN := 28, conf := "crypto_high", src := "crypto_v0|double_corr|1h|short"
        else
            prob := 87.9, sampleN := 33, conf := "crypto_ok", src := "crypto_v0|double_corr|short"
    else if figType == "flat" and side == "LONG"
        if tfKey == "1d"
            prob := 66.7, sampleN := 24, conf := "low", src := "baseline|flat|1d|long"
        else if tfKey == "1h"
            prob := 64.4, sampleN := 59, conf := "grid_high", src := "grid_v0|flat|1h|long|htf_not_against"
        else
            prob := 56.4, sampleN := 275, conf := "high", src := "baseline|flat|long"
    else if figType == "flat" and side == "SHORT"
        if tfKey == "1d"
            prob := 69.6, sampleN := 23, conf := "avoid", src := "grid_v0|avoid|flat|1d|short"
        else if tfKey == "1h"
            prob := 54.5, sampleN := 233, conf := "avoid", src := "grid_v0|avoid|flat|1h|short"
        else
            prob := 55.9, sampleN := 256, conf := "high", src := "baseline|flat|short"
    else if figType == "double_corr" and side == "LONG"
        if tfKey == "1d"
            prob := 100.0, sampleN := 3, conf := "low", src := "baseline|double_corr|1d|long"
        else if tfKey == "1h"
            prob := 78.6, sampleN := 14, conf := "low", src := "baseline|double_corr|1h|long"
        else
            prob := 82.4, sampleN := 17, conf := "low", src := "baseline|double_corr|long"
    else if figType == "double_corr" and side == "SHORT"
        if tfKey == "1d"
            prob := 100.0, sampleN := 1, conf := "low", src := "baseline|double_corr|1d|short"
        else if tfKey == "1h"
            prob := 86.7, sampleN := 15, conf := "low", src := "baseline|double_corr|1h|short"
        else
            prob := 87.5, sampleN := 16, conf := "low", src := "baseline|double_corr|short"
    [prob, sampleN, conf, src]

signalGrade(string action, float prob, int sampleN, string conf, float rr) =>
    if action != "BUY" and action != "SELL"
        "NO TRADE"
    else if conf == "avoid" or prob < minActionProb
        "NO EDGE"
    else if sampleN < 20 or conf == "low"
        "B-SMALL-N"
    else if conf == "grid_high" and not na(rr) and rr >= 1.0
        "A"
    else if prob >= 65 and not na(rr) and rr >= 1.5
        "A"
    else if prob >= 55 and not na(rr) and rr >= 1.0
        "B"
    else
        "C"

scoreNear(float value, float target, float tolerancePct) =>
    not na(value) and target != 0 ? math.max(0.0, 1.0 - math.abs(value - target) / (math.abs(target) * tolerancePct)) : 0.0

scoreBand(float value, float lo, float hi) =>
    float out = 0.0
    if not na(value)
        if value >= lo and value <= hi
            out := 1.0
        else if value < lo and lo != 0
            out := math.max(0.0, 1.0 - (lo - value) / lo)
        else if hi != 0
            out := math.max(0.0, 1.0 - (value - hi) / hi)
    out

fibClusterScore(float ratio) =>
    float s618 = scoreNear(ratio, 0.618, 0.18)
    float s100 = scoreNear(ratio, 1.000, 0.18)
    float s138 = scoreNear(ratio, 1.382, 0.14)
    float s161 = scoreNear(ratio, 1.618, 0.14)
    math.max(s618, math.max(s100, math.max(s138, s161)))

tfFocusScore() =>
    bool is4h = timeframe.isintraday and timeframe.multiplier == 240
    bool is1h = timeframe.isintraday and timeframe.multiplier == 60
    bool is1d = timeframe.isdaily and timeframe.multiplier == 1
    bool is1w = timeframe.isweekly and timeframe.multiplier == 1
    preferLongTermTF ? is1d ? 1.0 : is4h ? 0.95 : is1w ? 0.85 : is1h ? 0.65 : 0.45 : 0.65

htfFocusScore() =>
    bool isHtf4h = htf == "240" or htf == "4H" or htf == "4h"
    bool isHtf1h = htf == "60" or htf == "1H" or htf == "1h"
    bool isHtf1d = htf == "D" or htf == "1D" or htf == "1d"
    bool isHtf1w = htf == "W" or htf == "1W" or htf == "1w"
    preferLongTermTF ? isHtf1d ? 1.0 : isHtf4h ? 0.95 : isHtf1w ? 0.85 : isHtf1h ? 0.65 : 0.45 : 0.65

dirAlignScore(int wantedDir, int biasDir) =>
    biasDir == 0 ? 0.55 : wantedDir * biasDir > 0 ? 1.0 : 0.25

followMomentumScore(int dir, float closePx, float emaFast, float emaSlow, float rsiValue, float volValue, float volAvg) =>
    float emaScore = dir > 0 ? closePx > emaFast and emaFast > emaSlow ? 1.0 : closePx > emaFast ? 0.70 : 0.35 :
         closePx < emaFast and emaFast < emaSlow ? 1.0 : closePx < emaFast ? 0.70 : 0.35
    float rsiScore = dir > 0 ? rsiValue >= 55 ? 1.0 : rsiValue >= 50 ? 0.75 : rsiValue >= 45 ? 0.45 : 0.20 :
         rsiValue <= 45 ? 1.0 : rsiValue <= 50 ? 0.75 : rsiValue <= 55 ? 0.45 : 0.20
    float volScore = na(volAvg) or volAvg == 0 ? 0.50 : volValue > volAvg ? 0.75 : 0.50
    emaScore * 0.45 + rsiScore * 0.35 + volScore * 0.20

reversalExhaustionScore(int fadeDir, float rsiValue, float completionRatio) =>
    float rsiScore = fadeDir > 0 ? rsiValue <= 35 ? 1.0 : rsiValue <= 45 ? 0.75 : rsiValue <= 55 ? 0.45 : 0.20 :
         rsiValue >= 65 ? 1.0 : rsiValue >= 55 ? 0.75 : rsiValue >= 45 ? 0.45 : 0.20
    math.min(1.0, rsiScore * 0.65 + fibClusterScore(completionRatio) * 0.35)

rrFor(int dir, float entry, float stop, float target) =>
    float reward = dir > 0 ? target - entry : entry - target
    float risk = dir > 0 ? entry - stop : stop - entry
    risk > 0 ? reward / risk : na

rrScore(float rr) =>
    na(rr) ? 0.0 : rr >= 2.0 ? 1.0 : rr >= 1.5 ? 0.85 : rr >= 1.0 ? 0.65 : rr >= 0.7 ? 0.35 : 0.10

probFromScores(float patternScore, float fibScore, float htfScore, float momentumScore, float locationScore, float rrQuality, float tfScore) =>
    clampPct(28.0 + patternScore * 18.0 + fibScore * 17.0 + htfScore * 14.0 + momentumScore * 12.0 + locationScore * 12.0 + rrQuality * 5.0 + tfScore * 6.0)

hypothesisGrade(float prob, float rr, bool ready) =>
    ready and prob >= 78 and not na(rr) and rr >= 1.5 ? "A live" :
     ready and prob >= 70 and not na(rr) and rr >= 1.0 ? "B live" :
     prob >= minHypothesisProb ? "WATCH" : "WAIT"

waitNoEntryReason(string reason) =>
    reason == "NO SIGNAL" or reason == "INCOMPLETE" or
     str.contains(reason, "UNSUPPORTED") or str.contains(reason, "CALIBRATION") or str.contains(reason, "ACTION DISABLED") or
     str.contains(reason, "STALE") or str.contains(reason, "LATE") or str.contains(reason, "RR BAD") or
     str.contains(reason, "PROB LOW") or str.contains(reason, "NO EDGE") or str.contains(reason, "SMALL N") or
     str.contains(reason, "HTF W3 ONLY") or str.contains(reason, "HTF AGAINST")

hypColor(float prob, int dir, bool ready) =>
    ready ? dir > 0 ? color.new(color.lime, 0) : color.new(color.red, 0) :
     prob >= minHypothesisProb ? color.new(color.yellow, 5) : color.new(color.gray, 45)

hypSideText(int dir) =>
    dir > 0 ? "LONG" : dir < 0 ? "SHORT" : "WAIT"

hypDirText(int dir) =>
    dir > 0 ? "UP" : dir < 0 ? "DOWN" : "NEUTRAL"

// ─── Рейтинг Энергии (AKU-0213, Гл.10 стр.10-2) ─────────────────────────────
// Возвращает рейтинг энергии и макс. откат следующей волны для подтверждённой фигуры.
// figType: "impulse"|"terminal"|"flat"|"zigzag"|"triangle"|"double_corr"
// dir: 1=восходящая -1=нисходящая
energyRating(string figType, int dir) =>
    int e = 0
    float retracePct = 1.0  // макс. % следующей волны от текущей
    if figType == "impulse"
        e := dir > 0 ? 0 : 0   // Трендовый Импульс: нейтральный (0)
        retracePct := 1.0       // следующая < 100% (не достигает старта)
    else if figType == "terminal"
        e := dir > 0 ? -2 : 2  // Терминал: сильный контртренд
        retracePct := 1.0       // следующая ДОЛЖНА достичь старта (быстро)
    else if figType == "zigzag"
        e := dir > 0 ? 0 : 0
        retracePct := 1.0
    else if figType == "flat"
        e := dir > 0 ? -1 : 1
        retracePct := 0.9
    else if figType == "triangle"
        e := 0                  // Треугольник нейтрален для последующих волн
        retracePct := 1.0
    else if figType == "double_corr"
        e := dir > 0 ? 2 : -2  // Двойная Коррекция: сильная (+2/-2)
        retracePct := 0.8
    [e, retracePct]

// Рисует метку Рейтинга Энергии и линию максимального отката после фигуры.
drawEnergy(int b1, float p1, string figType, int dir, float figLen) =>
    [e, retPct] = energyRating(figType, dir)
    string eStr = e > 0 ? "+" + str.tostring(e) : str.tostring(e)
    string eTip  = "Рейтинг Энергии: " + eStr + " | Макс.откат: " + str.tostring(math.round(retPct*100)) + "% (AKU-0213)"
    color eCol = e > 1 ? color.lime : e < -1 ? color.red : e != 0 ? color.orange : color.gray
    label.new(b1, p1, "E" + eStr, xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_right, color = color.new(eCol, 20),
         textcolor = color.white, size = size.small, tooltip = eTip)
    // Линия максимального отката следующей волны
    if retPct < 1.0 and figLen > 0
        float retLevel = dir > 0 ? p1 - figLen * retPct : p1 + figLen * retPct
        line.new(b1, retLevel, b1 + 30, retLevel, xloc = xloc.bar_index,
             color = color.new(eCol, 40), width = 1, style = line.style_dotted)

// ─── Правило соотношения длительностей (AKU-0205, Гл.9 стр.9-4) ─────────────
// 3 смежных волны одного Порядка не могут иметь одинаковую временную длину.
// Возвращает true если нарушение (все три равны ±10%).
checkTimeEquality(int t1, int t2, int t3) =>
    float tmax = math.max(t1, math.max(t2, t3))
    float tmin = math.min(t1, math.min(t2, t3))
    tmax > 0 ? tmin / tmax > 0.9 : false  // все три в пределах 10% → нарушение

// ─── Правило точек касания (AKU-0204, Гл.9 стр.9-1) ─────────────────────────
// Считает, сколько из 6 пивотов Импульса (p0..p5) лежат на двух линиях канала.
// Если > 4 → скорее Коррекция, чем Импульс.
countTouchpoints(array<float> ep, int i0, int b0lo, float p0lo,
                 int b1lo, float p1lo, int b0hi, float p0hi, int b1hi, float p1hi) =>
    int touches = 0
    for i = 0 to 5
        if i0 + i < array.size(ep)
            float px = array.get(ep, i0 + i)
            float loLine = priceOnLine(b0lo, p0lo, b1lo, p1lo, b0lo + i * 5)
            float hiLine = priceOnLine(b0hi, p0hi, b1hi, p1hi, b0hi + i * 5)
            if math.abs(px - loLine) < loLine * 0.005 or math.abs(px - hiLine) < hiLine * 0.005
                touches += 1
    touches

// ─── Сжатие (Compaction) — Цикл 2 Нили (AKU-0180) ────────────────────────────
// После подтверждения фигуры удаляем N элементов из хвоста массивов и заменяем
// их ОДНИМ сжатым элементом с базовой структурой (:5 для импульса, :3 для коррекции).
// Пивот сжатой волны = начальный бар фигуры + конечная цена.
// AKU-0180: подтверждённая группа сжимается до базовой :3/:5; соседние волны переоцениваются.
compactFigure(array<int> s, array<int> eb, array<float> ep,
              int n, int count, int baseStruct) =>
    // Удаляем count+1 пивотов из хвоста (count волн = count+1 пивот, но первый = граница)
    // Оставляем стартовый пивот фигуры, убираем промежуточные, финальный остаётся
    for i = 0 to count - 1
        if array.size(s) > 1
            array.remove(s,  array.size(s) - 2)   // убираем предпоследний (сохраняем финальный)
            array.remove(eb, array.size(eb) - 2)
            array.remove(ep, array.size(ep) - 2)
    // Меняем последнюю структуру на сжатую
    if array.size(s) > 0
        array.set(s, array.size(s) - 1, baseStruct)

// Сопоставляет хвост последовательности базовых структур (5/3) со Структурными Сериями.
// Приоритет 5-элементных шаблонов (Импульс/Треугольник) — правило 'Зигзаг или Импульс?'.
matchFigure(array<int> s, array<int> eb, array<float> ep, color c) =>
    int n = array.size(s)
    bool drew = false
    if n >= 5
        int v1 = array.get(s, n - 5), v2 = array.get(s, n - 4), v3 = array.get(s, n - 3)
        int v4 = array.get(s, n - 2), v5 = array.get(s, n - 1)
        int startIdx = n >= 6 ? n - 6 : n - 5
        int b0 = array.get(eb, startIdx)
        int b1 = array.get(eb, n - 1)
        float hi = array.get(ep, startIdx), lo = array.get(ep, startIdx)
        for i = startIdx to n - 1
            float p = array.get(ep, i)
            hi := math.max(hi, p)
            lo := math.min(lo, p)
        if v1 == 5 and v2 == 3 and v3 == 5 and v4 == 3 and v5 == 5
            // Уровень 4: подтвердить Импульс + каналы + Сжатие (AKU-0180)
            int pi0 = startIdx
            string dir = figDirection(array.get(ep, pi0), array.get(ep, pi0 + 1))
            [impOK, impMsg] = confirmImpulse(ep, pi0, dir)
            string nm = impOK ? "Импульс ✅" : "Импульс? ❌ " + impMsg
            color fc = impOK ? color.new(color.green, 20) : color.new(color.red, 20)
            drawFig(nm, b0, b1, lo, hi, fc)
            labelSeg(eb, ep, n - 5, ":5|:F3|:5|:F3|:L5", fc)
            if impOK
                // AKU-0205: проверка соотношения длительностей волн (3 не могут быть равны)
                int tb0 = array.get(eb, pi0),  int tb1 = array.get(eb, pi0+1)
                int tb2 = array.get(eb, pi0+2), int tb3 = array.get(eb, pi0+3)
                int tb4 = array.get(eb, pi0+4)
                bool timeEqWarn = checkTimeEquality(tb1-tb0, tb2-tb1, tb3-tb2)
                if timeEqWarn
                    label.new(b1, hi, "⚠ t1≈t2≈t3", xloc = xloc.bar_index,
                         yloc = yloc.price, style = label.style_label_down,
                         color = color.new(color.orange, 20), textcolor = color.white, size = size.tiny)
                drawImpulseChannels(eb, ep, pi0, color.green)
                drawMotionLabels(eb, ep, pi0, 6, "0|1|2|3|4|5", color.green)
                float impLen = math.abs(array.get(ep, n-1) - array.get(ep, pi0))
                drawEnergy(b1, hi, "impulse", dir == "up" ? 1 : -1, impLen)
                // AKU-0224: Реальная линия 2-4 — временное окно прорыва = длительность W5
                // Рисуем вертикальную зону: конец W5 + длительность W5 = ожидаемый прорыв
                int w5dur = tb4 - tb3  // длительность W5 в барах
                if w5dur > 0
                    line.new(tb4 + w5dur, lo, tb4 + w5dur, hi, xloc = xloc.bar_index,
                         color = color.new(color.yellow, 50), width = 1, style = line.style_dotted)
                    label.new(tb4 + w5dur, lo, "↓2-4\n≤W5", xloc = xloc.bar_index,
                         yloc = yloc.price, style = label.style_label_up,
                         color = color.new(color.yellow, 30), textcolor = color.white, size = size.tiny,
                         tooltip = "AKU-0224: прорыв линии 2-4 должен произойти в этот срок (≤ длительности W5). Иначе → W5 сегментирована или Терминал.")
                compactFigure(s, eb, ep, n, 4, 5)  // 5 волн → :5
            drew := true
        else if v1 == 3 and v2 == 3 and v3 == 3 and v4 == 3 and v5 == 3
            // Уровень 4: Треугольник (→:3) ИЛИ Терминал (→:5)
            // AKU Гл.7 стр.7-1: Треугольник сжимается в :3, Терминальный Импульс — в :5
            int pi0 = startIdx
            [triOK, triMsg] = confirmTriangle(ep, pi0)
            // Терминал: те же 3-3-3-3-3 НО волны перекрываются и сужаются как клин
            // Точное различение требует правил Гл.5 стр.5-2 (AKU-0177)
            // В Pine v1: если подтверждён по сужению → помечаем как Треуг. (безопасная версия)
            string nm = triOK ? "Треуг./Терминал ✅" : "Треуг.? ❌ " + triMsg
            color fc = triOK ? color.new(color.purple, 20) : color.new(color.red, 20)
            drawFig(nm, b0, b1, lo, hi, fc)
            labelSeg(eb, ep, n - 5, ":F3|:c3|:c3|:sL3|:L3", fc)
            if triOK
                drawMotionLabels(eb, ep, pi0, 6, "0|a|b|c|d|e", color.purple)
                // Сжатие: :3 для Треугольника, :5 для Терминала — пока :3 (безопасно)
                compactFigure(s, eb, ep, n, 4, 3)
            drew := true
    if not drew and n >= 5
        // Нестандартные серии с x-волнами: Двойной Зигзаг / Двойная Коррекция (AKU-0187..0191)
        // Паттерн: :3 ++ :3(x) ++ :3 — три тройки подряд, средняя = x-волна
        // Проверяем относительный размер x-волны: если средний элемент < 61.8% первого → x-волна
        int dx1 = array.get(s, n - 5), dx2 = array.get(s, n - 4), dx3 = array.get(s, n - 3)
        int dx4 = array.get(s, n - 2), dx5 = array.get(s, n - 1)
        if dx1 == 3 and dx2 == 3 and dx3 == 3 and dx4 == 3 and dx5 == 3
            // 5 троек = потенциальная Двойная Коррекция с большой x + Тройная?
            // Пропускаем — уже детектируется как Треугольник выше
            drew := false
        if not drew and n >= 3
            int cx1 = array.get(s, n - 3), cx2 = array.get(s, n - 2), cx3 = array.get(s, n - 1)
            if cx1 == 3 and cx2 == 3 and cx3 == 3
                // Три тройки — кандидат на Двойную Коррекцию (:3 ++ x:3 ++ :3)
                int dstartIdx = n >= 4 ? n - 4 : n - 3
                int db0 = array.get(eb, dstartIdx)
                int db1 = array.get(eb, n - 1)
                float dhi = array.get(ep, dstartIdx), dlo = array.get(ep, dstartIdx)
                for i = dstartIdx to n - 1
                    float p = array.get(ep, i)
                    dhi := math.max(dhi, p)
                    dlo := math.min(dlo, p)
                // Проверяем размер x-волны (средний элемент)
                float p0x = array.get(ep, n - 4), float p1x = array.get(ep, n - 3)
                float p2x = array.get(ep, n - 2), float p3x = array.get(ep, n - 1)
                float len1 = math.abs(p1x - p0x), float lenX = math.abs(p2x - p1x)
                float xRatio = len1 > 0 ? lenX / len1 : na
                bool isSmallX = not na(xRatio) and xRatio < 0.618   // Условие 1 (AKU-0185)
                bool isBigX   = not na(xRatio) and xRatio >= 1.618  // Условие 2 (AKU-0186)
                if isSmallX
                    drawFig("Двойн.Корр. ✅", db0, db1, dlo, dhi, color.new(color.orange, 20))
                    compactFigure(s, eb, ep, n, 2, 3)  // → :3 (AKU-0191)
                    drew := true
                else if isBigX
                    drawFig("Двойн.Корр.? (большая x)", db0, db1, dlo, dhi, color.new(color.orange, 40))
                    drew := true

    if not drew and n >= 3
        int w1 = array.get(s, n - 3), int w2 = array.get(s, n - 2), int w3 = array.get(s, n - 1)
        int startIdx = n >= 4 ? n - 4 : n - 3
        int b0 = array.get(eb, startIdx)
        int b1 = array.get(eb, n - 1)
        float hi = array.get(ep, startIdx), lo = array.get(ep, startIdx)
        for i = startIdx to n - 1
            float p = array.get(ep, i)
            hi := math.max(hi, p)
            lo := math.min(lo, p)
        if w1 == 3 and w2 == 3 and w3 == 5
            // Уровень 4: подтвердить Плоскую (AKU-0017)
            int pi0 = startIdx
            [flatOK, flatMsg] = confirmFlat(ep, pi0)
            string nm = flatOK ? "Плоская ✅" : "Плоская? ❌ " + flatMsg
            color fc = flatOK ? color.new(color.teal, 20) : color.new(color.red, 20)
            drawFig(nm, b0, b1, lo, hi, fc)
            labelSeg(eb, ep, n - 3, ":F3|:c3|:?5", fc)
            if flatOK
                drawMotionLabels(eb, ep, n - 4, 4, "0|A|B|C", color.teal)
                float flatDir = array.get(ep, n-3) > array.get(ep, n-4) ? 1.0 : -1.0
                float flatLen = math.abs(array.get(ep, n-1) - array.get(ep, n-4))
                drawEnergy(b1, hi, "flat", int(flatDir), flatLen)
                compactFigure(s, eb, ep, n, 2, 3)  // 3 волны → :3
        // Зигзаг (5-3-5) подавлен: неотличим от хвоста Импульса без Индикаторов положения.
        // Активировать после реализации полной логики F/c/L (Гл.3 стр.3-60+).

// ──────────────────── ПОРОГ РАЗВОРОТА (текущий ТФ) ───────────────
revC = useATR ? ta.atr(atrLen) * atrMult : close * pctRev / 100.0

// ──────────────────── ТЕКУЩИЙ ТАЙМФРЕЙМ ──────────────────────────
var ZZState zC = ZZState.new()
var line activeCLine = na
var label activeCLabel = na
var array<int> latestPivotBars = array.new<int>()
var array<float> latestPivotPrices = array.new<float>()
var array<label> latestPivotLabels = array.new<label>()
ZZResult rc = zC.step(high, low, revC)
if showC
    drawMono(rc, colCUp, colCDn, wC, false, colH, showLbl)
if rc.confirmed and not na(rc.prevBar)
    if array.size(latestPivotBars) == 0
        array.push(latestPivotBars, rc.prevBar)
        array.push(latestPivotPrices, rc.prevPrice)
    array.push(latestPivotBars, rc.bar)
    array.push(latestPivotPrices, rc.price)
    while array.size(latestPivotBars) > 6
        array.shift(latestPivotBars)
        array.shift(latestPivotPrices)
// Маркер смены Порядка: смежные моноволны НЕ подобны (AKU-0003) → нужно сжатие
if showC and showSim and rc.simChecked and not rc.similar
    label.new(rc.prevBar, rc.prevPrice, "≠",
         xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_center, color = color.new(color.yellow, 0),
         textcolor = color.black, size = size.tiny,
         tooltip = "Смежные моноволны разного Порядка (правило подобия AKU-0003): " +
         "кандидат на сжатие/перегруппировку")
// Классификация моноволны по Определителю Правил (Уровень 2, AKU-0141/0142)
if showC and showClass and rc.ruleNo > 0
    string lbl = "П" + str.tostring(rc.ruleNo) + rc.condLetter + " " + ruleToStructure(rc.ruleNo)
    label.new(rc.prevBar, rc.prevPrice, lbl,
         xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_left, color = color.new(colClass, 20),
         textcolor = color.white, size = size.tiny,
         tooltip = "Определитель Правил: m2/m1 -> Правило " + str.tostring(rc.ruleNo) +
         ", m0/m1 -> Условие '" + rc.condLetter + "'. Вероятная структура m1: " +
         ruleToStructure(rc.ruleNo) + " (Нили, Гл.3)")

float activeCAmp = not na(zC.pivotPrice) ? math.abs(close - zC.pivotPrice) : na
string activeCDir = waveDirText(zC.dir)
string activeCInfo = not na(zC.pivotBar) and not na(zC.pivotPrice) ? "m" + str.tostring(zC.count) + " " + activeCDir + " / " + waveAtrText(activeCAmp, ta.atr(atrLen)) : "—"
if barstate.islast
    if not na(activeCLine)
        line.delete(activeCLine)
    if not na(activeCLabel)
        label.delete(activeCLabel)
    while array.size(latestPivotLabels) > 0
        label oldPivotLabel = array.pop(latestPivotLabels)
        label.delete(oldPivotLabel)
    activeCLine := na
    activeCLabel := na
    if showLatestPivotNumbers and showC and array.size(latestPivotBars) > 0
        for lp = 0 to array.size(latestPivotBars) - 1
            int pivotX = array.get(latestPivotBars, lp)
            float pivotY = array.get(latestPivotPrices, lp)
            string pivotName = "P" + str.tostring(lp)
            label pivotLabel = label.new(pivotX, pivotY, pivotName,
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(color.black, 0), textcolor = color.white, size = size.small,
                 tooltip = "Pivot-точка моноволны Нили. Структурные метки Elliott/Neely рисуются отдельно: A/B/C, W/X/Y, 1-5 или a-e.")
            array.push(latestPivotLabels, pivotLabel)
    if showActiveWave and showC and not na(zC.pivotBar) and not na(zC.pivotPrice)
        color activeCColor = zC.dir > 0 ? colCUp : zC.dir < 0 ? colCDn : color.gray
        activeCLine := line.new(zC.pivotBar, zC.pivotPrice, bar_index, close,
             xloc = xloc.bar_index, color = color.new(activeCColor, 0),
             width = activeWaveWidth, style = line.style_dotted)
        activeCLabel := label.new(bar_index, close, "LAST BAR WAVE\n" + activeCInfo,
             xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
             color = color.new(activeCColor, 10), textcolor = color.white, size = size.tiny,
             tooltip = "Активная незавершённая моноволна текущего ТФ: от последнего подтверждённого pivot до последнего бара.")

// ── Накопление базовых структур и распознавание фигур (Уровень 3) ──
// Окно ограничено 10 элементами — достаточно для 5-эл. шаблона + контекст.
// Без ограничения массивы растут до тысяч баров → ложные рамки на всей истории.
var array<int>   figStruct  = array.new<int>()
var array<int>   figEndBar  = array.new<int>()
var array<float> figEndPx   = array.new<float>()
if showFig and rc.ruleNo > 0
    string st = ruleToStructure(rc.ruleNo)
    int base = st == ":5" ? 5 : st == ":F3" ? 3 : 0
    array.push(figStruct, base)
    array.push(figEndBar, rc.prevBar)
    array.push(figEndPx, rc.prevPrice)
    while array.size(figStruct) > 10
        array.shift(figStruct)
        array.shift(figEndBar)
        array.shift(figEndPx)
    if base > 0
        matchFigure(figStruct, figEndBar, figEndPx, colFig)

// ── Hybrid trade matcher: подтверждённые пивоты текущего ТФ ──
var array<int>   hybBar  = array.new<int>()
var array<float> hybPx   = array.new<float>()
var array<int>   hybDir  = array.new<int>()
var array<int>   hybConf = array.new<int>()
var bool hybInit = false
var int lastTradeConfBar = na
var string lastTradeSide = "—"
var string lastTradeType = "—"
var float lastTradeProb = na
var float lastTradeEntry = na
var float lastTradeTp = na
var float lastTradeSl = na
var float lastTradeAmp = na
var int lastTradeB0 = na
var int lastTradeB1 = na
var float lastTradeLo = na
var float lastTradeHi = na
var int lastTradeWaveBar0 = na
var int lastTradeWaveBar1 = na
var int lastTradeWaveBar2 = na
var int lastTradeWaveBar3 = na
var float lastTradeWavePx0 = na
var float lastTradeWavePx1 = na
var float lastTradeWavePx2 = na
var float lastTradeWavePx3 = na
var string lastTradeStatus = "—"
var int lastTradeAge = na
var int lastTradeSampleN = 0
var string lastTradeConfidence = "—"
var string lastTradeProbSource = "—"
var int lastCoreConfBar = na
var string lastCoreSignal = "—"
var string lastCoreSide = "—"
var string lastCoreReason = "—"
var float lastCoreEntry = na
var float lastCoreTarget = na
var float lastCoreInvalid = na
var int lastCoreAge = na
var int lastCoreDir = 0
var int lastCoreWaveCount = 0
var int lastCoreWaveBar0 = na
var int lastCoreWaveBar1 = na
var int lastCoreWaveBar2 = na
var int lastCoreWaveBar3 = na
var int lastCoreWaveBar4 = na
var int lastCoreWaveBar5 = na
var float lastCoreWavePx0 = na
var float lastCoreWavePx1 = na
var float lastCoreWavePx2 = na
var float lastCoreWavePx3 = na
var float lastCoreWavePx4 = na
var float lastCoreWavePx5 = na
var bool tradeLongSignal = false
var bool tradeShortSignal = false
var bool coreSignalEvent = false
var bool coreImpulseEvent = false
var bool coreTriangleEvent = false
var bool coreZigzagEvent = false
var bool coreMovingCorrEvent = false
tradeLongSignal := false
tradeShortSignal := false
coreSignalEvent := false
coreImpulseEvent := false
coreTriangleEvent := false
coreZigzagEvent := false
coreMovingCorrEvent := false

if (showTrade or showCoreSignals or showNoise or showLiveHypothesis) and rc.confirmed and not na(rc.prevBar)
    if not hybInit
        array.push(hybBar, rc.prevBar)
        array.push(hybPx, rc.prevPrice)
        array.push(hybDir, 0)
        array.push(hybConf, rc.prevBar)
        hybInit := true
    array.push(hybBar, rc.bar)
    array.push(hybPx, rc.price)
    array.push(hybDir, rc.dir)
    array.push(hybConf, bar_index)
    while array.size(hybBar) > maxHybridPivots
        array.shift(hybBar)
        array.shift(hybPx)
        array.shift(hybDir)
        array.shift(hybConf)

    int hn = array.size(hybBar)
    bool matchedTrade = false
    if showTrade and hn >= 4
        int s4 = hn - 4
        bool alt4 = hybridAlternate(hybDir, s4, 3)
        if alt4
            string figDir4 = figDirection(array.get(hybPx, s4), array.get(hybPx, s4 + 1))
            int confBar4 = array.get(hybConf, hn - 1)
            float entry4 = close
            float amp4 = math.abs(array.get(hybPx, s4 + 3) - array.get(hybPx, s4))
            [b0h4, b1h4, loh4, hih4] = hybridBounds(hybBar, hybPx, s4, 4)
            if hybridFlatOK(hybPx, s4)
                if showTradeMarkers
                    drawTradeSignal("flat", figDir4, confBar4, entry4, b0h4, b1h4, loh4, hih4, amp4)
                bool isLongFlat = figDir4 == "down"
                tradeLongSignal := isLongFlat
                tradeShortSignal := not isLongFlat
                string sideFlat = isLongFlat ? "LONG" : "SHORT"
                [probFlat, nFlat, confFlat, srcFlat] = calibratedTradeStats("flat", sideFlat, syminfo.type == "crypto")
                lastTradeConfBar := confBar4
                lastTradeSide := sideFlat
                lastTradeType := "Flat fade"
                lastTradeProb := probFlat
                lastTradeEntry := entry4
                lastTradeTp := isLongFlat ? entry4 + amp4 * actionTargetMult : entry4 - amp4 * actionTargetMult
                lastTradeSl := isLongFlat ? entry4 - amp4 * actionStopMult : entry4 + amp4 * actionStopMult
                lastTradeAmp := amp4
                lastTradeB0 := b0h4
                lastTradeB1 := b1h4
                lastTradeLo := loh4
                lastTradeHi := hih4
                lastTradeWaveBar0 := array.get(hybBar, s4)
                lastTradeWaveBar1 := array.get(hybBar, s4 + 1)
                lastTradeWaveBar2 := array.get(hybBar, s4 + 2)
                lastTradeWaveBar3 := array.get(hybBar, s4 + 3)
                lastTradeWavePx0 := array.get(hybPx, s4)
                lastTradeWavePx1 := array.get(hybPx, s4 + 1)
                lastTradeWavePx2 := array.get(hybPx, s4 + 2)
                lastTradeWavePx3 := array.get(hybPx, s4 + 3)
                lastTradeStatus := "ACTIVE"
                lastTradeAge := 0
                lastTradeSampleN := nFlat
                lastTradeConfidence := confFlat
                lastTradeProbSource := srcFlat
                matchedTrade := true
            else if hybridDoubleCorrOK(hybPx, s4)
                if showTradeMarkers
                    drawTradeSignal("double_corr", figDir4, confBar4, entry4, b0h4, b1h4, loh4, hih4, amp4)
                bool isLongDc = figDir4 == "down"
                tradeLongSignal := isLongDc
                tradeShortSignal := not isLongDc
                string sideDc = isLongDc ? "LONG" : "SHORT"
                [probDc, nDc, confDc, srcDc] = calibratedTradeStats("double_corr", sideDc, syminfo.type == "crypto")
                lastTradeConfBar := confBar4
                lastTradeSide := sideDc
                lastTradeType := "DoubleCorr fade"
                lastTradeProb := probDc
                lastTradeEntry := entry4
                lastTradeTp := isLongDc ? entry4 + amp4 * actionTargetMult : entry4 - amp4 * actionTargetMult
                lastTradeSl := isLongDc ? entry4 - amp4 * actionStopMult : entry4 + amp4 * actionStopMult
                lastTradeAmp := amp4
                lastTradeB0 := b0h4
                lastTradeB1 := b1h4
                lastTradeLo := loh4
                lastTradeHi := hih4
                lastTradeWaveBar0 := array.get(hybBar, s4)
                lastTradeWaveBar1 := array.get(hybBar, s4 + 1)
                lastTradeWaveBar2 := array.get(hybBar, s4 + 2)
                lastTradeWaveBar3 := array.get(hybBar, s4 + 3)
                lastTradeWavePx0 := array.get(hybPx, s4)
                lastTradeWavePx1 := array.get(hybPx, s4 + 1)
                lastTradeWavePx2 := array.get(hybPx, s4 + 2)
                lastTradeWavePx3 := array.get(hybPx, s4 + 3)
                lastTradeStatus := "ACTIVE"
                lastTradeAge := 0
                lastTradeSampleN := nDc
                lastTradeConfidence := confDc
                lastTradeProbSource := srcDc
                matchedTrade := true
    if showNoise and not matchedTrade and hn >= 6
        int s6 = hn - 6
        bool alt6 = hybridAlternate(hybDir, s6, 5)
        if alt6
            int confBar6 = array.get(hybConf, hn - 1)
            float entry6 = close
            if hybridImpulseOK(hybPx, s6)
                drawNoTrade("Impulse", confBar6, entry6)
            else if hybridTriangleOK(hybPx, s6)
                drawNoTrade("Triangle", confBar6, entry6)

    if showCoreSignals
        bool matchedCore = false
        if hn >= 6
            int c6 = hn - 6
            bool altCore6 = hybridAlternate(hybDir, c6, 5)
            if altCore6
                int confBarCore6 = array.get(hybConf, hn - 1)
                float entryCore6 = close
                float p0c6 = array.get(hybPx, c6)
                float p1c6 = array.get(hybPx, c6 + 1)
                float p2c6 = array.get(hybPx, c6 + 2)
                float p3c6 = array.get(hybPx, c6 + 3)
                float p4c6 = array.get(hybPx, c6 + 4)
                float p5c6 = array.get(hybPx, c6 + 5)
                if hybridImpulseOK(hybPx, c6)
                    string impDir = figDirection(p0c6, p1c6)
                    int postDir = impDir == "up" ? -1 : 1
                    lastCoreConfBar := confBarCore6
                    lastCoreSignal := "IMPULSE POST"
                    lastCoreSide := "WAIT / pullback " + coreDirText(postDir)
                    lastCoreReason := "Post-pattern: watch W4 zone, not raw chase"
                    lastCoreEntry := entryCore6
                    lastCoreTarget := p4c6
                    lastCoreInvalid := p0c6
                    lastCoreAge := 0
                    lastCoreDir := postDir
                    lastCoreWaveCount := 6
                    lastCoreWaveBar0 := array.get(hybBar, c6)
                    lastCoreWaveBar1 := array.get(hybBar, c6 + 1)
                    lastCoreWaveBar2 := array.get(hybBar, c6 + 2)
                    lastCoreWaveBar3 := array.get(hybBar, c6 + 3)
                    lastCoreWaveBar4 := array.get(hybBar, c6 + 4)
                    lastCoreWaveBar5 := array.get(hybBar, c6 + 5)
                    lastCoreWavePx0 := p0c6
                    lastCoreWavePx1 := p1c6
                    lastCoreWavePx2 := p2c6
                    lastCoreWavePx3 := p3c6
                    lastCoreWavePx4 := p4c6
                    lastCoreWavePx5 := p5c6
                    coreSignalEvent := true
                    coreImpulseEvent := true
                    matchedCore := true
                else if hybridTriangleOK(hybPx, c6)
                    float w1c = math.abs(p1c6 - p0c6)
                    float w2c = math.abs(p2c6 - p1c6)
                    float w3c = math.abs(p3c6 - p2c6)
                    float w4c = math.abs(p4c6 - p3c6)
                    float widest = math.max(w1c, math.max(w2c, math.max(w3c, w4c)))
                    int eDir = p5c6 > p4c6 ? 1 : -1
                    int thrustDir = -eDir
                    lastCoreConfBar := confBarCore6
                    lastCoreSignal := "TRIANGLE THRUST"
                    lastCoreSide := coreDirText(thrustDir)
                    lastCoreReason := "Post-pattern: thrust target = widest triangle wave"
                    lastCoreEntry := entryCore6
                    lastCoreTarget := p5c6 + thrustDir * widest
                    lastCoreInvalid := p5c6 - thrustDir * widest * 0.382
                    lastCoreAge := 0
                    lastCoreDir := thrustDir
                    lastCoreWaveCount := 6
                    lastCoreWaveBar0 := array.get(hybBar, c6)
                    lastCoreWaveBar1 := array.get(hybBar, c6 + 1)
                    lastCoreWaveBar2 := array.get(hybBar, c6 + 2)
                    lastCoreWaveBar3 := array.get(hybBar, c6 + 3)
                    lastCoreWaveBar4 := array.get(hybBar, c6 + 4)
                    lastCoreWaveBar5 := array.get(hybBar, c6 + 5)
                    lastCoreWavePx0 := p0c6
                    lastCoreWavePx1 := p1c6
                    lastCoreWavePx2 := p2c6
                    lastCoreWavePx3 := p3c6
                    lastCoreWavePx4 := p4c6
                    lastCoreWavePx5 := p5c6
                    coreSignalEvent := true
                    coreTriangleEvent := true
                    matchedCore := true
        if not matchedCore and hn >= 4
            int c4 = hn - 4
            bool altCore4 = hybridAlternate(hybDir, c4, 3)
            if altCore4
                int confBarCore4 = array.get(hybConf, hn - 1)
                float entryCore4 = close
                float p0c4 = array.get(hybPx, c4)
                float p1c4 = array.get(hybPx, c4 + 1)
                float p2c4 = array.get(hybPx, c4 + 2)
                float p3c4 = array.get(hybPx, c4 + 3)
                string figDirCore4 = figDirection(p0c4, p1c4)
                int fadeDir = figDirCore4 == "up" ? -1 : 1
                float aLenCore = math.abs(p1c4 - p0c4)
                float cTarget100 = p2c4 + fadeDir * -1 * aLenCore
                float cTarget161 = p2c4 + fadeDir * -1 * aLenCore * 1.618
                if hybridMovingFlatOK(hybPx, c4)
                    int followDir = fadeDir
                    lastCoreConfBar := confBarCore4
                    lastCoreSignal := "MOVING CORR"
                    lastCoreSide := "RESEARCH follow " + coreDirText(followDir)
                    lastCoreReason := "Moving correction: expect strong post-pattern impulse"
                    lastCoreEntry := entryCore4
                    lastCoreTarget := entryCore4 + followDir * aLenCore * 1.618
                    lastCoreInvalid := p3c4 - followDir * aLenCore * 0.382
                    lastCoreAge := 0
                    lastCoreDir := followDir
                    lastCoreWaveCount := 4
                    lastCoreWaveBar0 := array.get(hybBar, c4)
                    lastCoreWaveBar1 := array.get(hybBar, c4 + 1)
                    lastCoreWaveBar2 := array.get(hybBar, c4 + 2)
                    lastCoreWaveBar3 := array.get(hybBar, c4 + 3)
                    lastCoreWaveBar4 := na
                    lastCoreWaveBar5 := na
                    lastCoreWavePx0 := p0c4
                    lastCoreWavePx1 := p1c4
                    lastCoreWavePx2 := p2c4
                    lastCoreWavePx3 := p3c4
                    lastCoreWavePx4 := na
                    lastCoreWavePx5 := na
                    coreSignalEvent := true
                    coreMovingCorrEvent := true
                else if hybridZigzagOK(hybPx, c4)
                    bool cAtOneToOne = math.abs(p3c4 - cTarget100) <= aLenCore * 0.1
                    int zigzagDir = cAtOneToOne ? fadeDir : -fadeDir
                    lastCoreConfBar := confBarCore4
                    lastCoreSignal := "ZIGZAG REVERSAL"
                    lastCoreSide := cAtOneToOne ? "WAIT / reversal " + coreDirText(fadeDir) : "WAIT / C=A " + coreDirText(zigzagDir)
                    lastCoreReason := cAtOneToOne ? "C≈A reached; watch reversal confirmation" : "Zigzag: monitor C=A completion level"
                    lastCoreEntry := entryCore4
                    lastCoreTarget := cAtOneToOne ? p2c4 : cTarget100
                    lastCoreInvalid := cAtOneToOne ? cTarget161 : p2c4
                    lastCoreAge := 0
                    lastCoreDir := zigzagDir
                    lastCoreWaveCount := 4
                    lastCoreWaveBar0 := array.get(hybBar, c4)
                    lastCoreWaveBar1 := array.get(hybBar, c4 + 1)
                    lastCoreWaveBar2 := array.get(hybBar, c4 + 2)
                    lastCoreWaveBar3 := array.get(hybBar, c4 + 3)
                    lastCoreWaveBar4 := na
                    lastCoreWaveBar5 := na
                    lastCoreWavePx0 := p0c4
                    lastCoreWavePx1 := p1c4
                    lastCoreWavePx2 := p2c4
                    lastCoreWavePx3 := p3c4
                    lastCoreWavePx4 := na
                    lastCoreWavePx5 := na
                    coreSignalEvent := true
                    coreZigzagEvent := true

if lastTradeStatus == "ACTIVE" and not na(lastTradeConfBar) and bar_index > lastTradeConfBar and not na(lastTradeTp) and not na(lastTradeSl)
    lastTradeAge := bar_index - lastTradeConfBar
    bool lastIsLong = lastTradeSide == "LONG"
    bool tpHit = lastIsLong ? high >= lastTradeTp : low <= lastTradeTp
    bool slHit = lastIsLong ? low <= lastTradeSl : high >= lastTradeSl
    if slHit
        // Консервативно: если TP и SL достигнуты в одном баре, считаем риск первым.
        lastTradeStatus := "SL HIT"
        if showTradeMarkers
            label.new(bar_index, lastTradeSl, "EXIT SL",
                 xloc = xloc.bar_index, yloc = yloc.price,
                 style = label.style_label_left, color = color.new(color.red, 0),
                 textcolor = color.white, size = size.tiny,
                 tooltip = "Фактический выход по Stop Loss последнего Flat/DC плана.")
    else if tpHit
        lastTradeStatus := "TP HIT"
        if showTradeMarkers
            label.new(bar_index, lastTradeTp, "EXIT TP",
                 xloc = xloc.bar_index, yloc = yloc.price,
                 style = label.style_label_left, color = color.new(color.lime, 0),
                 textcolor = color.white, size = size.tiny,
                 tooltip = "Фактический выход по Take Profit последнего Flat/DC плана.")
    else if lastTradeAge > tradeMaxAgeBars
        lastTradeStatus := "EXPIRED"
        if showTradeMarkers
            label.new(bar_index, close, "EXIT TIME",
                 xloc = xloc.bar_index, yloc = yloc.price,
                 style = label.style_label_left, color = color.new(color.orange, 0),
                 textcolor = color.white, size = size.tiny,
                 tooltip = "Выход по времени: план устарел до TP/SL.")

if not na(lastCoreConfBar)
    lastCoreAge := bar_index - lastCoreConfBar

// ──────────────────── СТАРШИЙ ТАЙМФРЕЙМ (MTF) ────────────────────
// Запрашиваем OHLC старшего ТФ; детектор шагает только при закрытии HTF-бара.
// Pine v6: tuple в request.security не поддерживается — отдельный запрос на каждое значение.
float hHigh  = request.security(syminfo.tickerid, htf, high,          lookahead = barmerge.lookahead_off)
float hLow   = request.security(syminfo.tickerid, htf, low,           lookahead = barmerge.lookahead_off)
float hClose = request.security(syminfo.tickerid, htf, close,         lookahead = barmerge.lookahead_off)
int   hTime  = request.security(syminfo.tickerid, htf, time,          lookahead = barmerge.lookahead_off)
float hAtr   = request.security(syminfo.tickerid, htf, ta.atr(atrLen), lookahead = barmerge.lookahead_off)
float hEmaFast = request.security(syminfo.tickerid, htf, ta.ema(close, 34), lookahead = barmerge.lookahead_off)
float hEmaSlow = request.security(syminfo.tickerid, htf, ta.ema(close, 89), lookahead = barmerge.lookahead_off)
float hRsi = request.security(syminfo.tickerid, htf, ta.rsi(close, 14), lookahead = barmerge.lookahead_off)
float hVol = request.security(syminfo.tickerid, htf, volume, lookahead = barmerge.lookahead_off)
float hVolAvg = request.security(syminfo.tickerid, htf, ta.sma(volume, 20), lookahead = barmerge.lookahead_off)

revH = useATR ? hAtr * atrMult : hClose * pctRev / 100.0

var ZZState zH = ZZState.new()
var line activeHLine = na
var label activeHLabel = na
var int htfBiasDir = 0
var int htfPrevDir = 0
var int htfLastDir = 0
var array<int> htfPivotBars = array.new<int>()
var array<float> htfPivotPrices = array.new<float>()
int   hTimeChg = ta.change(hTime)
bool newHTF = not na(hTime) and hTimeChg != 0
if newHTF and not na(hHigh)
    ZZResult rh = zH.step(hHigh, hLow, revH)
    if rh.confirmed
        htfPrevDir := htfLastDir
        htfLastDir := rh.dir
        htfBiasDir := htfPrevDir != 0 and htfPrevDir == htfLastDir ? 2 * htfLastDir : htfLastDir
        if array.size(htfPivotBars) == 0
            array.push(htfPivotBars, rh.prevBar)
            array.push(htfPivotPrices, rh.prevPrice)
        array.push(htfPivotBars, rh.bar)
        array.push(htfPivotPrices, rh.price)
        while array.size(htfPivotBars) > 8
            array.shift(htfPivotBars)
            array.shift(htfPivotPrices)
    if showH
        drawMono(rh, colCUp, colCDn, wH, true, colH, showLbl)

string htfBias = htfBiasDir > 1 ? "UP strong" : htfBiasDir > 0 ? "UP" : htfBiasDir < -1 ? "DOWN strong" : htfBiasDir < 0 ? "DOWN" : "NEUTRAL"
float activeHPrice = na(hClose) ? close : hClose
float activeHAmp = not na(zH.pivotPrice) ? math.abs(activeHPrice - zH.pivotPrice) : na
string activeHDir = waveDirText(zH.dir)
string activeHInfo = not na(zH.pivotBar) and not na(zH.pivotPrice) ? activeHDir + " / " + waveAtrText(activeHAmp, hAtr) + " / " + htfBias : "—"
if barstate.islast
    if not na(activeHLine)
        line.delete(activeHLine)
    if not na(activeHLabel)
        label.delete(activeHLabel)
    activeHLine := na
    activeHLabel := na
    if showActiveHTFWave and showH and not na(zH.pivotBar) and not na(zH.pivotPrice)
        activeHLine := line.new(zH.pivotBar, zH.pivotPrice, bar_index, activeHPrice,
             xloc = xloc.bar_index, color = color.new(colH, 0),
             width = activeWaveWidth + 1, style = line.style_dashed)
        activeHLabel := label.new(bar_index + 1, activeHPrice, "Active HTF " + htf + "\n" + activeHInfo,
             xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
             color = color.new(colH, 5), textcolor = color.white, size = size.tiny,
             tooltip = "Активная незавершённая HTF-моноволна: от последнего подтверждённого HTF pivot до текущего HTF close.")

int htfPivotN = array.size(htfPivotBars)
string htfWave3Name = "HTF no W3 bias"
string htfWave3Plan = "HTF no W3 bias"
string htfWave3Reason = "Need W1/W2 pivots"
float htfWave3Prob = na
float htfWave3Invalid = na
float htfWave3Target1 = na
float htfWave3Target2 = na
float htfWave3W2Ratio = na
float htfWave3ActiveRatio = na
int htfWave3Dir = 0
bool htfWave3Breakout = false
bool htfWave3Candidate = false
bool htfWave3BiasActive = false

if showHtfWave3Bias and htfPivotN >= 3
    int hw0 = htfPivotN - 3
    int hw1 = htfPivotN - 2
    int hw2 = htfPivotN - 1
    float hp0 = array.get(htfPivotPrices, hw0)
    float hp1 = array.get(htfPivotPrices, hw1)
    float hp2 = array.get(htfPivotPrices, hw2)
    int w3Dir = hp1 > hp0 ? 1 : -1
    float w1Len = math.abs(hp1 - hp0)
    float w2Len = math.abs(hp2 - hp1)
    float activeMove = w3Dir > 0 ? activeHPrice - hp2 : hp2 - activeHPrice
    htfWave3W2Ratio := w1Len > 0 ? w2Len / w1Len : na
    htfWave3ActiveRatio := w1Len > 0 ? math.max(0.0, activeMove) / w1Len : na
    bool w2Valid = w1Len > 0 and not na(htfWave3W2Ratio) and htfWave3W2Ratio > 0.10 and htfWave3W2Ratio < 1.00 and (w3Dir > 0 ? hp2 > hp0 : hp2 < hp0)
    bool w3Moves = activeMove > (na(hAtr) ? w1Len * 0.05 : hAtr * 0.20)
    htfWave3Breakout := w3Dir > 0 ? activeHPrice > hp1 : activeHPrice < hp1
    htfWave3Candidate := w2Valid and w3Moves
    if htfWave3Candidate
        float w2Score = math.max(scoreBand(htfWave3W2Ratio, 0.382, 0.786), scoreNear(htfWave3W2Ratio, 0.618, 0.20))
        float activeScore = htfWave3Breakout ? 1.0 : htfWave3ActiveRatio >= 0.382 ? 0.75 : htfWave3ActiveRatio >= 0.20 ? 0.55 : 0.35
        float htfMomentumScore = followMomentumScore(w3Dir, activeHPrice, hEmaFast, hEmaSlow, hRsi, hVol, hVolAvg)
        float htfTrendScore = dirAlignScore(w3Dir, htfBiasDir)
        float htfRRScore = htfWave3Breakout ? 0.80 : 1.0
        htfWave3Prob := probFromScores(0.82, w2Score, htfTrendScore, htfMomentumScore, activeScore, htfRRScore, htfFocusScore())
        htfWave3BiasActive := htfWave3Prob >= minHtfWave3Prob
        htfWave3Dir := w3Dir
        htfWave3Name := htfWave3Dir > 0 ? "HTF possible W3 UP" : "HTF possible W3 DOWN"
        htfWave3Plan := htfWave3BiasActive ? (htfWave3Dir > 0 ? "HTF W3 UP -> buy LTF pullbacks" : "HTF W3 DOWN -> sell LTF pullbacks") : "HTF W3 watch only"
        htfWave3Reason := "W2/W1 " + str.tostring(htfWave3W2Ratio, "#.00") + ", W3/W1 " + str.tostring(htfWave3ActiveRatio, "#.00") + (htfWave3Breakout ? ", W1 break" : ", pre-break")
        float htfBuffer = na(hAtr) ? w1Len * 0.05 : hAtr * 0.25
        htfWave3Invalid := hp2 - htfWave3Dir * htfBuffer
        htfWave3Target1 := hp2 + htfWave3Dir * w1Len * 1.618
        htfWave3Target2 := hp2 + htfWave3Dir * w1Len * 2.618

// ───────────────────── HTF WAVE MAP (VISUAL CONTEXT) ─────────────────────
int currentTfRank = chartTfRank()
bool map1hEnabled = contextTfEnabled(2, currentTfRank)
bool map4hEnabled = contextTfEnabled(3, currentTfRank)
bool mapDEnabled = contextTfEnabled(4, currentTfRank)
bool mapWEnabled = contextTfEnabled(5, currentTfRank)
bool mapMEnabled = contextTfEnabled(6, currentTfRank)

float map1hHigh = request.security(syminfo.tickerid, "60", high, lookahead = barmerge.lookahead_off)
float map1hLow = request.security(syminfo.tickerid, "60", low, lookahead = barmerge.lookahead_off)
float map1hClose = request.security(syminfo.tickerid, "60", close, lookahead = barmerge.lookahead_off)
int map1hTime = request.security(syminfo.tickerid, "60", time, lookahead = barmerge.lookahead_off)
float map1hAtr = request.security(syminfo.tickerid, "60", ta.atr(atrLen), lookahead = barmerge.lookahead_off)

float map4hHigh = request.security(syminfo.tickerid, "240", high, lookahead = barmerge.lookahead_off)
float map4hLow = request.security(syminfo.tickerid, "240", low, lookahead = barmerge.lookahead_off)
float map4hClose = request.security(syminfo.tickerid, "240", close, lookahead = barmerge.lookahead_off)
int map4hTime = request.security(syminfo.tickerid, "240", time, lookahead = barmerge.lookahead_off)
float map4hAtr = request.security(syminfo.tickerid, "240", ta.atr(atrLen), lookahead = barmerge.lookahead_off)

float mapDHigh = request.security(syminfo.tickerid, "D", high, lookahead = barmerge.lookahead_off)
float mapDLow = request.security(syminfo.tickerid, "D", low, lookahead = barmerge.lookahead_off)
float mapDClose = request.security(syminfo.tickerid, "D", close, lookahead = barmerge.lookahead_off)
int mapDTime = request.security(syminfo.tickerid, "D", time, lookahead = barmerge.lookahead_off)
float mapDAtr = request.security(syminfo.tickerid, "D", ta.atr(atrLen), lookahead = barmerge.lookahead_off)

float mapWHigh = request.security(syminfo.tickerid, "W", high, lookahead = barmerge.lookahead_off)
float mapWLow = request.security(syminfo.tickerid, "W", low, lookahead = barmerge.lookahead_off)
float mapWClose = request.security(syminfo.tickerid, "W", close, lookahead = barmerge.lookahead_off)
int mapWTime = request.security(syminfo.tickerid, "W", time, lookahead = barmerge.lookahead_off)
float mapWAtr = request.security(syminfo.tickerid, "W", ta.atr(atrLen), lookahead = barmerge.lookahead_off)

float mapMHigh = request.security(syminfo.tickerid, "M", high, lookahead = barmerge.lookahead_off)
float mapMLow = request.security(syminfo.tickerid, "M", low, lookahead = barmerge.lookahead_off)
float mapMClose = request.security(syminfo.tickerid, "M", close, lookahead = barmerge.lookahead_off)
int mapMTime = request.security(syminfo.tickerid, "M", time, lookahead = barmerge.lookahead_off)
float mapMAtr = request.security(syminfo.tickerid, "M", ta.atr(atrLen), lookahead = barmerge.lookahead_off)

var ZZState zMap1h = ZZState.new()
var ZZState zMap4h = ZZState.new()
var ZZState zMapD = ZZState.new()
var ZZState zMapW = ZZState.new()
var ZZState zMapM = ZZState.new()
var array<int> map1hBars = array.new<int>()
var array<float> map1hPrices = array.new<float>()
var array<int> map4hBars = array.new<int>()
var array<float> map4hPrices = array.new<float>()
var array<int> mapDBars = array.new<int>()
var array<float> mapDPrices = array.new<float>()
var array<int> mapWBars = array.new<int>()
var array<float> mapWPrices = array.new<float>()
var array<int> mapMBars = array.new<int>()
var array<float> mapMPrices = array.new<float>()
var array<line> map1hLines = array.new<line>()
var array<label> map1hLabels = array.new<label>()
var array<line> map4hLines = array.new<line>()
var array<label> map4hLabels = array.new<label>()
var array<line> mapDLines = array.new<line>()
var array<label> mapDLabels = array.new<label>()
var array<line> mapWLines = array.new<line>()
var array<label> mapWLabels = array.new<label>()
var array<line> mapMLines = array.new<line>()
var array<label> mapMLabels = array.new<label>()

int mapMaxPivots = htfContextSegments + 2
int map1hTimeChg = ta.change(map1hTime)
int map4hTimeChg = ta.change(map4hTime)
int mapDTimeChg = ta.change(mapDTime)
int mapWTimeChg = ta.change(mapWTime)
int mapMTimeChg = ta.change(mapMTime)
if map1hEnabled and not na(map1hHigh) and map1hTimeChg != 0
    ZZResult rMap1h = zMap1h.step(map1hHigh, map1hLow, useATR ? map1hAtr * atrMult : map1hClose * pctRev / 100.0)
    rememberContextPivot(map1hBars, map1hPrices, rMap1h, mapMaxPivots)
if map4hEnabled and not na(map4hHigh) and map4hTimeChg != 0
    ZZResult rMap4h = zMap4h.step(map4hHigh, map4hLow, useATR ? map4hAtr * atrMult : map4hClose * pctRev / 100.0)
    rememberContextPivot(map4hBars, map4hPrices, rMap4h, mapMaxPivots)
if mapDEnabled and not na(mapDHigh) and mapDTimeChg != 0
    ZZResult rMapD = zMapD.step(mapDHigh, mapDLow, useATR ? mapDAtr * atrMult : mapDClose * pctRev / 100.0)
    rememberContextPivot(mapDBars, mapDPrices, rMapD, mapMaxPivots)
if mapWEnabled and not na(mapWHigh) and mapWTimeChg != 0
    ZZResult rMapW = zMapW.step(mapWHigh, mapWLow, useATR ? mapWAtr * atrMult : mapWClose * pctRev / 100.0)
    rememberContextPivot(mapWBars, mapWPrices, rMapW, mapMaxPivots)
if mapMEnabled and not na(mapMHigh) and mapMTimeChg != 0
    ZZResult rMapM = zMapM.step(mapMHigh, mapMLow, useATR ? mapMAtr * atrMult : mapMClose * pctRev / 100.0)
    rememberContextPivot(mapMBars, mapMPrices, rMapM, mapMaxPivots)

string mtfContextStack = ""
mtfContextStack := appendContextText(mtfContextStack, contextWaveText(map1hEnabled, "1H", zMap1h.count, zMap1h.dir))
mtfContextStack := appendContextText(mtfContextStack, contextWaveText(map4hEnabled, "4H", zMap4h.count, zMap4h.dir))
mtfContextStack := appendContextText(mtfContextStack, contextWaveText(mapDEnabled, "1D", zMapD.count, zMapD.dir))
mtfContextStack := appendContextText(mtfContextStack, contextWaveText(mapWEnabled, "1W", zMapW.count, zMapW.dir))
mtfContextStack := appendContextText(mtfContextStack, contextWaveText(mapMEnabled, "1M", zMapM.count, zMapM.dir))

if barstate.islast
    drawHtfWaveMap("1H", map1hEnabled, map1hBars, map1hPrices, zMap1h.dir, zMap1h.count, zMap1h.pivotBar, zMap1h.pivotPrice, map1hClose, map1hAtr, colMap1h, 0, 0.40, map1hLines, map1hLabels)
    drawHtfWaveMap("4H", map4hEnabled, map4hBars, map4hPrices, zMap4h.dir, zMap4h.count, zMap4h.pivotBar, zMap4h.pivotPrice, map4hClose, map4hAtr, colMap4h, 2, 0.80, map4hLines, map4hLabels)
    drawHtfWaveMap("1D", mapDEnabled, mapDBars, mapDPrices, zMapD.dir, zMapD.count, zMapD.pivotBar, zMapD.pivotPrice, mapDClose, mapDAtr, colMapD, 4, 1.20, mapDLines, mapDLabels)
    drawHtfWaveMap("1W", mapWEnabled, mapWBars, mapWPrices, zMapW.dir, zMapW.count, zMapW.pivotBar, zMapW.pivotPrice, mapWClose, mapWAtr, colMapW, 6, 1.60, mapWLines, mapWLabels)
    drawHtfWaveMap("1M", mapMEnabled, mapMBars, mapMPrices, zMapM.dir, zMapM.count, zMapM.pivotBar, zMapM.pivotPrice, mapMClose, mapMAtr, colMapM, 8, 2.00, mapMLines, mapMLabels)

bool chartIsStock = syminfo.type == "stock"
bool chartIsCrypto = syminfo.type == "crypto"
bool marketModeAllowsChart = marketMode == "Research any" or (marketMode == "Stocks" and chartIsStock) or (marketMode == "Crypto" and chartIsCrypto) or (marketMode == "Auto" and (chartIsStock or chartIsCrypto))
bool cryptoModeAllowed = chartIsCrypto and (marketMode == "Crypto" or marketMode == "Auto" or marketMode == "Research any")
bool actionableCryptoSymbol = cryptoModeAllowed and enableCryptoActions
bool cryptoResearchMarket = cryptoModeAllowed and not enableCryptoActions
bool actionableTradeSymbol = (chartIsStock and (marketMode == "Stocks" or marketMode == "Auto" or marketMode == "Research any")) or actionableCryptoSymbol
string marketModel = chartIsStock and actionableTradeSymbol ? "stocks-v0" : actionableCryptoSymbol ? "crypto-v0" : cryptoResearchMarket ? "crypto-v0 research" : "unsupported"
string assetClassLabel = chartIsStock ? "STOCK" : chartIsCrypto ? "CRYPTO" : syminfo.type
string canTradeLabel = chartIsStock and actionableTradeSymbol ? "YES - STOCK MODEL" : actionableCryptoSymbol ? "YES - CRYPTO MODEL" : cryptoResearchMarket ? "NO - CRYPTO RESEARCH" : "NO - UNSUPPORTED"

// ───────────────────── LIVE STRUCTURE HYPOTHESIS ─────────────────────
// Forward-looking слой: последняя точка = текущий close, поэтому метки заканчиваются на C?/Y?/5?/e?.
int hybN = array.size(hybBar)
float hypAtr = ta.atr(atrLen)
float hypEmaFast = ta.ema(close, 34)
float hypEmaSlow = ta.ema(close, 89)
float hypRsi = ta.rsi(close, 14)
float hypVolAvg = ta.sma(volume, 20)
float hypVol = na(volume) ? 0.0 : volume
float hypTfScore = tfFocusScore()

string liveHypothesisName = "No live hypothesis"
string liveHypothesisState = "WAIT"
string liveHypothesisReason = "Need more confirmed pivots"
string liveHypothesisLevels = "—"
string liveHypothesisSource = "book+price"
string liveHypothesisLabels = ""
float liveHypothesisProb = na
float liveHypothesisRR = na
float liveHypothesisEntry = na
float liveHypothesisTp1 = na
float liveHypothesisTp2 = na
float liveHypothesisTp3 = na
float liveHypothesisInvalid = na
int liveHypothesisTradeDir = 0
int liveHypothesisMoveDir = 0
int liveHypothesisWaveCount = 0
int liveHypWaveBar0 = na
int liveHypWaveBar1 = na
int liveHypWaveBar2 = na
int liveHypWaveBar3 = na
int liveHypWaveBar4 = na
int liveHypWaveBar5 = na
float liveHypWavePx0 = na
float liveHypWavePx1 = na
float liveHypWavePx2 = na
float liveHypWavePx3 = na
float liveHypWavePx4 = na
float liveHypWavePx5 = na
bool liveHypothesisReady = false
float bestHypRank = -1.0
string hypSideForStats = "LONG"

if showLiveHypothesis and hybN >= 3
    int h3 = hybN - 3
    int b0h = array.get(hybBar, h3)
    int b1h = array.get(hybBar, h3 + 1)
    int b2h = array.get(hybBar, h3 + 2)
    float p0h = array.get(hybPx, h3)
    float p1h = array.get(hybPx, h3 + 1)
    float p2h = array.get(hybPx, h3 + 2)
    float aLenH = math.abs(p1h - p0h)
    float bLenH = math.abs(p2h - p1h)
    int cDirH = p1h > p0h ? 1 : -1
    int fadeDirH = -cDirH
    float cMoveH = cDirH > 0 ? close - p2h : p2h - close
    float cLenH = math.max(0.0, cMoveH)
    float bRatioH = aLenH > 0 ? bLenH / aLenH : na
    float cRatioH = aLenH > 0 ? cLenH / aLenH : na
    bool cIsDeveloping = aLenH > 0 and cMoveH > (na(hypAtr) ? 0.0 : hypAtr * 0.15)
    float c100H = p2h + cDirH * aLenH
    float c138H = p2h + cDirH * aLenH * 1.382
    float c161H = p2h + cDirH * aLenH * 1.618
    float zoneLoH = math.min(c100H, c138H)
    float zoneHiH = math.max(c100H, c138H)
    float hypBuffer = na(hypAtr) ? aLenH * 0.05 : hypAtr * 0.25
    hypSideForStats := fadeDirH > 0 ? "LONG" : "SHORT"

    bool flatCandidate = cIsDeveloping and not na(bRatioH) and bRatioH >= 0.50 and bRatioH < 1.75
    if flatCandidate
        float flatPatternScore = bRatioH >= 0.618 and bRatioH <= 1.382 ? 1.0 : bRatioH < 1.618 ? 0.80 : 0.55
        float flatFibScore = math.max(fibClusterScore(cRatioH), scoreBand(cRatioH, 0.382, 1.382) * 0.65)
        float flatLocationScore = cRatioH >= 0.85 and cRatioH <= 1.45 ? 1.0 : cRatioH >= 0.382 and cRatioH < 0.85 ? 0.55 : cRatioH > 1.45 and cRatioH <= 1.618 ? 0.45 : 0.15
        bool flatAgainstHtfW3 = htfWave3BiasActive and fadeDirH != htfWave3Dir
        float flatHtfScore = htfWave3BiasActive ? (flatAgainstHtfW3 ? 0.05 : math.max(dirAlignScore(fadeDirH, htfBiasDir), htfWave3Prob / 100.0)) : dirAlignScore(fadeDirH, htfBiasDir)
        float flatMomScore = reversalExhaustionScore(fadeDirH, hypRsi, cRatioH)
        float flatEntry = flatLocationScore >= 0.65 ? close : c100H
        float flatStop = c161H - fadeDirH * hypBuffer
        float flatTp1 = p2h
        float flatTp2 = p2h + fadeDirH * aLenH * 0.618
        float flatTp3 = p2h + fadeDirH * aLenH
        float flatRR = rrFor(fadeDirH, flatEntry, flatStop, flatTp1)
        [flatCalP, flatCalN, flatCalConf, flatCalSrc] = calibratedTradeStats("flat", hypSideForStats, chartIsCrypto)
        float flatRawProb = probFromScores(flatPatternScore, flatFibScore, flatHtfScore, flatMomScore, flatLocationScore, rrScore(flatRR), hypTfScore)
        float flatW3Bonus = htfWave3BiasActive ? (flatAgainstHtfW3 ? -12.0 : 6.0) : 0.0
        float flatProbLive = clampPct(flatRawProb * 0.70 + flatCalP * 0.30 - (flatCalConf == "avoid" ? 10.0 : 0.0) + flatW3Bonus)
        bool flatBlockedByHtf = (htfActionMode == "BLOCK" and fadeDirH * htfBiasDir < 0) or (htfWave3PullbackOnly and flatAgainstHtfW3)
        bool flatReady = flatProbLive >= readyHypothesisProb and flatLocationScore >= 0.65 and not na(flatRR) and flatRR >= minActionRR and not flatBlockedByHtf
        float flatRank = flatProbLive + (flatReady ? 5.0 : 0.0)
        if flatRank > bestHypRank
            bestHypRank := flatRank
            liveHypothesisName := "Dev Flat C"
            liveHypothesisState := flatReady ? "EARLY " + hypSideText(fadeDirH) : "WATCH " + hypSideText(fadeDirH)
            liveHypothesisReason := "B/A " + str.tostring(bRatioH, "#.00") + ", C/A " + str.tostring(cRatioH, "#.00") + ", " + (htfWave3BiasActive ? htfWave3Plan : "HTF " + htfBias)
            liveHypothesisLevels := "Zone " + str.tostring(zoneLoH, format.mintick) + "-" + str.tostring(zoneHiH, format.mintick) + " | SL " + str.tostring(flatStop, format.mintick) + " | TP " + str.tostring(flatTp1, format.mintick)
            liveHypothesisSource := flatCalSrc
            liveHypothesisLabels := "0|A|B|C?"
            liveHypothesisProb := flatProbLive
            liveHypothesisRR := flatRR
            liveHypothesisEntry := flatEntry
            liveHypothesisTp1 := flatTp1
            liveHypothesisTp2 := flatTp2
            liveHypothesisTp3 := flatTp3
            liveHypothesisInvalid := flatStop
            liveHypothesisTradeDir := fadeDirH
            liveHypothesisMoveDir := cDirH
            liveHypothesisWaveCount := 4
            liveHypWaveBar0 := b0h
            liveHypWaveBar1 := b1h
            liveHypWaveBar2 := b2h
            liveHypWaveBar3 := bar_index
            liveHypWavePx0 := p0h
            liveHypWavePx1 := p1h
            liveHypWavePx2 := p2h
            liveHypWavePx3 := close
            liveHypothesisReady := flatReady

    bool dcCandidate = cIsDeveloping and not na(bRatioH) and bRatioH > 0.10 and bRatioH < 0.618
    if dcCandidate
        float dcPatternScore = math.min(scoreBand(bRatioH, 0.10, 0.618), cRatioH >= 0.382 ? 1.0 : 0.55)
        float dcFibScore = math.max(fibClusterScore(cRatioH), scoreBand(cRatioH, 0.618, 1.618) * 0.70)
        float dcLocationScore = cRatioH >= 0.75 and cRatioH <= 1.65 ? 1.0 : cRatioH >= 0.382 ? 0.55 : 0.20
        bool dcAgainstHtfW3 = htfWave3BiasActive and fadeDirH != htfWave3Dir
        float dcHtfScore = htfWave3BiasActive ? (dcAgainstHtfW3 ? 0.05 : math.max(dirAlignScore(fadeDirH, htfBiasDir), htfWave3Prob / 100.0)) : dirAlignScore(fadeDirH, htfBiasDir)
        float dcMomScore = reversalExhaustionScore(fadeDirH, hypRsi, cRatioH)
        float dcEntry = dcLocationScore >= 0.65 ? close : c100H
        float dcStop = c161H - fadeDirH * hypBuffer
        float dcTp1 = p2h
        float dcTp2 = p2h + fadeDirH * aLenH * 0.618
        float dcTp3 = p2h + fadeDirH * aLenH
        float dcRR = rrFor(fadeDirH, dcEntry, dcStop, dcTp1)
        [dcCalP, dcCalN, dcCalConf, dcCalSrc] = calibratedTradeStats("double_corr", hypSideForStats, chartIsCrypto)
        float dcRawProb = probFromScores(dcPatternScore, dcFibScore, dcHtfScore, dcMomScore, dcLocationScore, rrScore(dcRR), hypTfScore)
        float dcW3Bonus = htfWave3BiasActive ? (dcAgainstHtfW3 ? -12.0 : 6.0) : 0.0
        float dcProbLive = clampPct(dcRawProb * 0.65 + dcCalP * 0.35 - (dcCalN < minActionSample and not allowSmallSampleDC ? 5.0 : 0.0) + dcW3Bonus)
        bool dcBlockedByHtf = (htfActionMode == "BLOCK" and fadeDirH * htfBiasDir < 0) or (htfWave3PullbackOnly and dcAgainstHtfW3)
        bool dcReady = dcProbLive >= readyHypothesisProb and dcLocationScore >= 0.65 and not na(dcRR) and dcRR >= minActionRR and not dcBlockedByHtf and (dcCalN >= minActionSample or allowSmallSampleDC)
        float dcRank = dcProbLive + (dcReady ? 5.0 : 0.0)
        if dcRank > bestHypRank
            bestHypRank := dcRank
            liveHypothesisName := "Dev WXY / Zigzag C"
            liveHypothesisState := dcReady ? "EARLY " + hypSideText(fadeDirH) : "WATCH " + hypSideText(fadeDirH)
            liveHypothesisReason := "X/B " + str.tostring(bRatioH, "#.00") + ", Y/C " + str.tostring(cRatioH, "#.00") + ", " + (htfWave3BiasActive ? htfWave3Plan : "HTF " + htfBias)
            liveHypothesisLevels := "Zone " + str.tostring(zoneLoH, format.mintick) + "-" + str.tostring(zoneHiH, format.mintick) + " | SL " + str.tostring(dcStop, format.mintick) + " | TP " + str.tostring(dcTp1, format.mintick)
            liveHypothesisSource := dcCalSrc
            liveHypothesisLabels := "0|W/A|X/B|Y/C?"
            liveHypothesisProb := dcProbLive
            liveHypothesisRR := dcRR
            liveHypothesisEntry := dcEntry
            liveHypothesisTp1 := dcTp1
            liveHypothesisTp2 := dcTp2
            liveHypothesisTp3 := dcTp3
            liveHypothesisInvalid := dcStop
            liveHypothesisTradeDir := fadeDirH
            liveHypothesisMoveDir := cDirH
            liveHypothesisWaveCount := 4
            liveHypWaveBar0 := b0h
            liveHypWaveBar1 := b1h
            liveHypWaveBar2 := b2h
            liveHypWaveBar3 := bar_index
            liveHypWavePx0 := p0h
            liveHypWavePx1 := p1h
            liveHypWavePx2 := p2h
            liveHypWavePx3 := close
            liveHypothesisReady := dcReady

if showLiveHypothesis and hybN >= 5
    int h5 = hybN - 5
    int b0i = array.get(hybBar, h5)
    int b1i = array.get(hybBar, h5 + 1)
    int b2i = array.get(hybBar, h5 + 2)
    int b3i = array.get(hybBar, h5 + 3)
    int b4i = array.get(hybBar, h5 + 4)
    float p0i = array.get(hybPx, h5)
    float p1i = array.get(hybPx, h5 + 1)
    float p2i = array.get(hybPx, h5 + 2)
    float p3i = array.get(hybPx, h5 + 3)
    float p4i = array.get(hybPx, h5 + 4)
    int impDir = p1i > p0i ? 1 : -1
    float w1i = math.abs(p1i - p0i)
    float w2i = math.abs(p2i - p1i)
    float w3i = math.abs(p3i - p2i)
    float w4i = math.abs(p4i - p3i)
    float w5Live = impDir > 0 ? close - p4i : p4i - close
    float w5Ratio = w1i > 0 ? math.max(0.0, w5Live) / w1i : na
    bool impR1 = impDir > 0 ? p2i > p0i : p2i < p0i
    bool impR2 = impDir > 0 ? p4i > p2i : p4i < p2i
    bool impR3 = w3i >= w1i
    bool impR4 = w1i > 0 ? w2i / w1i <= 0.786 : false
    bool impActive = w5Live > (na(hypAtr) ? 0.0 : hypAtr * 0.15)
    float impPatternScore = (impR1 ? 0.22 : 0.0) + (impR2 ? 0.20 : 0.0) + (impR3 ? 0.24 : 0.0) + (impR4 ? 0.16 : 0.0) + (impActive ? 0.18 : 0.0)
    if impPatternScore >= 0.62 and impActive
        float impFibScore = math.max(scoreNear(w5Ratio, 0.618, 0.25), math.max(scoreNear(w5Ratio, 1.000, 0.25), scoreNear(w5Ratio, 1.618, 0.20)))
        float impLocationScore = w5Ratio <= 1.618 ? scoreBand(w5Ratio, 0.15, 1.30) : 0.25
        bool impAgainstHtfW3 = htfWave3BiasActive and impDir != htfWave3Dir
        float impHtfScore = htfWave3BiasActive ? (impAgainstHtfW3 ? 0.05 : math.max(dirAlignScore(impDir, htfBiasDir), htfWave3Prob / 100.0)) : dirAlignScore(impDir, htfBiasDir)
        float impMomScore = followMomentumScore(impDir, close, hypEmaFast, hypEmaSlow, hypRsi, hypVol, hypVolAvg)
        float impEntry = close
        float impStop = p4i - impDir * (na(hypAtr) ? w1i * 0.05 : hypAtr * 0.25)
        float impTp1 = p4i + impDir * w1i
        float impTp2 = p4i + impDir * w1i * 1.618
        float impTp3 = p4i + impDir * math.min(w1i + w3i, w3i * 1.618)
        float impRR = rrFor(impDir, impEntry, impStop, impTp1)
        float impW3Bonus = htfWave3BiasActive ? (impAgainstHtfW3 ? -12.0 : 5.0) : 0.0
        float impProbLive = clampPct(probFromScores(impPatternScore, impFibScore, impHtfScore, impMomScore, impLocationScore, rrScore(impRR), hypTfScore) + impW3Bonus)
        bool impBlockedByHtf = (htfActionMode == "BLOCK" and impDir * htfBiasDir < 0) or (htfWave3PullbackOnly and impAgainstHtfW3)
        bool impReady = impProbLive >= readyHypothesisProb and not na(impRR) and impRR >= minActionRR and not impBlockedByHtf
        float impRank = impProbLive + (impReady ? 5.0 : 0.0)
        if impRank > bestHypRank
            bestHypRank := impRank
            liveHypothesisName := "Dev Impulse W5"
            liveHypothesisState := impReady ? "EARLY " + hypSideText(impDir) : "WATCH " + hypSideText(impDir)
            liveHypothesisReason := "W5/W1 " + str.tostring(w5Ratio, "#.00") + ", momentum " + hypDirText(impDir) + ", " + (htfWave3BiasActive ? htfWave3Plan : "HTF " + htfBias)
            liveHypothesisLevels := "Entry " + str.tostring(impEntry, format.mintick) + " | SL " + str.tostring(impStop, format.mintick) + " | TP " + str.tostring(impTp1, format.mintick)
            liveHypothesisSource := "book|impulse-w5"
            liveHypothesisLabels := "0|1|2|3|4|5?"
            liveHypothesisProb := impProbLive
            liveHypothesisRR := impRR
            liveHypothesisEntry := impEntry
            liveHypothesisTp1 := impTp1
            liveHypothesisTp2 := impTp2
            liveHypothesisTp3 := impTp3
            liveHypothesisInvalid := impStop
            liveHypothesisTradeDir := impDir
            liveHypothesisMoveDir := impDir
            liveHypothesisWaveCount := 6
            liveHypWaveBar0 := b0i
            liveHypWaveBar1 := b1i
            liveHypWaveBar2 := b2i
            liveHypWaveBar3 := b3i
            liveHypWaveBar4 := b4i
            liveHypWaveBar5 := bar_index
            liveHypWavePx0 := p0i
            liveHypWavePx1 := p1i
            liveHypWavePx2 := p2i
            liveHypWavePx3 := p3i
            liveHypWavePx4 := p4i
            liveHypWavePx5 := close
            liveHypothesisReady := impReady

    float triE = math.abs(close - p4i)
    int triEDir = close > p4i ? 1 : -1
    int triThrustDir = -triEDir
    float triRangeLo = math.min(p0i, math.min(p1i, math.min(p2i, math.min(p3i, p4i))))
    float triRangeHi = math.max(p0i, math.max(p1i, math.max(p2i, math.max(p3i, p4i))))
    bool triContracting = w3i < w1i and w4i < w2i
    bool triInside = close >= triRangeLo and close <= triRangeHi
    float triWidest = math.max(w1i, math.max(w2i, math.max(w3i, w4i)))
    float triERatio = w3i > 0 ? triE / w3i : na
    if triContracting and triInside and triE > (na(hypAtr) ? 0.0 : hypAtr * 0.10)
        float triPatternScore = 0.85
        float triFibScore = math.max(fibClusterScore(triERatio), fibClusterScore(w3i / math.max(w1i, 0.0000001)) * 0.50)
        bool triAgainstHtfW3 = htfWave3BiasActive and triThrustDir != htfWave3Dir
        float triHtfScore = htfWave3BiasActive ? (triAgainstHtfW3 ? 0.05 : math.max(dirAlignScore(triThrustDir, htfBiasDir), htfWave3Prob / 100.0)) : dirAlignScore(triThrustDir, htfBiasDir)
        float triMomScore = followMomentumScore(triThrustDir, close, hypEmaFast, hypEmaSlow, hypRsi, hypVol, hypVolAvg) * 0.70
        float triEntry = close
        float triStop = close - triThrustDir * triWidest * 0.382
        float triTp1 = close + triThrustDir * triWidest
        float triTp2 = close + triThrustDir * triWidest * 1.618
        float triRR = rrFor(triThrustDir, triEntry, triStop, triTp1)
        float triW3Bonus = htfWave3BiasActive ? (triAgainstHtfW3 ? -12.0 : 5.0) : 0.0
        float triProbLive = clampPct(probFromScores(triPatternScore, triFibScore, triHtfScore, triMomScore, 0.55, rrScore(triRR), hypTfScore) + triW3Bonus)
        bool triBlockedByHtf = (htfActionMode == "BLOCK" and triThrustDir * htfBiasDir < 0) or (htfWave3PullbackOnly and triAgainstHtfW3)
        bool triReady = false
        float triRank = triProbLive + (triReady ? 5.0 : 0.0)
        if triRank > bestHypRank
            bestHypRank := triRank
            liveHypothesisName := "Dev Triangle e"
            liveHypothesisState := "WATCH " + hypSideText(triThrustDir)
            liveHypothesisReason := "e forming; wait B-D break, " + (htfWave3BiasActive ? htfWave3Plan : "HTF " + htfBias)
            liveHypothesisLevels := "Breakout watch | Invalid " + str.tostring(triStop, format.mintick) + " | TP " + str.tostring(triTp1, format.mintick)
            liveHypothesisSource := "book|triangle-thrust"
            liveHypothesisLabels := "0|a|b|c|d|e?"
            liveHypothesisProb := triProbLive
            liveHypothesisRR := triRR
            liveHypothesisEntry := triEntry
            liveHypothesisTp1 := triTp1
            liveHypothesisTp2 := triTp2
            liveHypothesisTp3 := na
            liveHypothesisInvalid := triStop
            liveHypothesisTradeDir := triThrustDir
            liveHypothesisMoveDir := triEDir
            liveHypothesisWaveCount := 6
            liveHypWaveBar0 := b0i
            liveHypWaveBar1 := b1i
            liveHypWaveBar2 := b2i
            liveHypWaveBar3 := b3i
            liveHypWaveBar4 := b4i
            liveHypWaveBar5 := bar_index
            liveHypWavePx0 := p0i
            liveHypWavePx1 := p1i
            liveHypWavePx2 := p2i
            liveHypWavePx3 := p3i
            liveHypWavePx4 := p4i
            liveHypWavePx5 := close
            liveHypothesisReady := triReady

bool hasLiveHypothesis = showLiveHypothesis and not na(liveHypothesisProb) and liveHypothesisProb >= minHypothesisProb and liveHypothesisTradeDir != 0
string liveHypothesisGrade = hasLiveHypothesis ? hypothesisGrade(liveHypothesisProb, liveHypothesisRR, liveHypothesisReady) : "WAIT"
string liveHypothesisDisplay = hasLiveHypothesis ? liveHypothesisName + " | " + liveHypothesisState : "No live setup"
string liveHypothesisProbabilityText = hasLiveHypothesis ? "Hyp P " + str.tostring(liveHypothesisProb, "#.0") + "% | " + liveHypothesisGrade : "—"
string liveHypothesisTfText = preferLongTermTF ? "Primary 1D/4H; current " + timeframe.period + " | HTF " + htf : timeframe.period + " entry | HTF " + htf

string actionNow = "WAIT"
string actionReason = "NO SIGNAL"
float actionRR = na
float actionProgress = na
bool htfAgainstAction = false

if not marketModeAllowsChart
    actionReason := "UNSUPPORTED " + syminfo.type
else if cryptoResearchMarket
    actionReason := "CRYPTO ACTION DISABLED"
else if not actionableTradeSymbol
    actionReason := "NO " + syminfo.type + " CALIBRATION"
else if lastTradeSide != "LONG" and lastTradeSide != "SHORT"
    actionReason := "NO SIGNAL"
else if lastTradeStatus != "ACTIVE"
    actionReason := lastTradeStatus
else if na(lastTradeEntry) or na(lastTradeTp) or na(lastTradeSl)
    actionReason := "INCOMPLETE"
else
    int actionAge = na(lastTradeAge) and not na(lastTradeConfBar) ? bar_index - lastTradeConfBar : lastTradeAge
    bool actionLong = lastTradeSide == "LONG"
    htfAgainstAction := htfActionMode != "OFF" and ((actionLong and htfBiasDir < 0) or (not actionLong and htfBiasDir > 0))
    float rewardNow = actionLong ? lastTradeTp - close : close - lastTradeTp
    float riskNow = actionLong ? close - lastTradeSl : lastTradeSl - close
    float pathToTp = math.abs(lastTradeTp - lastTradeEntry)
    float movedToTp = actionLong ? close - lastTradeEntry : lastTradeEntry - close
    actionProgress := pathToTp > 0 ? movedToTp / pathToTp : na
    actionRR := riskNow > 0 ? rewardNow / riskNow : na
    bool smallSampleBlocked = lastTradeSampleN < minActionSample and not (allowSmallSampleDC and lastTradeType == "DoubleCorr fade")
    if actionAge > actionFreshBars
        actionReason := "STALE " + str.tostring(actionAge) + "b"
    else if rewardNow <= 0
        actionReason := "TP PASSED"
    else if riskNow <= 0
        actionReason := "SL ZONE"
    else if not na(actionProgress) and actionProgress > maxEntryProgress
        actionReason := "LATE " + str.tostring(actionProgress * 100, "#") + "%"
    else if not na(actionRR) and actionRR < minActionRR
        actionReason := "RR BAD " + str.tostring(actionRR, "#.00")
    else if not na(lastTradeProb) and lastTradeProb < minActionProb
        actionReason := "PROB LOW " + str.tostring(lastTradeProb, "#.0") + "%"
    else if lastTradeConfidence == "avoid"
        actionReason := "NO EDGE " + lastTradeProbSource
    else if smallSampleBlocked
        actionReason := "SMALL N " + str.tostring(lastTradeSampleN) + "<" + str.tostring(minActionSample)
    else if htfWave3PullbackOnly and htfWave3BiasActive and (actionLong ? 1 : -1) != htfWave3Dir
        actionReason := "HTF W3 ONLY " + hypSideText(htfWave3Dir)
    else if htfActionMode == "BLOCK" and actionLong and htfBiasDir < 0
        actionReason := "HTF AGAINST " + htfBias
    else if htfActionMode == "BLOCK" and not actionLong and htfBiasDir > 0
        actionReason := "HTF AGAINST " + htfBias
    else
        actionNow := actionLong ? "BUY" : "SELL"
        actionReason := htfAgainstAction and htfActionMode == "WARN" ? "FRESH + RR OK / HTF WARN " + htfBias : "FRESH + RR OK"

bool actionBuySignal = actionableTradeSymbol and actionNow == "BUY" and tradeLongSignal
bool actionSellSignal = actionableTradeSymbol and actionNow == "SELL" and tradeShortSignal
bool liveHypothesisReadySignal = hasLiveHypothesis and liveHypothesisReady
bool liveHypothesisWasReady = bar_index > 0 ? liveHypothesisReadySignal[1] : false
bool liveHypothesisReadyEvent = liveHypothesisReadySignal and not liveHypothesisWasReady
string signalGradeNow = signalGrade(actionNow, lastTradeProb, lastTradeSampleN, lastTradeConfidence, actionRR)
if actionNow != "WAIT" and htfAgainstAction and htfActionMode == "WARN"
    signalGradeNow := signalGradeNow == "A" ? "B-HTF" : signalGradeNow == "B" ? "C-HTF" : signalGradeNow + "-HTF"

string decisionMode = chartIsStock and actionableTradeSymbol ? "STOCK LIVE" : actionableCryptoSymbol ? "CRYPTO LIVE" : cryptoResearchMarket ? "CRYPTO RESEARCH" : "UNSUPPORTED"
color decisionModeColor = actionableTradeSymbol ? color.new(color.lime, 50) : cryptoResearchMarket ? color.new(color.orange, 20) : color.new(color.red, 45)
string marketBannerText = chartIsStock and actionableTradeSymbol ? "STOCK LIVE\nBUY/SELL ENABLED" : actionableCryptoSymbol ? "CRYPTO LIVE\nBUY/SELL ENABLED" : cryptoResearchMarket ? "CRYPTO RESEARCH\nACTIONS DISABLED" : "UNSUPPORTED MARKET\nWAIT ONLY"
color marketBannerColor = actionableTradeSymbol ? color.new(color.lime, 10) : cryptoResearchMarket ? color.new(color.orange, 10) : color.new(color.red, 20)
string displayTradeSide = actionableTradeSymbol ? lastTradeSide : "WAIT"
string displayTradeType = actionableTradeSymbol ? lastTradeType : marketModel
string displayTradeStatus = actionableTradeSymbol ? lastTradeStatus : "WAIT"
string displayTradeProb = actionableTradeSymbol and not na(lastTradeProb) ? str.tostring(lastTradeProb, "#.0") + "%" : "—"
string displaySampleConf = actionableTradeSymbol ? str.tostring(lastTradeSampleN) + " / " + lastTradeConfidence : "—"
string displayEntryTp = actionableTradeSymbol and not na(lastTradeEntry) ? str.tostring(lastTradeEntry, format.mintick) + " / " + str.tostring(lastTradeTp, format.mintick) : "—"
string displaySl = actionableTradeSymbol and not na(lastTradeSl) ? str.tostring(lastTradeSl, format.mintick) : "—"
string displaySignalGrade = actionableTradeSymbol ? signalGradeNow : cryptoResearchMarket ? "RESEARCH" : "—"
string displayRrProgress = actionableTradeSymbol ? (na(actionRR) ? "—" : str.tostring(actionRR, "#.00")) + " / " + (na(actionProgress) ? "—" : str.tostring(actionProgress * 100, "#") + "%") : "—"
string displayMarket = marketMode + " / " + marketModel
string displayCalibration = actionableTradeSymbol ? lastTradeProbSource : marketModel
string displayCoreSignal = showCoreSignals ? lastCoreSignal : "OFF"
string displayHtfWave3 = htfWave3BiasActive ? htfWave3Name + " | P " + str.tostring(htfWave3Prob, "#.0") + "%" : "No HTF W3 bias"
string displayHtfWave3Levels = htfWave3BiasActive ? "Invalid " + str.tostring(htfWave3Invalid, format.mintick) + " | TP1 " + str.tostring(htfWave3Target1, format.mintick) : "—"
string displayHtfWave3Prob = htfWave3BiasActive ? "HTF W3 P " + str.tostring(htfWave3Prob, "#.0") + "%" : "—"
string displayConfirmedPattern = displayTradeType != "—" and displayTradeType != marketModel ? displayTradeType : displayCoreSignal != "—" and displayCoreSignal != "OFF" ? displayCoreSignal : "No confirmed pattern"
string displayPatternNow = hasLiveHypothesis ? liveHypothesisDisplay : htfWave3BiasActive ? displayHtfWave3 : displayConfirmedPattern
bool shouldExitPosition = lastTradeStatus == "TP HIT" or lastTradeStatus == "SL HIT" or actionReason == "TP PASSED" or actionReason == "SL ZONE"
bool actionWaitNoEntry = actionNow == "WAIT" and waitNoEntryReason(actionReason)
bool shouldHoldPosition = lastTradeStatus == "ACTIVE" and actionNow == "WAIT" and not shouldExitPosition and not actionWaitNoEntry
bool useLiveHypothesisDecision = hasLiveHypothesis and actionNow == "WAIT" and not shouldExitPosition and not shouldHoldPosition
bool useHtfWave3WaitDecision = htfWave3BiasActive and actionNow == "WAIT" and not shouldExitPosition and not shouldHoldPosition and not useLiveHypothesisDecision
bool liveAgainstHtfWave3 = useLiveHypothesisDecision and htfWave3BiasActive and liveHypothesisTradeDir != htfWave3Dir
string antonDecision = actionNow == "BUY" ? "ENTER LONG" : actionNow == "SELL" ? "ENTER SHORT" : shouldExitPosition ? "EXIT" : shouldHoldPosition ? "HOLD / MANAGE" : liveAgainstHtfWave3 and htfWave3PullbackOnly ? "WAIT / NO COUNTER" : useLiveHypothesisDecision and liveHypothesisReady ? "EARLY " + hypSideText(liveHypothesisTradeDir) : useLiveHypothesisDecision ? "WATCH " + hypSideText(liveHypothesisTradeDir) : useHtfWave3WaitDecision ? "WAIT PULLBACK " + hypSideText(htfWave3Dir) : "WAIT / NO ENTRY"
string antonRule = actionNow == "BUY" or actionNow == "SELL" ? "Enter near Entry; risk only to SL" : shouldExitPosition ? actionReason : shouldHoldPosition ? "Do not add; trail or wait" : liveAgainstHtfWave3 and htfWave3PullbackOnly ? "Countertrend blocked by HTF W3" : useLiveHypothesisDecision and liveHypothesisReady ? (htfWave3BiasActive ? "HTF W3 aligned; early setup in zone" : "Early setup in zone; invalid = SL") : useLiveHypothesisDecision ? (htfWave3BiasActive ? "Wait LTF pullback trigger with HTF W3" : "Wait for zone/breakout; no chase") : useHtfWave3WaitDecision ? "HTF W3 active; wait LTF ABC/Flat/WXY pullback" : actionReason
string displayLevels = liveAgainstHtfWave3 and htfWave3PullbackOnly ? displayHtfWave3Levels : useLiveHypothesisDecision ? liveHypothesisLevels : useHtfWave3WaitDecision ? displayHtfWave3Levels : actionableTradeSymbol and not na(lastTradeEntry) ? "E " + str.tostring(lastTradeEntry, format.mintick) + " | SL " + str.tostring(lastTradeSl, format.mintick) + " | TP " + str.tostring(lastTradeTp, format.mintick) : "—"
string displayProbabilityState = shouldExitPosition ? "EXIT" : shouldHoldPosition ? "MANAGE" : displaySignalGrade
string displayProbabilityMove = liveAgainstHtfWave3 and htfWave3PullbackOnly ? displayHtfWave3Prob : useLiveHypothesisDecision ? liveHypothesisProbabilityText : useHtfWave3WaitDecision ? displayHtfWave3Prob : actionableTradeSymbol and not na(lastTradeProb) ? "P " + str.tostring(lastTradeProb, "#.0") + "% | " + displayProbabilityState : cryptoResearchMarket ? "research only" : "—"
string tfPlanBase = htfWave3BiasActive ? htfWave3Plan : useLiveHypothesisDecision ? liveHypothesisTfText : timeframe.period + " entry | HTF " + htf + " filter"
string tfPlanText = mtfContextStack == "" ? tfPlanBase : tfPlanBase + " | Map " + mtfContextStack
string tfPlanShortBase = htfWave3BiasActive ? "W3 " + hypSideText(htfWave3Dir) : useLiveHypothesisDecision ? liveHypothesisState : timeframe.period + " entry"
string tfPlanShort = mtfContextStack == "" ? tfPlanShortBase : tfPlanShortBase + " | " + mtfContextStack
string displayLiveContextLevels = hasLiveHypothesis ? liveHypothesisLevels : htfWave3BiasActive ? displayHtfWave3Levels : "—"
string activeHtfDisplay = mtfContextStack == "" ? activeHInfo : activeHInfo + " | Map " + mtfContextStack

// ───────────────────── ТЕКУЩИЙ ТОРГОВЫЙ ПЛАН ─────────────────────
var int drawnActionKey = na
var int drawnCoreKey = na
var line actionEntryLine = na
var line actionSlLine = na
var line actionTp1Line = na
var line actionTp2Line = na
var line actionTp3Line = na
var line coreTargetLine = na
var line coreInvalidLine = na
var label actionMainLabel = na
var label actionEntryLabel = na
var label actionSlLabel = na
var label actionTp1Label = na
var label actionTp2Label = na
var label actionTp3Label = na
var label coreMainLabel = na
var label coreTargetLabel = na
var label coreInvalidLabel = na
var label coreWaveLabel0 = na
var label coreWaveLabel1 = na
var label coreWaveLabel2 = na
var label coreWaveLabel3 = na
var label coreWaveLabel4 = na
var label coreWaveLabel5 = na
var line hypEntryLine = na
var line hypStopLine = na
var line hypTp1Line = na
var line hypTp2Line = na
var label hypMainLabel = na
var label hypEntryLabel = na
var label hypStopLabel = na
var label hypTp1Label = na
var label hypTp2Label = na
var label hypWaveLabel0 = na
var label hypWaveLabel1 = na
var label hypWaveLabel2 = na
var label hypWaveLabel3 = na
var label hypWaveLabel4 = na
var label hypWaveLabel5 = na
var line htfW3InvalidLine = na
var line htfW3Target1Line = na
var line htfW3Target2Line = na
var label htfW3MainLabel = na
var label htfW3InvalidLabel = na
var label htfW3Target1Label = na
var label htfW3Target2Label = na
var box actionWaveBox = na
var line actionWaveLine1 = na
var line actionWaveLine2 = na
var line actionWaveLine3 = na
var label actionWaveLabel0 = na
var label actionWaveLabel1 = na
var label actionWaveLabel2 = na
var label actionWaveLabel3 = na
var label marketBannerLabel = na
var array<line> historicalPlanLines = array.new<line>()
var array<label> historicalPlanLabels = array.new<label>()
var array<box> historicalPlanBoxes = array.new<box>()

bool canDrawActionPlan = showTradePlan and actionableTradeSymbol and (lastTradeSide == "LONG" or lastTradeSide == "SHORT") and not na(lastTradeConfBar) and not na(lastTradeEntry) and not na(lastTradeSl) and not na(lastTradeAmp) and lastTradeAmp > 0
bool canDrawWaitNote = showTradePlan and not canDrawActionPlan and actionNow == "WAIT" and actionableTradeSymbol and lastTradeSide != "—" and actionReason != "NO SIGNAL" and not na(lastTradeConfBar) and not na(lastTradeEntry)
if barstate.islast
    if not na(marketBannerLabel)
        label.delete(marketBannerLabel)
    if showMarketBanner and showTradePanel
        float bannerY = high + ta.atr(atrLen) * 2.0
        marketBannerLabel := label.new(bar_index + 2, bannerY, marketBannerText,
             xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
             color = marketBannerColor, textcolor = color.white, size = size.normal,
             tooltip = chartIsStock and actionableTradeSymbol ? "Акции: рабочая stock-калибровка. BUY/SELL и alerts разрешены фильтрами Action now." :
                  actionableCryptoSymbol ? "Крипта: рабочая crypto-v0 калибровка. BUY/SELL и alerts разрешены фильтрами Action now." :
                  cryptoResearchMarket ? "Крипта: research-контур. Включите Enable crypto Action BUY/SELL для рабочих crypto-сигналов." :
                  "Этот тип рынка не поддержан текущей калибровкой. Action now всегда WAIT.")
    else
        marketBannerLabel := na
bool canDrawAnyAction = canDrawActionPlan or canDrawWaitNote
int actionStateKey = actionNow == "BUY" ? 1 : actionNow == "SELL" ? 2 : shouldExitPosition ? 4 : shouldHoldPosition ? 5 : 3
int actionKey = canDrawActionPlan ? lastTradeConfBar * 10 + actionStateKey : canDrawWaitNote ? lastTradeConfBar * 10 + 3 : na
bool redrawActionPlan = barstate.islast and (actionKey != drawnActionKey)
if redrawActionPlan
    bool deletePreviousPlan = onlyLatestSignal or not canDrawAnyAction
    if deletePreviousPlan
        if not na(actionEntryLine)
            line.delete(actionEntryLine)
        if not na(actionSlLine)
            line.delete(actionSlLine)
        if not na(actionTp1Line)
            line.delete(actionTp1Line)
        if not na(actionTp2Line)
            line.delete(actionTp2Line)
        if not na(actionTp3Line)
            line.delete(actionTp3Line)
        if not na(actionMainLabel)
            label.delete(actionMainLabel)
        if not na(actionEntryLabel)
            label.delete(actionEntryLabel)
        if not na(actionSlLabel)
            label.delete(actionSlLabel)
        if not na(actionTp1Label)
            label.delete(actionTp1Label)
        if not na(actionTp2Label)
            label.delete(actionTp2Label)
        if not na(actionTp3Label)
            label.delete(actionTp3Label)
        if not na(actionWaveBox)
            box.delete(actionWaveBox)
        if not na(actionWaveLine1)
            line.delete(actionWaveLine1)
        if not na(actionWaveLine2)
            line.delete(actionWaveLine2)
        if not na(actionWaveLine3)
            line.delete(actionWaveLine3)
        if not na(actionWaveLabel0)
            label.delete(actionWaveLabel0)
        if not na(actionWaveLabel1)
            label.delete(actionWaveLabel1)
        if not na(actionWaveLabel2)
            label.delete(actionWaveLabel2)
        if not na(actionWaveLabel3)
            label.delete(actionWaveLabel3)

    actionEntryLine := na
    actionSlLine := na
    actionTp1Line := na
    actionTp2Line := na
    actionTp3Line := na
    actionMainLabel := na
    actionEntryLabel := na
    actionSlLabel := na
    actionTp1Label := na
    actionTp2Label := na
    actionTp3Label := na
    actionWaveBox := na
    actionWaveLine1 := na
    actionWaveLine2 := na
    actionWaveLine3 := na
    actionWaveLabel0 := na
    actionWaveLabel1 := na
    actionWaveLabel2 := na
    actionWaveLabel3 := na
    drawnActionKey := actionKey

    if canDrawActionPlan
        bool actionLongPlan = lastTradeSide == "LONG"
        int planDir = actionLongPlan ? 1 : -1
        int x0Plan = lastTradeConfBar
        int x1Plan = lastTradeConfBar + actionLevelBars
        color planColor = actionLongPlan ? color.lime : color.red
        float tp1 = lastTradeEntry + planDir * lastTradeAmp * 0.618
        float tp2 = lastTradeEntry + planDir * lastTradeAmp
        float tp3 = lastTradeEntry + planDir * lastTradeAmp * 1.618
        float tp1Prob = tpProbability(lastTradeProb, 13.0)
        float tp2Prob = tpProbability(lastTradeProb, 0.0)
        float tp3Prob = tpProbability(lastTradeProb, -17.0)
        string actionIcon = actionNow == "BUY" ? "▲ BUY" : actionNow == "SELL" ? "▼ SELL" : shouldExitPosition ? "EXIT" : shouldHoldPosition ? "HOLD" : "WAIT"
        string waveLabels = lastTradeType == "DoubleCorr fade" ? "0|W|X|Y" : "0|A|B|C"
        array<string> wlbl = str.split(waveLabels, "|")

        actionEntryLine := line.new(x0Plan, lastTradeEntry, x1Plan, lastTradeEntry,
             xloc = xloc.bar_index, color = color.new(color.white, 10), width = 2, style = line.style_solid)
        actionSlLine := line.new(x0Plan, lastTradeSl, x1Plan, lastTradeSl,
             xloc = xloc.bar_index, color = color.new(color.red, 0), width = 2, style = line.style_solid)
        actionTp1Line := line.new(x0Plan, tp1, x1Plan, tp1,
             xloc = xloc.bar_index, color = color.new(color.lime, 35), width = 1, style = line.style_dotted)
        actionTp2Line := line.new(x0Plan, tp2, x1Plan, tp2,
             xloc = xloc.bar_index, color = color.new(color.lime, 15), width = 2, style = line.style_dashed)
        actionTp3Line := line.new(x0Plan, tp3, x1Plan, tp3,
             xloc = xloc.bar_index, color = color.new(color.aqua, 10), width = 2, style = line.style_dotted)

        actionMainLabel := label.new(x0Plan, lastTradeEntry, actionIcon + "\n" + lastTradeType + "\nP≈" + str.tostring(lastTradeProb, "#.0") + "% / " + displayProbabilityState,
             xloc = xloc.bar_index, yloc = yloc.price,
             style = actionLongPlan ? label.style_label_up : label.style_label_down,
             color = color.new(planColor, 0), textcolor = color.white, size = size.normal,
             tooltip = "Last plan: Entry/SL/MOVE levels remain visible while the trade is ENTER, HOLD or EXIT.")
        actionEntryLabel := label.new(x1Plan, lastTradeEntry, "Entry",
             xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
             color = color.new(color.white, 15), textcolor = color.black, size = size.tiny)
        actionSlLabel := label.new(x1Plan, lastTradeSl, "Stop Loss",
             xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
             color = color.new(color.red, 0), textcolor = color.white, size = size.tiny)
        actionTp1Label := label.new(x1Plan, tp1, tpText("MOVE 0.618", tp1Prob),
             xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
             color = color.new(color.lime, 35), textcolor = color.white, size = size.tiny)
        actionTp2Label := label.new(x1Plan, tp2, tpText("MOVE 1.000", tp2Prob),
             xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
             color = color.new(color.lime, 10), textcolor = color.white, size = size.tiny)
        actionTp3Label := label.new(x1Plan, tp3, tpText("MOVE 1.618", tp3Prob),
             xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
             color = color.new(color.aqua, 10), textcolor = color.white, size = size.tiny)

        if showActionWave and not na(lastTradeWaveBar0) and not na(lastTradeWaveBar3)
            actionWaveBox := box.new(lastTradeB0, lastTradeHi, lastTradeB1, lastTradeLo,
                 xloc = xloc.bar_index, border_color = color.new(planColor, 15),
                 border_width = 1, bgcolor = color.new(planColor, 92))
            actionWaveLine1 := line.new(lastTradeWaveBar0, lastTradeWavePx0, lastTradeWaveBar1, lastTradeWavePx1,
                 xloc = xloc.bar_index, color = color.new(planColor, 0), width = 2)
            actionWaveLine2 := line.new(lastTradeWaveBar1, lastTradeWavePx1, lastTradeWaveBar2, lastTradeWavePx2,
                 xloc = xloc.bar_index, color = color.new(planColor, 0), width = 2)
            actionWaveLine3 := line.new(lastTradeWaveBar2, lastTradeWavePx2, lastTradeWaveBar3, lastTradeWavePx3,
                 xloc = xloc.bar_index, color = color.new(planColor, 0), width = 2)
            actionWaveLabel0 := label.new(lastTradeWaveBar0, lastTradeWavePx0, array.get(wlbl, 0),
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(planColor, 20), textcolor = color.white, size = size.tiny)
            actionWaveLabel1 := label.new(lastTradeWaveBar1, lastTradeWavePx1, array.get(wlbl, 1),
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(planColor, 20), textcolor = color.white, size = size.tiny)
            actionWaveLabel2 := label.new(lastTradeWaveBar2, lastTradeWavePx2, array.get(wlbl, 2),
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(planColor, 20), textcolor = color.white, size = size.tiny)
            actionWaveLabel3 := label.new(lastTradeWaveBar3, lastTradeWavePx3, array.get(wlbl, 3),
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(planColor, 20), textcolor = color.white, size = size.tiny)

    else if canDrawWaitNote
        actionMainLabel := label.new(lastTradeConfBar, lastTradeEntry, "WAIT\n" + actionReason,
             xloc = xloc.bar_index, yloc = yloc.price,
             style = label.style_label_left,
             color = color.new(color.yellow, 15), textcolor = color.black, size = size.small,
             tooltip = "Нет рабочего входа: late, target passed, stale, weak probability, SL zone или другой фильтр Action now.")

    if not onlyLatestSignal
        if not na(actionEntryLine)
            array.push(historicalPlanLines, actionEntryLine)
        if not na(actionSlLine)
            array.push(historicalPlanLines, actionSlLine)
        if not na(actionTp1Line)
            array.push(historicalPlanLines, actionTp1Line)
        if not na(actionTp2Line)
            array.push(historicalPlanLines, actionTp2Line)
        if not na(actionTp3Line)
            array.push(historicalPlanLines, actionTp3Line)
        if not na(actionWaveLine1)
            array.push(historicalPlanLines, actionWaveLine1)
        if not na(actionWaveLine2)
            array.push(historicalPlanLines, actionWaveLine2)
        if not na(actionWaveLine3)
            array.push(historicalPlanLines, actionWaveLine3)
        if not na(actionMainLabel)
            array.push(historicalPlanLabels, actionMainLabel)
        if not na(actionEntryLabel)
            array.push(historicalPlanLabels, actionEntryLabel)
        if not na(actionSlLabel)
            array.push(historicalPlanLabels, actionSlLabel)
        if not na(actionTp1Label)
            array.push(historicalPlanLabels, actionTp1Label)
        if not na(actionTp2Label)
            array.push(historicalPlanLabels, actionTp2Label)
        if not na(actionTp3Label)
            array.push(historicalPlanLabels, actionTp3Label)
        if not na(actionWaveLabel0)
            array.push(historicalPlanLabels, actionWaveLabel0)
        if not na(actionWaveLabel1)
            array.push(historicalPlanLabels, actionWaveLabel1)
        if not na(actionWaveLabel2)
            array.push(historicalPlanLabels, actionWaveLabel2)
        if not na(actionWaveLabel3)
            array.push(historicalPlanLabels, actionWaveLabel3)
        if not na(actionWaveBox)
            array.push(historicalPlanBoxes, actionWaveBox)
        while array.size(historicalPlanLines) > maxHistoricalSignals * 8
            line oldLine = array.shift(historicalPlanLines)
            line.delete(oldLine)
        while array.size(historicalPlanLabels) > maxHistoricalSignals * 10
            label oldLabel = array.shift(historicalPlanLabels)
            label.delete(oldLabel)
        while array.size(historicalPlanBoxes) > maxHistoricalSignals
            box oldBox = array.shift(historicalPlanBoxes)
            box.delete(oldBox)

// ───────────────────── NEELY CORE SIGNAL LAYER ─────────────────────
bool canDrawCoreSignal = showCoreSignals and showCoreMarkers and not na(lastCoreConfBar) and lastCoreSignal != "—" and not na(lastCoreEntry)
int coreKey = canDrawCoreSignal ? lastCoreConfBar * 10 + (lastCoreSignal == "IMPULSE POST" ? 1 : lastCoreSignal == "TRIANGLE THRUST" ? 2 : lastCoreSignal == "ZIGZAG REVERSAL" ? 3 : 4) : na
bool redrawCoreSignal = barstate.islast and coreKey != drawnCoreKey
if redrawCoreSignal
    if not na(coreTargetLine)
        line.delete(coreTargetLine)
    if not na(coreInvalidLine)
        line.delete(coreInvalidLine)
    if not na(coreMainLabel)
        label.delete(coreMainLabel)
    if not na(coreTargetLabel)
        label.delete(coreTargetLabel)
    if not na(coreInvalidLabel)
        label.delete(coreInvalidLabel)
    if not na(coreWaveLabel0)
        label.delete(coreWaveLabel0)
    if not na(coreWaveLabel1)
        label.delete(coreWaveLabel1)
    if not na(coreWaveLabel2)
        label.delete(coreWaveLabel2)
    if not na(coreWaveLabel3)
        label.delete(coreWaveLabel3)
    if not na(coreWaveLabel4)
        label.delete(coreWaveLabel4)
    if not na(coreWaveLabel5)
        label.delete(coreWaveLabel5)
    coreTargetLine := na
    coreInvalidLine := na
    coreMainLabel := na
    coreTargetLabel := na
    coreInvalidLabel := na
    coreWaveLabel0 := na
    coreWaveLabel1 := na
    coreWaveLabel2 := na
    coreWaveLabel3 := na
    coreWaveLabel4 := na
    coreWaveLabel5 := na
    drawnCoreKey := coreKey

    if canDrawCoreSignal
        color coreCol = coreSignalColor(lastCoreSignal, lastCoreDir)
        int coreX0 = lastCoreConfBar
        int coreX1 = lastCoreConfBar + coreLevelBars
        string coreWaveLabels = lastCoreSignal == "TRIANGLE THRUST" ? "0|a|b|c|d|e" : lastCoreWaveCount == 6 ? "0|1|2|3|4|5" : "0|A|B|C"
        array<string> coreLbls = str.split(coreWaveLabels, "|")
        coreMainLabel := label.new(coreX0, lastCoreEntry, "CORE\n" + lastCoreSignal + "\n" + lastCoreSide,
             xloc = xloc.bar_index, yloc = yloc.price,
             style = lastCoreDir >= 0 ? label.style_label_up : label.style_label_down,
             color = color.new(coreCol, 0), textcolor = color.white, size = size.small,
             tooltip = lastCoreReason + ". Research context: does not override Action now.")
        if showNeelyWaveNumbers and lastCoreWaveCount >= 4
            coreWaveLabel0 := label.new(lastCoreWaveBar0, lastCoreWavePx0, array.get(coreLbls, 0),
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(coreCol, 10), textcolor = color.white, size = size.tiny)
            coreWaveLabel1 := label.new(lastCoreWaveBar1, lastCoreWavePx1, array.get(coreLbls, 1),
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(coreCol, 10), textcolor = color.white, size = size.tiny)
            coreWaveLabel2 := label.new(lastCoreWaveBar2, lastCoreWavePx2, array.get(coreLbls, 2),
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(coreCol, 10), textcolor = color.white, size = size.tiny)
            coreWaveLabel3 := label.new(lastCoreWaveBar3, lastCoreWavePx3, array.get(coreLbls, 3),
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(coreCol, 10), textcolor = color.white, size = size.tiny)
            if lastCoreWaveCount >= 6
                coreWaveLabel4 := label.new(lastCoreWaveBar4, lastCoreWavePx4, array.get(coreLbls, 4),
                     xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                     color = color.new(coreCol, 10), textcolor = color.white, size = size.tiny)
                coreWaveLabel5 := label.new(lastCoreWaveBar5, lastCoreWavePx5, array.get(coreLbls, 5),
                     xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                     color = color.new(coreCol, 10), textcolor = color.white, size = size.tiny)
        if not na(lastCoreTarget)
            coreTargetLine := line.new(coreX0, lastCoreTarget, coreX1, lastCoreTarget,
                 xloc = xloc.bar_index, color = color.new(coreCol, 10),
                 width = 2, style = line.style_dashed)
            coreTargetLabel := label.new(coreX1, lastCoreTarget, "Core target",
                 xloc = xloc.bar_index, yloc = yloc.price,
                 style = label.style_label_left, color = color.new(coreCol, 10),
                 textcolor = color.white, size = size.tiny)
            if not na(lastCoreInvalid)
                coreInvalidLine := line.new(coreX0, lastCoreInvalid, coreX1, lastCoreInvalid,
                     xloc = xloc.bar_index, color = color.new(color.yellow, 20),
                     width = 1, style = line.style_dotted)
                coreInvalidLabel := label.new(coreX1, lastCoreInvalid, "Core invalid",
                     xloc = xloc.bar_index, yloc = yloc.price,
                     style = label.style_label_left, color = color.new(color.yellow, 20),
                     textcolor = color.black, size = size.tiny)

// ───────────────────── LIVE HYPOTHESIS LAYER ─────────────────────
if barstate.islast
    if not na(hypEntryLine)
        line.delete(hypEntryLine)
    if not na(hypStopLine)
        line.delete(hypStopLine)
    if not na(hypTp1Line)
        line.delete(hypTp1Line)
    if not na(hypTp2Line)
        line.delete(hypTp2Line)
    if not na(hypMainLabel)
        label.delete(hypMainLabel)
    if not na(hypEntryLabel)
        label.delete(hypEntryLabel)
    if not na(hypStopLabel)
        label.delete(hypStopLabel)
    if not na(hypTp1Label)
        label.delete(hypTp1Label)
    if not na(hypTp2Label)
        label.delete(hypTp2Label)
    if not na(hypWaveLabel0)
        label.delete(hypWaveLabel0)
    if not na(hypWaveLabel1)
        label.delete(hypWaveLabel1)
    if not na(hypWaveLabel2)
        label.delete(hypWaveLabel2)
    if not na(hypWaveLabel3)
        label.delete(hypWaveLabel3)
    if not na(hypWaveLabel4)
        label.delete(hypWaveLabel4)
    if not na(hypWaveLabel5)
        label.delete(hypWaveLabel5)
    hypEntryLine := na
    hypStopLine := na
    hypTp1Line := na
    hypTp2Line := na
    hypMainLabel := na
    hypEntryLabel := na
    hypStopLabel := na
    hypTp1Label := na
    hypTp2Label := na
    hypWaveLabel0 := na
    hypWaveLabel1 := na
    hypWaveLabel2 := na
    hypWaveLabel3 := na
    hypWaveLabel4 := na
    hypWaveLabel5 := na

    if showLiveHypothesis and hasLiveHypothesis
        color hypColNow = hypColor(liveHypothesisProb, liveHypothesisTradeDir, liveHypothesisReady)
        int hypX0 = bar_index
        int hypX1 = bar_index + hypothesisLevelBars
        string hypTip = "Live hypothesis, not confirmed. Current wave moves " + hypDirText(liveHypothesisMoveDir) +
             "; expected trade is " + hypSideText(liveHypothesisTradeDir) + ". " + liveHypothesisReason +
             ". Source: " + liveHypothesisSource
        if showHypothesisLevels and not na(liveHypothesisEntry)
            hypEntryLine := line.new(hypX0, liveHypothesisEntry, hypX1, liveHypothesisEntry,
                 xloc = xloc.bar_index, color = color.new(hypColNow, 0), width = 2, style = line.style_dashed)
            hypMainLabel := label.new(hypX0, liveHypothesisEntry,
                 "LIVE\n" + liveHypothesisName + "\n" + liveHypothesisState + "\nP≈" + str.tostring(liveHypothesisProb, "#.0") + "% / " + liveHypothesisGrade,
                 xloc = xloc.bar_index, yloc = yloc.price,
                 style = liveHypothesisTradeDir >= 0 ? label.style_label_up : label.style_label_down,
                 color = hypColNow, textcolor = liveHypothesisReady ? color.white : color.black, size = size.small,
                 tooltip = hypTip)
            hypEntryLabel := label.new(hypX1, liveHypothesisEntry, liveHypothesisReady ? "Hyp entry" : "Hyp zone",
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
                 color = color.new(hypColNow, 10), textcolor = liveHypothesisReady ? color.white : color.black, size = size.tiny)
        if showHypothesisLevels and not na(liveHypothesisInvalid)
            hypStopLine := line.new(hypX0, liveHypothesisInvalid, hypX1, liveHypothesisInvalid,
                 xloc = xloc.bar_index, color = color.new(color.yellow, 0), width = 2, style = line.style_solid)
            hypStopLabel := label.new(hypX1, liveHypothesisInvalid, "Hyp invalid / SL",
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
                 color = color.new(color.yellow, 0), textcolor = color.black, size = size.tiny)
        if showHypothesisLevels and not na(liveHypothesisTp1)
            hypTp1Line := line.new(hypX0, liveHypothesisTp1, hypX1, liveHypothesisTp1,
                 xloc = xloc.bar_index, color = color.new(color.lime, 15), width = 2, style = line.style_dotted)
            hypTp1Label := label.new(hypX1, liveHypothesisTp1, "Hyp TP1",
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
                 color = color.new(color.lime, 15), textcolor = color.white, size = size.tiny)
        if showHypothesisLevels and not na(liveHypothesisTp2)
            hypTp2Line := line.new(hypX0, liveHypothesisTp2, hypX1, liveHypothesisTp2,
                 xloc = xloc.bar_index, color = color.new(color.aqua, 20), width = 1, style = line.style_dotted)
            hypTp2Label := label.new(hypX1, liveHypothesisTp2, "Hyp TP2",
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
                 color = color.new(color.aqua, 20), textcolor = color.white, size = size.tiny)
        if showHypothesisWaveLabels and liveHypothesisWaveCount >= 4 and liveHypothesisLabels != ""
            array<string> hypLbls = str.split(liveHypothesisLabels, "|")
            hypWaveLabel0 := label.new(liveHypWaveBar0, liveHypWavePx0, array.get(hypLbls, 0),
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(hypColNow, 0), textcolor = liveHypothesisReady ? color.white : color.black, size = size.small)
            hypWaveLabel1 := label.new(liveHypWaveBar1, liveHypWavePx1, array.get(hypLbls, 1),
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(hypColNow, 0), textcolor = liveHypothesisReady ? color.white : color.black, size = size.small)
            hypWaveLabel2 := label.new(liveHypWaveBar2, liveHypWavePx2, array.get(hypLbls, 2),
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(hypColNow, 0), textcolor = liveHypothesisReady ? color.white : color.black, size = size.small)
            hypWaveLabel3 := label.new(liveHypWaveBar3, liveHypWavePx3, array.get(hypLbls, 3),
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                 color = color.new(hypColNow, 0), textcolor = liveHypothesisReady ? color.white : color.black, size = size.small)
            if liveHypothesisWaveCount >= 6 and array.size(hypLbls) >= 6
                hypWaveLabel4 := label.new(liveHypWaveBar4, liveHypWavePx4, array.get(hypLbls, 4),
                     xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                     color = color.new(hypColNow, 0), textcolor = liveHypothesisReady ? color.white : color.black, size = size.small)
                hypWaveLabel5 := label.new(liveHypWaveBar5, liveHypWavePx5, array.get(hypLbls, 5),
                     xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_center,
                     color = color.new(hypColNow, 0), textcolor = liveHypothesisReady ? color.white : color.black, size = size.small)

// ───────────────────── HTF WAVE-3 BIAS LAYER ─────────────────────
if barstate.islast
    if not na(htfW3InvalidLine)
        line.delete(htfW3InvalidLine)
    if not na(htfW3Target1Line)
        line.delete(htfW3Target1Line)
    if not na(htfW3Target2Line)
        line.delete(htfW3Target2Line)
    if not na(htfW3MainLabel)
        label.delete(htfW3MainLabel)
    if not na(htfW3InvalidLabel)
        label.delete(htfW3InvalidLabel)
    if not na(htfW3Target1Label)
        label.delete(htfW3Target1Label)
    if not na(htfW3Target2Label)
        label.delete(htfW3Target2Label)
    htfW3InvalidLine := na
    htfW3Target1Line := na
    htfW3Target2Line := na
    htfW3MainLabel := na
    htfW3InvalidLabel := na
    htfW3Target1Label := na
    htfW3Target2Label := na

    if showHtfWave3Bias and htfWave3BiasActive
        color w3Col = htfWave3Dir > 0 ? color.new(color.lime, 0) : color.new(color.red, 0)
        int w3X0 = bar_index
        int w3X1 = bar_index + htfWave3LevelBars
        htfW3MainLabel := label.new(w3X1, activeHPrice,
             "HTF W3\n" + (htfWave3Dir > 0 ? "BUY PULLBACKS" : "SELL PULLBACKS") + "\nP≈" + str.tostring(htfWave3Prob, "#.0") + "%",
             xloc = xloc.bar_index, yloc = yloc.price,
             style = label.style_label_left,
             color = w3Col, textcolor = color.white, size = size.small,
             tooltip = htfWave3Reason + ". LTF rule: trade pullbacks only in HTF W3 direction.")
        if not na(htfWave3Invalid)
            htfW3InvalidLine := line.new(w3X0, htfWave3Invalid, w3X1, htfWave3Invalid,
                 xloc = xloc.bar_index, color = color.new(color.yellow, 0), width = 2, style = line.style_solid)
            htfW3InvalidLabel := label.new(w3X1, htfWave3Invalid, "HTF W2 invalid",
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
                 color = color.new(color.yellow, 0), textcolor = color.black, size = size.tiny)
        if not na(htfWave3Target1)
            htfW3Target1Line := line.new(w3X0, htfWave3Target1, w3X1, htfWave3Target1,
                 xloc = xloc.bar_index, color = color.new(w3Col, 15), width = 2, style = line.style_dashed)
            htfW3Target1Label := label.new(w3X1, htfWave3Target1, "HTF W3 TP1 1.618",
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
                 color = color.new(w3Col, 15), textcolor = color.white, size = size.tiny)
        if not na(htfWave3Target2)
            htfW3Target2Line := line.new(w3X0, htfWave3Target2, w3X1, htfWave3Target2,
                 xloc = xloc.bar_index, color = color.new(w3Col, 35), width = 1, style = line.style_dotted)
            htfW3Target2Label := label.new(w3X1, htfWave3Target2, "HTF W3 TP2 2.618",
                 xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left,
                 color = color.new(w3Col, 35), textcolor = color.white, size = size.tiny)

// ──────────────────────── ИНФО-ПАНЕЛЬ ────────────────────────────
alertcondition(actionBuySignal, "EWB Action BUY", "EWB Action now BUY on {{ticker}} {{interval}}")
alertcondition(actionSellSignal, "EWB Action SELL", "EWB Action now SELL on {{ticker}} {{interval}}")
alertcondition(coreSignalEvent, "EWB Neely Core Signal", "EWB Neely Core signal on {{ticker}} {{interval}}")
alertcondition(coreImpulseEvent, "EWB Core IMPULSE POST", "EWB Neely Core impulse post-pattern on {{ticker}} {{interval}}")
alertcondition(coreTriangleEvent, "EWB Core TRIANGLE THRUST", "EWB Neely Core triangle thrust on {{ticker}} {{interval}}")
alertcondition(coreZigzagEvent, "EWB Core ZIGZAG REVERSAL", "EWB Neely Core zigzag reversal context on {{ticker}} {{interval}}")
alertcondition(coreMovingCorrEvent, "EWB Core MOVING CORR", "EWB Neely Core moving correction research signal on {{ticker}} {{interval}}")
alertcondition(liveHypothesisReadyEvent, "EWB Live Hypothesis Ready", "EWB live structure hypothesis is ready on {{ticker}} {{interval}}")

string actionAlertMessage = "EWB " + actionNow + " | " + syminfo.ticker + " " + timeframe.period +
     " | " + lastTradeType + " | Grade " + signalGradeNow +
     " | Entry " + (na(lastTradeEntry) ? "n/a" : str.tostring(lastTradeEntry, format.mintick)) +
     " | SL " + (na(lastTradeSl) ? "n/a" : str.tostring(lastTradeSl, format.mintick)) +
     " | TP " + (na(lastTradeTp) ? "n/a" : str.tostring(lastTradeTp, format.mintick)) +
     " | P " + (na(lastTradeProb) ? "n/a" : str.tostring(lastTradeProb, "#.0") + "%") +
     " | RR " + (na(actionRR) ? "n/a" : str.tostring(actionRR, "#.00")) +
     " | " + actionReason
string coreAlertMessage = "EWB CORE | " + syminfo.ticker + " " + timeframe.period +
     " | " + lastCoreSignal + " | " + lastCoreSide +
     " | Entry " + (na(lastCoreEntry) ? "n/a" : str.tostring(lastCoreEntry, format.mintick)) +
     " | Target " + (na(lastCoreTarget) ? "n/a" : str.tostring(lastCoreTarget, format.mintick)) +
     " | Invalid " + (na(lastCoreInvalid) ? "n/a" : str.tostring(lastCoreInvalid, format.mintick)) +
     " | " + lastCoreReason
string hypothesisAlertMessage = "EWB LIVE HYPOTHESIS | " + syminfo.ticker + " " + timeframe.period +
     " | " + liveHypothesisName + " | " + liveHypothesisState +
     " | P " + (na(liveHypothesisProb) ? "n/a" : str.tostring(liveHypothesisProb, "#.0") + "%") +
     " | Entry " + (na(liveHypothesisEntry) ? "n/a" : str.tostring(liveHypothesisEntry, format.mintick)) +
     " | Invalid " + (na(liveHypothesisInvalid) ? "n/a" : str.tostring(liveHypothesisInvalid, format.mintick)) +
     " | TP1 " + (na(liveHypothesisTp1) ? "n/a" : str.tostring(liveHypothesisTp1, format.mintick)) +
     " | " + liveHypothesisReason
bool soundAlertBarOK = soundAlertsOnClose ? barstate.isconfirmed : true
if enableActionSoundAlerts and soundAlertBarOK and (actionBuySignal or actionSellSignal)
    alert(actionAlertMessage, soundAlertsOnClose ? alert.freq_once_per_bar_close : alert.freq_once_per_bar)
if enableCoreSoundAlerts and soundAlertBarOK and coreSignalEvent
    alert(coreAlertMessage, soundAlertsOnClose ? alert.freq_once_per_bar_close : alert.freq_once_per_bar)
if enableHypothesisSoundAlerts and soundAlertBarOK and liveHypothesisReadyEvent
    alert(hypothesisAlertMessage, soundAlertsOnClose ? alert.freq_once_per_bar_close : alert.freq_once_per_bar)

panelPosition = panelPositionInput == "Top right" ? position.top_right : panelPositionInput == "Bottom right" ? position.bottom_right : position.middle_right
var table info = table.new(panelPosition, 2, 22, border_width = 1)
if showTradePanel and barstate.islast
    if simpleAntonPanel
        table.cell(info, 0, 0, "Anton decision", text_color = color.white, bgcolor = color.new(color.gray, 10))
        table.cell(info, 1, 0, antonDecision, text_color = color.white,
             bgcolor = antonDecision == "ENTER LONG" or antonDecision == "EARLY LONG" or antonDecision == "WAIT PULLBACK LONG" ? color.new(color.lime, 20) : antonDecision == "ENTER SHORT" or antonDecision == "EARLY SHORT" or antonDecision == "WAIT PULLBACK SHORT" ? color.new(color.red, 20) : antonDecision == "WATCH LONG" or antonDecision == "WATCH SHORT" or antonDecision == "WAIT / NO COUNTER" ? color.new(color.yellow, 15) : antonDecision == "EXIT" ? color.new(color.orange, 15) : color.new(color.gray, 45))
        table.cell(info, 0, 1, "Levels", text_color = color.white, bgcolor = color.new(color.gray, 35))
        table.cell(info, 1, 1, displayLevels, text_color = color.white, bgcolor = color.new(color.gray, 70))
        table.cell(info, 0, 2, "Probability", text_color = color.white, bgcolor = color.new(color.gray, 35))
        table.cell(info, 1, 2, displayProbabilityMove, text_color = color.white, bgcolor = useLiveHypothesisDecision ? hypColor(liveHypothesisProb, liveHypothesisTradeDir, liveHypothesisReady) : useHtfWave3WaitDecision ? coreSignalColor("IMPULSE POST", htfWave3Dir) : actionableTradeSymbol ? actionColor(actionNow) : decisionModeColor)
        table.cell(info, 0, 3, "Reason", text_color = color.white, bgcolor = color.new(color.gray, 35))
        table.cell(info, 1, 3, antonRule, text_color = useLiveHypothesisDecision and not liveHypothesisReady ? color.black : color.white, bgcolor = useLiveHypothesisDecision ? hypColor(liveHypothesisProb, liveHypothesisTradeDir, liveHypothesisReady) : useHtfWave3WaitDecision ? coreSignalColor("IMPULSE POST", htfWave3Dir) : actionColor(actionNow))
        table.cell(info, 0, 4, "Last bar wave", text_color = color.white, bgcolor = color.new(color.gray, 35))
        table.cell(info, 1, 4, activeCInfo, text_color = color.white,
             bgcolor = zC.dir > 0 ? color.new(colCUp, 55) : zC.dir < 0 ? color.new(colCDn, 55) : color.new(color.gray, 70))
        table.cell(info, 0, 5, "Live hypothesis", text_color = color.white, bgcolor = color.new(color.gray, 35))
        table.cell(info, 1, 5, displayPatternNow, text_color = useLiveHypothesisDecision and not liveHypothesisReady ? color.black : color.white, bgcolor = hasLiveHypothesis ? hypColor(liveHypothesisProb, liveHypothesisTradeDir, liveHypothesisReady) : htfWave3BiasActive ? coreSignalColor("IMPULSE POST", htfWave3Dir) : color.new(color.gray, 70))
        table.cell(info, 0, 6, "TF plan", text_color = color.white, bgcolor = color.new(color.gray, 35))
        table.cell(info, 1, 6, tfPlanShort, text_color = color.white, bgcolor = color.new(color.gray, 70))
        for clearRow = 7 to 21
            table.cell(info, 0, clearRow, "", bgcolor = color.new(color.black, 100))
            table.cell(info, 1, clearRow, "", bgcolor = color.new(color.black, 100))
    else
        table.cell(info, 0, 0, "EWB Market", text_color = color.white, bgcolor = color.new(color.gray, 10))
        table.cell(info, 1, 0, marketBannerText, text_color = color.white, bgcolor = marketBannerColor)
        table.cell(info, 0, 1, "Can trade?", text_color = color.white, bgcolor = color.new(color.gray, 20))
        table.cell(info, 1, 1, canTradeLabel, text_color = color.white,
             bgcolor = actionableTradeSymbol ? color.new(color.lime, 40) : color.new(color.orange, 20))
        table.cell(info, 0, 2, "Action now", text_color = color.white, bgcolor = color.new(color.gray, 20))
        table.cell(info, 1, 2, actionNow, text_color = color.white, bgcolor = actionColor(actionNow))
        table.cell(info, 0, 3, "Reason", text_color = color.white, bgcolor = color.new(color.gray, 45))
        table.cell(info, 1, 3, actionReason, text_color = color.white, bgcolor = actionColor(actionNow))
        table.cell(info, 0, 4, "Mode", text_color = color.white, bgcolor = color.new(color.gray, 30))
        table.cell(info, 1, 4, decisionMode, text_color = color.white, bgcolor = decisionModeColor)
        table.cell(info, 0, 5, "Trade", text_color = color.white, bgcolor = color.new(color.gray, 35))
        table.cell(info, 1, 5, displayTradeSide, text_color = color.white,
             bgcolor = tradeStatusColor(displayTradeStatus, displayTradeSide))
        table.cell(info, 0, 6, "Фигура", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 6, displayTradeType, text_color = color.white, bgcolor = color.new(color.gray, 70))
        table.cell(info, 0, 7, "Status", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 7, displayTradeStatus + (actionableTradeSymbol and not na(lastTradeAge) ? " / " + str.tostring(lastTradeAge) + "b" : ""),
             text_color = color.white, bgcolor = tradeStatusColor(displayTradeStatus, displayTradeSide))
        table.cell(info, 0, 8, "P≈", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 8, displayTradeProb, text_color = color.white, bgcolor = color.new(color.gray, 70))
        table.cell(info, 0, 9, "Grade", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 9, displaySignalGrade, text_color = color.white, bgcolor = actionableTradeSymbol ? actionColor(actionNow) : decisionModeColor)
        table.cell(info, 0, 10, "n / conf", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 10, displaySampleConf, text_color = color.white, bgcolor = color.new(color.gray, 70))
        table.cell(info, 0, 11, "Entry / TP", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 11, displayEntryTp, text_color = color.white, bgcolor = color.new(color.gray, 70))
        table.cell(info, 0, 12, "SL / invalid", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 12, displaySl, text_color = color.white, bgcolor = color.new(color.gray, 70))
        table.cell(info, 0, 13, "RR / progress", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 13, displayRrProgress, text_color = color.white, bgcolor = color.new(color.gray, 70))
        table.cell(info, 0, 14, "HTF bias/W3", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 14, htfWave3BiasActive ? displayHtfWave3 : htfActionMode + " / " + htfBias, text_color = color.white,
             bgcolor = htfWave3BiasActive ? coreSignalColor("IMPULSE POST", htfWave3Dir) : htfBiasDir > 0 ? color.new(color.lime, 45) : htfBiasDir < 0 ? color.new(color.red, 45) : color.new(color.gray, 70))
        table.cell(info, 0, 15, "Asset / Market", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 15, assetClassLabel + " / " + displayMarket, text_color = color.white,
             bgcolor = actionableTradeSymbol ? color.new(color.lime, 55) : cryptoResearchMarket ? color.new(color.orange, 35) : color.new(color.gray, 70))
        table.cell(info, 0, 16, "Calib / TF", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 16, displayCalibration, text_color = color.white, bgcolor = color.new(color.gray, 70))
        table.cell(info, 0, 17, "Live hypothesis", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 17, displayPatternNow, text_color = hasLiveHypothesis and not liveHypothesisReady ? color.black : color.white,
             bgcolor = hasLiveHypothesis ? hypColor(liveHypothesisProb, liveHypothesisTradeDir, liveHypothesisReady) : htfWave3BiasActive ? coreSignalColor("IMPULSE POST", htfWave3Dir) : color.new(color.gray, 70))
        table.cell(info, 0, 18, "Hyp levels", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 18, displayLiveContextLevels,
             text_color = color.white, bgcolor = color.new(color.gray, 70))
        table.cell(info, 0, 19, "Neely Core", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 19, displayCoreSignal + (showCoreSignals and not na(lastCoreAge) ? " / " + str.tostring(lastCoreAge) + "b" : ""), text_color = color.white,
             bgcolor = coreSignalColor(lastCoreSignal, lastCoreDir))
        table.cell(info, 0, 20, "Active CTF wave", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 20, activeCInfo, text_color = color.white,
             bgcolor = zC.dir > 0 ? color.new(colCUp, 55) : zC.dir < 0 ? color.new(colCDn, 55) : color.new(color.gray, 70))
        table.cell(info, 0, 21, "Active HTF wave", text_color = color.white, bgcolor = color.new(color.gray, 50))
        table.cell(info, 1, 21, activeHtfDisplay, text_color = color.white,
             bgcolor = htfBiasDir > 0 ? color.new(color.lime, 55) : htfBiasDir < 0 ? color.new(color.red, 55) : color.new(color.gray, 70))
