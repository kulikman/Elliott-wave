<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.anton.elliott-wave.daily-report</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/DEV/Elliott-wave/scripts/run_daily_report.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/DEV/Elliott-wave</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>45</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/DEV/Elliott-wave/brain-output/signals/logs/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/DEV/Elliott-wave/brain-output/signals/logs/launchd.err.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
